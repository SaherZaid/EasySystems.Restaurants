@page "/admin/restaurants/{RestaurantId:int}/legal"
@rendermode InteractiveServer

@using EasySystems.Restaurants.Data
@using EasySystems.Restaurants.Models
@using EasySystems.Restaurants.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize]

@inject ApplicationDbContext Db
@inject RestaurantAccessService AccessService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Legal Pages</PageTitle>

@if (restaurant is not null && isAuthorized)
{
    <AdminNavbar RestaurantId="RestaurantId" RestaurantSlug="@restaurant.Slug" />
}

@if (!checkedAccess)
{
    <div class="public-loading">Checking access...</div>
}
else if (!isAuthorized)
{
    <div class="public-loading">Redirecting...</div>
}
else
{
    <div class="admin-page">
        <div class="admin-header">
            <div>
                <p class="eyebrow">Legal Pages</p>
                <h1>@(restaurant?.Name ?? "Restaurant")</h1>
                <p class="subtitle">Manage Privacy Policy and Terms & Conditions.</p>
            </div>
        </div>

        @if (restaurant is null)
        {
            <div class="form-card">
                <h2>Restaurant not found</h2>
            </div>
        }
        else
        {
            <EditForm Model="privacy" OnValidSubmit="SavePages">
                <div class="admin-grid">

                    <div class="form-card">
                        <h2>Privacy Policy</h2>

                        <label>Title</label>
                        <InputText class="input" @bind-Value="privacy.Title" />

                        <label>Content</label>
                        <InputTextArea class="input textarea legal-area"
                                       @bind-Value="privacy.Content" />

                        <label class="checkbox-label">
                            <InputCheckbox @bind-Value="privacy.IsPublished" />
                            Published
                        </label>
                    </div>

                    <div class="form-card">
                        <h2>Terms & Conditions</h2>

                        <label>Title</label>
                        <InputText class="input" @bind-Value="terms.Title" />

                        <label>Content</label>
                        <InputTextArea class="input textarea legal-area"
                                       @bind-Value="terms.Content" />

                        <label class="checkbox-label">
                            <InputCheckbox @bind-Value="terms.IsPublished" />
                            Published
                        </label>
                    </div>
                </div>

                <div class="form-card" style="margin-top:20px;">
                    <button class="save-btn" type="submit">
                        Save legal pages
                    </button>

                    @if (!string.IsNullOrWhiteSpace(message))
                    {
                        <div class="upload-success">@message</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="error">@errorMessage</div>
                    }
                </div>
            </EditForm>
        }
    </div>
}

@code {
    [Parameter]
    public int RestaurantId { get; set; }

    private Restaurant? restaurant;

    private RestaurantLegalPage privacy = new()
        {
            PageType = "Privacy",
            Title = "Privacy Policy"
        };

    private RestaurantLegalPage terms = new()
        {
            PageType = "Terms",
            Title = "Terms & Conditions"
        };

    private string? message;
    private string? errorMessage;

    private bool checkedAccess;
    private bool isAuthorized;

    protected override async Task OnParametersSetAsync()
    {
        checkedAccess = false;
        isAuthorized = false;
        message = null;
        errorMessage = null;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        isAuthorized = await AccessService.CanManageRestaurantLegalAsync(
            authState.User,
            RestaurantId);

        checkedAccess = true;

        if (!isAuthorized)
        {
            Navigation.NavigateTo("/Account/Denied", true);
            return;
        }

        restaurant = await Db.Restaurants
            .FirstOrDefaultAsync(x => x.Id == RestaurantId);

        if (restaurant is null)
            return;

        var pages = await Db.RestaurantLegalPages
            .Where(x => x.RestaurantId == RestaurantId)
            .ToListAsync();

        privacy = pages.FirstOrDefault(x => x.PageType == "Privacy")
            ?? new RestaurantLegalPage
                {
                    RestaurantId = RestaurantId,
                    PageType = "Privacy",
                    Title = "Privacy Policy"
                };

        terms = pages.FirstOrDefault(x => x.PageType == "Terms")
            ?? new RestaurantLegalPage
                {
                    RestaurantId = RestaurantId,
                    PageType = "Terms",
                    Title = "Terms & Conditions"
                };
    }

    private async Task SavePages()
    {
        message = null;
        errorMessage = null;

        if (!isAuthorized)
            return;

        if (restaurant is null)
        {
            errorMessage = "Restaurant not found.";
            return;
        }

        privacy.RestaurantId = RestaurantId;
        privacy.PageType = "Privacy";
        privacy.UpdatedAt = DateTime.UtcNow;

        terms.RestaurantId = RestaurantId;
        terms.PageType = "Terms";
        terms.UpdatedAt = DateTime.UtcNow;

        SaveSinglePage(privacy);
        SaveSinglePage(terms);

        await Db.SaveChangesAsync();

        message = "Saved successfully.";
    }

    private void SaveSinglePage(RestaurantLegalPage page)
    {
        if (page.Id == 0)
        {
            Db.RestaurantLegalPages.Add(page);
        }
        else
        {
            Db.RestaurantLegalPages.Update(page);
        }
    }
}