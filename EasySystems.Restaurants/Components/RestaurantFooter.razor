@using EasySystems.Restaurants.Models

<footer class="restaurant-footer"
        style="@GetFooterStyle()">
    <div class="restaurant-footer-inner">
        <div class="footer-brand">
            @if (Restaurant?.ShowFooterLogo == true)
            {
                @if (!string.IsNullOrWhiteSpace(Restaurant.LogoUrl))
                {
                    <img src="@Restaurant.LogoUrl" alt="@Restaurant.Name logo" />
                }
                else
                {
                    <span>@GetInitials()</span>
                }
            }

            <div>
                <strong style="color:@GetValue(Restaurant?.FooterHeadingColor, "#FFFFFF")">
                    @DisplayOrFallback(Restaurant?.FooterTitle, Restaurant?.Name ?? "Restaurang")
                </strong>

                <p style="color:@GetValue(Restaurant?.FooterMutedTextColor, "#A1A1AA")">
                    @DisplayOrFallback(Restaurant?.FooterDescription, Restaurant?.Address ?? "")
                </p>
            </div>
        </div>

        @if (Restaurant?.ShowFooterLegalLinks == true)
        {
            <div class="footer-links">
                <a style="@GetFooterLinkStyle()" href="/restaurant/@Restaurant?.Slug">Hem</a>
                <a style="@GetFooterLinkStyle()" href="/restaurant/@Restaurant?.Slug#menu">Meny</a>
                <a style="@GetFooterLinkStyle()" href="/restaurant/@Restaurant?.Slug/contact">Kontakt & öppettider</a>
                <a style="@GetFooterLinkStyle()" href="/restaurant/@Restaurant?.Slug/privacy">Integritet</a>
                <a style="@GetFooterLinkStyle()" href="/restaurant/@Restaurant?.Slug/terms">Villkor</a>
            </div>
        }

        @if (Restaurant?.ShowFooterSocialLinks == true)
        {
            <div class="footer-socials">
                @if (!string.IsNullOrWhiteSpace(Restaurant?.InstagramUrl))
                {
                    <a style="@GetFooterLinkStyle()" href="@Restaurant.InstagramUrl" target="_blank">Instagram</a>
                }

                @if (!string.IsNullOrWhiteSpace(Restaurant?.FacebookUrl))
                {
                    <a style="@GetFooterLinkStyle()" href="@Restaurant.FacebookUrl" target="_blank">Facebook</a>
                }

                @if (!string.IsNullOrWhiteSpace(Restaurant?.TikTokUrl))
                {
                    <a style="@GetFooterLinkStyle()" href="@Restaurant.TikTokUrl" target="_blank">TikTok</a>
                }

                @if (!string.IsNullOrWhiteSpace(Restaurant?.WebsiteUrl))
                {
                    <a style="@GetFooterLinkStyle()" href="@Restaurant.WebsiteUrl" target="_blank">Website</a>
                }
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(GetCopyrightText()))
    {
        <div class="restaurant-footer-bottom"
             style="border-top:1px solid @GetValue(Restaurant?.FooterBorderColor, "#2A2A2A"); color:@GetValue(Restaurant?.FooterMutedTextColor, "#A1A1AA");">
            @GetCopyrightText()
        </div>
    }
</footer>

@code {
    [Parameter]
    public Restaurant? Restaurant { get; set; }

    private string GetFooterStyle()
    {
        return
            $"--footer-bg:{GetFooterBackground()};" +
            $"--footer-text:{GetFooterText()};" +
            $"--primary:{GetPrimary()};" +
            $"--footer-link:{GetValue(Restaurant?.FooterLinkColor, "#FFFFFF")};" +
            $"--footer-link-hover:{GetValue(Restaurant?.FooterLinkHoverColor, GetPrimary())};" +
            $"background:{GetFooterBackground()};" +
            $"color:{GetFooterText()};" +
            $"border-top:1px solid {GetValue(Restaurant?.FooterBorderColor, "#2A2A2A")};";
    }

    private string GetFooterLinkStyle()
    {
        return $"color:{GetValue(Restaurant?.FooterLinkColor, "#FFFFFF")};";
    }

    private string GetFooterBackground()
        => GetValue(Restaurant?.FooterBackgroundColor, "#111827");

    private string GetFooterText()
        => GetValue(Restaurant?.FooterTextColor, "#FFFFFF");

    private string GetPrimary()
        => GetValue(Restaurant?.PrimaryColor, "#111827");

    private string GetValue(string? value, string fallback)
        => string.IsNullOrWhiteSpace(value) ? fallback : value;

    private string DisplayOrFallback(string? value, string fallback)
        => string.IsNullOrWhiteSpace(value) ? fallback : value;

    private string GetCopyrightText()
    {
        if (!string.IsNullOrWhiteSpace(Restaurant?.FooterCopyrightText))
            return Restaurant.FooterCopyrightText;

        if (!string.IsNullOrWhiteSpace(Restaurant?.Name))
            return $"© {DateTime.Now.Year} {Restaurant.Name}. Alla rättigheter förbehållna.";

        return string.Empty;
    }

    private string GetInitials()
    {
        if (Restaurant is null || string.IsNullOrWhiteSpace(Restaurant.Name))
            return "R";

        var words = Restaurant.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Join("", words.Take(2).Select(x => x[0])).ToUpper();
    }
}