@page "/admin/restaurants/{RestaurantId:int}/owner"
@rendermode InteractiveServer

@using EasySystems.Restaurants.Data
@using EasySystems.Restaurants.Models
@using EasySystems.Restaurants.Services
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize]

@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation
@inject RestaurantAccessService AccessService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Användare och behörigheter</PageTitle>

@if (restaurant is not null && isAuthorized)
{
    <AdminNavbar RestaurantId="RestaurantId" RestaurantSlug="@restaurant.Slug" />
}

@if (!checkedAccess)
{
    <div class="public-loading">Kontrollerar behörighet...</div>
}
else if (!isAuthorized)
{
    <div class="public-loading">Omdirigerar...</div>
}
else
{
    <div class="admin-page">
        <div class="admin-header">
            <div>
                <p class="eyebrow">Användare och behörigheter</p>
                <h1>@(restaurant?.Name ?? "Restaurang")</h1>
                <p class="subtitle">
                    Här kan du lägga till användare, välja roll och styra vem som får administrera restaurangen.
                </p>
            </div>
        </div>

        @if (restaurant is null)
        {
            <div class="form-card admin-center-card">
                <h2>Restaurangen hittades inte</h2>
            </div>
        }
        else
        {
            <div class="access-layout">
                <div class="form-card">
                    <h2>Lägg till eller ändra användare</h2>
                    <p class="subtitle">
                        Sök efter en användare, välj en roll och klicka sedan på spara.
                    </p>

                    <label>Sök användare</label>
                    <input class="input"
                           value="@searchText"
                           @oninput="OnSearchChanged"
                           placeholder="Sök via e-post, användarnamn eller telefon..." />

                    <div class="user-search-list">
                        @if (!FilteredUsers.Any())
                        {
                            <div class="empty-category">
                                Ingen användare hittades.
                            </div>
                        }
                        else
                        {
                            @foreach (var user in FilteredUsers)
                            {
                                <button type="button"
                                        class="user-search-item @(selectedUserId == user.Id ? "selected" : "")"
                                        @onclick="() => SelectUser(user)">
                                    <div>
                                        <strong>@DisplayUser(user)</strong>
                                        <span>@DisplayUserSubText(user)</span>
                                    </div>

                                    @if (selectedUserId == user.Id)
                                    {
                                        <small>Vald</small>
                                    }
                                </button>
                            }
                        }
                    </div>

                    @if (selectedUser is not null)
                    {
                        <div class="owner-highlight" style="margin-top:18px;">
                            <span>Vald användare</span>
                            <strong>@DisplayUser(selectedUser)</strong>
                            <p>@DisplayUserSubText(selectedUser)</p>
                        </div>
                    }

                    <label>Välj roll</label>

                    <div class="role-picker">
                        <button type="button"
                                class="role-option @(selectedAccessRole == "Customer" ? "selected" : "")"
                                @onclick='() => SelectRole("Customer")'>
                            <strong>Kund</strong>
                            <span>Kan beställa mat men får ingen adminåtkomst.</span>
                        </button>

                        <button type="button"
                                class="role-option @(selectedAccessRole == "RestaurantAdmin" ? "selected" : "")"
                                @onclick='() => SelectRole("RestaurantAdmin")'>
                            <strong>Restaurangadmin</strong>
                            <span>Kan hantera meny, kategorier, tillval och beställningar.</span>
                        </button>

                        <button type="button"
                                class="role-option @(selectedAccessRole == "RestaurantOwner" ? "selected" : "")"
                                @onclick='() => SelectRole("RestaurantOwner")'>
                            <strong>Restaurangägare</strong>
                            <span>Har full åtkomst till denna restaurang och användare.</span>
                        </button>
                    </div>

                    <button class="save-btn" type="button" @onclick="SaveAccess">
                        Spara roll
                    </button>

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="error">@errorMessage</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(successMessage))
                    {
                        <div class="upload-success">@successMessage</div>
                    }
                </div>

                <div class="preview-card">
                    <p class="preview-label">Nuvarande behörigheter</p>

                    <div class="owner-highlight">
                        <span>Huvudägare</span>

                        @if (currentOwner is null)
                        {
                            <strong>Ingen huvudägare vald</strong>
                            <p>Välj rollen Restaurangägare för att sätta en huvudägare.</p>
                        }
                        else
                        {
                            <strong>@DisplayUser(currentOwner)</strong>
                            <p>@currentOwner.Email</p>
                        }
                    </div>

                    @if (accesses.Count == 0)
                    {
                        <div class="empty-menu">
                            <h3>Inga användare har adminåtkomst</h3>
                            <p>Lägg till en restaurangägare eller restaurangadmin.</p>
                        </div>
                    }
                    else
                    {
                        <div class="access-list">
                            @foreach (var access in accesses)
                            {
                                <div class="access-card">
                                    <div>
                                        <strong>@DisplayUser(access.User)</strong>
                                        <span>@access.User?.Email</span>

                                        <small class="@GetRoleClass(access.Role)">
                                            @FormatRole(access.Role)
                                        </small>
                                    </div>

                                    <div class="access-actions">
                                        @if (access.Role != "RestaurantOwner")
                                        {
                                            <button type="button" @onclick='() => ChangeAccessRole(access, "RestaurantOwner")'>
                                                Gör till ägare
                                            </button>
                                        }

                                        @if (access.Role != "RestaurantAdmin")
                                        {
                                            <button type="button" @onclick='() => ChangeAccessRole(access, "RestaurantAdmin")'>
                                                Gör till admin
                                            </button>
                                        }

                                        <button type="button" @onclick='() => ChangeAccessRole(access, "Customer")'>
                                            Gör till kund
                                        </button>

                                        <button type="button" class="danger-btn" @onclick="() => RemoveAccess(access)">
                                            Ta bort åtkomst
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <div class="restaurant-admin-actions" style="margin-top:18px;">
                        <button type="button" @onclick="BackToRestaurants">Tillbaka</button>
                        <button type="button" @onclick="ViewRestaurant">Visa restaurang</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public int RestaurantId { get; set; }

    private Restaurant? restaurant;
    private ApplicationUser? currentOwner;
    private ApplicationUser? selectedUser;

    private List<ApplicationUser> users = [];
    private List<RestaurantUserAccess> accesses = [];
    private HashSet<string> platformSuperAdminUserIds = [];

    private string searchText = string.Empty;
    private string? selectedUserId;
    private string selectedAccessRole = "RestaurantAdmin";

    private string? errorMessage;
    private string? successMessage;

    private bool checkedAccess;
    private bool isAuthorized;

    private IEnumerable<ApplicationUser> FilteredUsers
    {
        get
        {
            var query = users
                .Where(x => !platformSuperAdminUserIds.Contains(x.Id))
                .AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                var text = searchText.Trim().ToLower();

                query = query.Where(x =>
                    (!string.IsNullOrWhiteSpace(x.Email) && x.Email.ToLower().Contains(text)) ||
                    (!string.IsNullOrWhiteSpace(x.UserName) && x.UserName.ToLower().Contains(text)) ||
                    (!string.IsNullOrWhiteSpace(x.PhoneNumber) && x.PhoneNumber.ToLower().Contains(text)));
            }

            return query.Take(12);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        checkedAccess = false;
        isAuthorized = false;
        errorMessage = null;
        successMessage = null;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        isAuthorized = await AccessService.CanManageRestaurantUsersAsync(
            authState.User,
            RestaurantId);

        checkedAccess = true;

        if (!isAuthorized)
        {
            Navigation.NavigateTo("/Account/Denied", true);
            return;
        }

        restaurant = await Db.Restaurants
            .FirstOrDefaultAsync(x => x.Id == RestaurantId);

        if (restaurant is null)
            return;

        await LoadPlatformSuperAdmins();

        users = await UserManager.Users
            .OrderBy(x => x.Email)
            .ToListAsync();

        await LoadAccesses();
    }

    private async Task LoadPlatformSuperAdmins()
    {
        var superAdmins = await UserManager.GetUsersInRoleAsync("PlatformSuperAdmin");
        platformSuperAdminUserIds = superAdmins.Select(x => x.Id).ToHashSet();
    }

    private async Task LoadAccesses()
    {
        if (!isAuthorized)
            return;

        accesses = await Db.RestaurantUserAccesses
            .Include(x => x.User)
            .Where(x =>
                x.RestaurantId == RestaurantId &&
                x.User != null &&
                !platformSuperAdminUserIds.Contains(x.UserId))
            .OrderBy(x => x.Role)
            .ThenBy(x => x.User!.Email)
            .ToListAsync();

        currentOwner = null;

        if (restaurant is not null &&
            !string.IsNullOrWhiteSpace(restaurant.OwnerUserId) &&
            !platformSuperAdminUserIds.Contains(restaurant.OwnerUserId))
        {
            currentOwner = await UserManager.FindByIdAsync(restaurant.OwnerUserId);
        }
    }

    private void SelectUser(ApplicationUser user)
    {
        if (!isAuthorized)
            return;

        if (platformSuperAdminUserIds.Contains(user.Id))
            return;

        selectedUser = user;
        selectedUserId = user.Id;
        errorMessage = null;
        successMessage = null;
    }

    private void SelectRole(string role)
    {
        selectedAccessRole = role;
        errorMessage = null;
        successMessage = null;
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;
    }

    private async Task SaveAccess()
    {
        errorMessage = null;
        successMessage = null;

        if (!isAuthorized)
            return;

        if (restaurant is null)
        {
            errorMessage = "Restaurangen hittades inte.";
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedUserId))
        {
            errorMessage = "Välj en användare först.";
            return;
        }

        var user = await UserManager.FindByIdAsync(selectedUserId);

        if (user is null || platformSuperAdminUserIds.Contains(user.Id))
        {
            errorMessage = "Användaren kunde inte väljas.";
            return;
        }

        await ApplyRoleToUser(user, selectedAccessRole);

        await Db.SaveChangesAsync();
        await LoadAccesses();

        selectedUserId = null;
        selectedUser = null;
        searchText = string.Empty;
        selectedAccessRole = "RestaurantAdmin";

        successMessage = "Rollen har sparats.";
    }

    private async Task ChangeAccessRole(RestaurantUserAccess access, string role)
    {
        errorMessage = null;
        successMessage = null;

        if (!isAuthorized)
            return;

        if (restaurant is null || access.User is null)
            return;

        if (platformSuperAdminUserIds.Contains(access.UserId))
            return;

        await ApplyRoleToUser(access.User, role);

        await Db.SaveChangesAsync();
        await LoadAccesses();

        successMessage = "Rollen har uppdaterats.";
    }

    private async Task ApplyRoleToUser(ApplicationUser user, string role)
    {
        if (restaurant is null)
            return;

        if (!await UserManager.IsInRoleAsync(user, role))
        {
            await UserManager.AddToRoleAsync(user, role);
        }

        var existingAccess = await Db.RestaurantUserAccesses
            .FirstOrDefaultAsync(x => x.RestaurantId == RestaurantId && x.UserId == user.Id);

        if (role == "Customer")
        {
            if (existingAccess is not null)
            {
                Db.RestaurantUserAccesses.Remove(existingAccess);
            }

            if (restaurant.OwnerUserId == user.Id)
            {
                restaurant.OwnerUserId = null;
            }

            return;
        }

        if (existingAccess is null)
        {
            existingAccess = new RestaurantUserAccess
                {
                    RestaurantId = RestaurantId,
                    UserId = user.Id,
                    Role = role,
                    CreatedAt = DateTime.UtcNow
                };

            Db.RestaurantUserAccesses.Add(existingAccess);
        }
        else
        {
            existingAccess.Role = role;
        }

        if (role == "RestaurantOwner")
        {
            restaurant.OwnerUserId = user.Id;
        }
    }

    private async Task RemoveAccess(RestaurantUserAccess access)
    {
        errorMessage = null;
        successMessage = null;

        if (!isAuthorized)
            return;

        if (restaurant is null)
            return;

        if (platformSuperAdminUserIds.Contains(access.UserId))
            return;

        if (restaurant.OwnerUserId == access.UserId)
        {
            restaurant.OwnerUserId = null;
        }

        Db.RestaurantUserAccesses.Remove(access);
        await Db.SaveChangesAsync();

        await LoadAccesses();

        successMessage = "Åtkomsten har tagits bort.";
    }

    private string DisplayUser(ApplicationUser? user)
    {
        if (user is null)
            return "Okänd användare";

        var fullName = $"{user.FirstName} {user.LastName}".Trim();

        if (!string.IsNullOrWhiteSpace(fullName))
            return fullName;

        if (!string.IsNullOrWhiteSpace(user.Email))
            return user.Email;

        if (!string.IsNullOrWhiteSpace(user.UserName))
            return user.UserName;

        return user.Id;
    }

    private string DisplayUserSubText(ApplicationUser user)
    {
        if (!string.IsNullOrWhiteSpace(user.Email) && !string.IsNullOrWhiteSpace(user.PhoneNumber))
            return $"{user.Email} • {user.PhoneNumber}";

        if (!string.IsNullOrWhiteSpace(user.Email))
            return user.Email;

        if (!string.IsNullOrWhiteSpace(user.PhoneNumber))
            return user.PhoneNumber;

        if (!string.IsNullOrWhiteSpace(user.UserName))
            return user.UserName;

        return user.Id;
    }

    private string FormatRole(string role)
    {
        return role switch
        {
            "RestaurantOwner" => "Restaurangägare",
            "RestaurantAdmin" => "Restaurangadmin",
            "Customer" => "Kund",
            _ => role
        };
    }

    private string GetRoleClass(string role)
    {
        return role switch
        {
            "RestaurantOwner" => "access-role-owner",
            "RestaurantAdmin" => "access-role-admin",
            "Customer" => "access-role-customer",
            _ => "access-role-admin"
        };
    }

    private void BackToRestaurants()
    {
        Navigation.NavigateTo("/admin/restaurants");
    }

    private void ViewRestaurant()
    {
        if (restaurant is not null)
            Navigation.NavigateTo($"/restaurant/{restaurant.Slug}");
    }
}