@page "/Account/ForgotPasswordConfirmation"

<PageTitle>Email sent</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <span>ES</span>
            <div>
                <strong>EasySystems</strong>
                <p>Password recovery</p>
            </div>
        </div>

        <div class="auth-header">
            <p class="eyebrow">Check your email</p>
            <h1>Reset link sent</h1>
            <p>
                If an account exists with that email, we’ve sent you a password reset link.
                Please check your inbox (and spam folder).
            </p>
        </div>

        <div class="auth-links">
            <a href="/Account/Login">Back to login</a>
            <a href="/Account/Register">Create account</a>
        </div>
    </div>

    <div class="auth-side">
        <div class="auth-side-content">
            <span class="auth-badge">Almost there</span>
            <h2>Open your email and continue the process.</h2>
            <p>
                Click the link we sent you to securely reset your password and get back into your account.
            </p>

            <div class="auth-points">
                <div>
                    <strong>01</strong>
                    <span>Check your inbox</span>
                </div>

                <div>
                    <strong>02</strong>
                    <span>Click the reset link</span>
                </div>

                <div>
                    <strong>03</strong>
                    <span>Set your new password</span>
                </div>
            </div>
        </div>
    </div>
</div>