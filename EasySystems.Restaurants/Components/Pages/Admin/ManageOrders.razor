@page "/admin/restaurants/{RestaurantId:int}/orders"
@rendermode InteractiveServer

@using EasySystems.Restaurants.Data
@using EasySystems.Restaurants.Models
@using EasySystems.Restaurants.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize]

@inject ApplicationDbContext Db
@inject RestaurantAccessService AccessService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Beställningar</PageTitle>

@if (restaurant is not null && isAuthorized)
{
    <AdminNavbar RestaurantId="RestaurantId" RestaurantSlug="@restaurant.Slug" />
}

@if (!checkedAccess)
{
    <div class="public-loading">Kontrollerar behörighet...</div>
}
else if (!isAuthorized)
{
    <div class="public-loading">Omdirigerar...</div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="toast-success">
            @successMessage
        </div>
    }

    <div class="admin-page">
        <div class="admin-header">
            <div>
                <p class="eyebrow">Beställningar</p>
                <h1>@(restaurant?.Name ?? "Restaurang")</h1>
                <p class="subtitle">
                    Hantera nya beställningar, följ status och se kundens detaljer.
                </p>
            </div>

            <div class="restaurant-admin-actions">
                <button type="button" @onclick="LoadOrders">Uppdatera</button>
            </div>
        </div>

        @if (restaurant is null)
        {
            <div class="form-card admin-center-card">
                <h2>Restaurangen hittades inte</h2>
            </div>
        }
        else
        {
            <div class="orders-dashboard modern-orders-dashboard">
                <div class="order-stats modern-order-stats">
                    <div>
                        <span>Nya</span>
                        <strong>@CountByStatus("New")</strong>
                    </div>

                    <div>
                        <span>Tillagas</span>
                        <strong>@CountByStatus("Preparing")</strong>
                    </div>

                    <div>
                        <span>Klara</span>
                        <strong>@CountByStatus("Ready")</strong>
                    </div>

                    <div>
                        <span>Försäljning</span>
                        <strong>@orders.Sum(x => x.TotalAmount).ToString("0.00") kr</strong>
                    </div>
                </div>

                <div class="orders-main-layout">
                    <div class="orders-list-panel">
                        <div class="orders-toolbar">
                            <input class="input"
                                   value="@searchText"
                                   @oninput="OnSearchChanged"
                                   placeholder="Sök namn, telefon, ordernummer eller rätt..." />

                            <InputSelect class="input" @bind-Value="selectedFilter">
                                @foreach (var status in filters)
                                {
                                    <option value="@status">@FormatStatus(status)</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="order-filter-tabs modern-order-tabs">
                            @foreach (var status in filters)
                            {
                                <button type="button"
                                        class="@(selectedFilter == status ? "active" : "")"
                                        @onclick="() => selectedFilter = status">
                                    @FormatStatus(status)
                                    <small>@CountForFilter(status)</small>
                                </button>
                            }
                        </div>

                        @if (FilteredOrders.Count == 0)
                        {
                            <div class="empty-menu">
                                <h3>Inga beställningar hittades</h3>
                                <p>Testa att ändra sökning eller filter.</p>
                            </div>
                        }
                        else
                        {
                            <div class="modern-orders-list">
                                @foreach (var order in FilteredOrders)
                                {
                                    <button type="button"
                                            class="modern-order-card @(selectedOrder?.Id == order.Id ? "selected" : "")"
                                            @onclick="() => SelectOrder(order)">
                                        <div class="modern-order-card-top">
                                            <div>
                                                <strong>#@order.Id</strong>
                                                <span>@order.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                            </div>

                                            <small class="order-status @GetStatusClass(order.Status)">
                                                @FormatStatus(order.Status)
                                            </small>
                                        </div>

                                        <div class="modern-order-customer">
                                            <strong>@order.CustomerName</strong>
                                            <span>@order.CustomerPhone</span>
                                        </div>

                                        <div class="modern-order-bottom">
                                            <span>@order.Items.Sum(x => x.Quantity) varor</span>
                                            <strong>@order.TotalAmount.ToString("0.00") kr</strong>
                                        </div>
                                    </button>
                                }
                            </div>
                        }
                    </div>

                    <div class="order-detail-panel modern-order-detail">
                        @if (selectedOrder is null)
                        {
                            <div class="empty-menu">
                                <h3>Välj en beställning</h3>
                                <p>Klicka på en beställning i listan för att se detaljer.</p>
                            </div>
                        }
                        else
                        {
                            <div class="order-detail-header">
                                <div>
                                    <p class="order-number">Beställning #@selectedOrder.Id</p>
                                    <h2>@selectedOrder.CustomerName</h2>
                                    <span>@selectedOrder.CustomerPhone</span>
                                </div>

                                <button type="button" class="cart-close" @onclick="() => selectedOrder = null">×</button>
                            </div>

                            <div class="order-status-big @GetStatusClass(selectedOrder.Status)">
                                @FormatStatus(selectedOrder.Status)
                            </div>

                            <div class="order-meta">
                                <span>@selectedOrder.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                <strong>@selectedOrder.TotalAmount.ToString("0.00") kr</strong>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(selectedOrder.CustomerNote))
                            {
                                <div class="customer-note">
                                    <strong>Kundens meddelande</strong>
                                    <p>@selectedOrder.CustomerNote</p>
                                </div>
                            }

                            <div class="order-items">
                                @foreach (var item in selectedOrder.Items)
                                {
                                    <div class="order-item-detail">
                                        <div>
                                            <span>@item.Quantity × @item.ItemName</span>

                                            @if (!string.IsNullOrWhiteSpace(item.SelectedOptions))
                                            {
                                                <small>@item.SelectedOptions</small>
                                            }
                                        </div>

                                        <strong>@item.LineTotal.ToString("0.00") kr</strong>
                                    </div>
                                }
                            </div>

                            <div class="order-actions modern-status-actions">
                                <button type="button" @onclick='() => UpdateStatus(selectedOrder, "Accepted")'>Acceptera</button>
                                <button type="button" @onclick='() => UpdateStatus(selectedOrder, "Preparing")'>Tillagas</button>
                                <button type="button" @onclick='() => UpdateStatus(selectedOrder, "Ready")'>Klar</button>
                                <button type="button" @onclick='() => UpdateStatus(selectedOrder, "Completed")'>Avslutad</button>
                                <button class="danger-btn" type="button" @onclick='() => UpdateStatus(selectedOrder, "Cancelled")'>Avbryt</button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public int RestaurantId { get; set; }

    private Restaurant? restaurant;
    private List<Order> orders = [];
    private Order? selectedOrder;

    private string selectedFilter = "All";
    private string searchText = string.Empty;
    private string? successMessage;

    private bool checkedAccess;
    private bool isAuthorized;

    private readonly string[] filters =
    [
        "All",
    "New",
    "Accepted",
    "Preparing",
    "Ready",
    "Completed",
    "Cancelled"
    ];

    private List<Order> FilteredOrders
    {
        get
        {
            var query = orders.AsEnumerable();

            if (selectedFilter != "All")
            {
                query = query.Where(x => x.Status == selectedFilter);
            }

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                var text = searchText.Trim();

                query = query.Where(x =>
                    x.Id.ToString().Contains(text, StringComparison.OrdinalIgnoreCase) ||
                    (!string.IsNullOrWhiteSpace(x.CustomerName) &&
                     x.CustomerName.Contains(text, StringComparison.OrdinalIgnoreCase)) ||
                    (!string.IsNullOrWhiteSpace(x.CustomerPhone) &&
                     x.CustomerPhone.Contains(text, StringComparison.OrdinalIgnoreCase)) ||
                    x.Items.Any(i =>
                        (!string.IsNullOrWhiteSpace(i.ItemName) &&
                         i.ItemName.Contains(text, StringComparison.OrdinalIgnoreCase)) ||
                        (!string.IsNullOrWhiteSpace(i.SelectedOptions) &&
                         i.SelectedOptions.Contains(text, StringComparison.OrdinalIgnoreCase))));
            }

            return query.ToList();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        checkedAccess = false;
        isAuthorized = false;
        successMessage = null;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        isAuthorized = await AccessService.CanManageRestaurantOrdersAsync(
            authState.User,
            RestaurantId);

        checkedAccess = true;

        if (!isAuthorized)
        {
            Navigation.NavigateTo("/Account/Denied", true);
            return;
        }

        restaurant = await Db.Restaurants
            .FirstOrDefaultAsync(x => x.Id == RestaurantId);

        if (restaurant is null)
            return;

        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        if (!isAuthorized)
            return;

        orders = await Db.Orders
            .Include(x => x.Items)
            .Where(x => x.RestaurantId == RestaurantId)
            .OrderByDescending(x => x.CreatedAt)
            .ToListAsync();

        if (selectedOrder is not null)
        {
            selectedOrder = orders.FirstOrDefault(x => x.Id == selectedOrder.Id);
        }
    }

    private void SelectOrder(Order order)
    {
        if (!isAuthorized)
            return;

        selectedOrder = order;
    }

    private async Task UpdateStatus(Order order, string status)
    {
        if (!isAuthorized)
            return;

        var dbOrder = await Db.Orders
            .FirstOrDefaultAsync(x =>
                x.Id == order.Id &&
                x.RestaurantId == RestaurantId);

        if (dbOrder is null)
            return;

        dbOrder.Status = status;

        await Db.SaveChangesAsync();
        await LoadOrders();

        successMessage = $"Beställning #{order.Id} uppdaterad till {FormatStatus(status)}.";
        StateHasChanged();

        await Task.Delay(2000);

        successMessage = null;
        StateHasChanged();
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;
    }

    private int CountByStatus(string status)
        => orders.Count(x => x.Status == status);

    private int CountForFilter(string status)
        => status == "All"
            ? orders.Count
            : CountByStatus(status);

    private string FormatStatus(string status)
    {
        return status switch
        {
            "All" => "Alla",
            "New" => "Ny",
            "Accepted" => "Accepterad",
            "Preparing" => "Tillagas",
            "Ready" => "Klar",
            "Completed" => "Avslutad",
            "Cancelled" => "Avbruten",
            _ => status
        };
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "New" => "status-new",
            "Accepted" => "status-accepted",
            "Preparing" => "status-preparing",
            "Ready" => "status-ready",
            "Completed" => "status-completed",
            "Cancelled" => "status-cancelled",
            _ => "status-new"
        };
    }
}