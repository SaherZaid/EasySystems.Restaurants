    private string GetInitials()
    {
        if (restaurant is null || string.IsNullOrWhiteSpace(restaurant.Name))
            return "ES";

        var words = restaurant.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Join("", words.Take(2).Select(x => x[0])).ToUpper();
    }

