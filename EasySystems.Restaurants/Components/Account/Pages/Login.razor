@page "/Account/Login"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using EasySystems.Restaurants.Data

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Logga in</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <span>ES</span>
            <div>
                <strong>EasySystems</strong>
                <p>Restaurangplattform för beställningar</p>
            </div>
        </div>

        <StatusMessage Message="@errorMessage" />

        <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
            <DataAnnotationsValidator />

            <div class="auth-header">
                <p class="eyebrow">Välkommen tillbaka</p>
                <h1>Logga in</h1>
                <p>Logga in för att se dina beställningar och beställa snabbare nästa gång.</p>
            </div>

            <ValidationSummary class="auth-error-list" role="alert" />

            <div class="auth-field">
                <label for="Input.Email">E-post</label>
                <InputText @bind-Value="Input.Email"
                           id="Input.Email"
                           class="auth-input"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="namn@example.com" />
                <ValidationMessage For="() => Input.Email" class="auth-validation" />
            </div>

            <div class="auth-field">
                <label for="Input.Password">Lösenord</label>
                <InputText type="password"
                           @bind-Value="Input.Password"
                           id="Input.Password"
                           class="auth-input"
                           autocomplete="current-password"
                           aria-required="true"
                           placeholder="••••••••" />
                <ValidationMessage For="() => Input.Password" class="auth-validation" />
            </div>

            <div class="auth-row-between">
                <label class="auth-check">
                    <InputCheckbox @bind-Value="Input.RememberMe" />
                    <span>Kom ihåg mig</span>
                </label>

                <a href="/Account/ForgotPassword">Glömt lösenord?</a>
            </div>

            <button type="submit" class="auth-submit">
                Logga in
            </button>

            <div class="auth-links">
                <a href="@(NavigationManager.GetUriWithQueryParameters("/Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))">
                    Skapa nytt konto
                </a>

                <a href="@GetResendLink()">
                    Skicka verifieringsmail igen
                </a>
            </div>
        </EditForm>
    </div>

    <div class="auth-side">
        <div class="auth-side-content">
            <span class="auth-badge">Snabbare beställningar</span>
            <h2>Logga in och beställ mat smidigare nästa gång.</h2>
            <p>
                Med ett konto kan du se dina tidigare beställningar, spara dina uppgifter och beställa igen snabbare.
            </p>

            <div class="auth-points">
                <div>
                    <strong>01</strong>
                    <span>Se dina tidigare beställningar</span>
                </div>

                <div>
                    <strong>02</strong>
                    <span>Fyll i dina uppgifter automatiskt</span>
                </div>

                <div>
                    <strong>03</strong>
                    <span>Beställ igen från din favoritrestaurang</span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string? errorMessage;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }
    }

    public async Task LoginUser()
    {
        var email = Input.Email.Trim();

        var user = await UserManager.FindByEmailAsync(email);

        if (user is not null && !await UserManager.IsEmailConfirmedAsync(user))
        {
            NavigationManager.NavigateTo(
                NavigationManager.GetUriWithQueryParameters(
                    "/Account/ResendEmailConfirmation",
                    new Dictionary<string, object?>
                        {
                            ["email"] = email
                        }));

            return;
        }

        var result = await SignInManager.PasswordSignInAsync(
            email,
            Input.Password,
            Input.RememberMe,
            lockoutOnFailure: false);

        if (result.Succeeded)
        {
            Logger.LogInformation("User logged in.");
            RedirectManager.RedirectTo(ReturnUrl);
        }
        else if (result.RequiresTwoFactor)
        {
            RedirectManager.RedirectTo(
                "Account/LoginWith2fa",
                new()
                    {
                        ["returnUrl"] = ReturnUrl,
                        ["rememberMe"] = Input.RememberMe
                    });
        }
        else if (result.IsLockedOut)
        {
            Logger.LogWarning("User account locked out.");
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else if (result.IsNotAllowed)
        {
            NavigationManager.NavigateTo(
                NavigationManager.GetUriWithQueryParameters(
                    "/Account/ResendEmailConfirmation",
                    new Dictionary<string, object?>
                        {
                            ["email"] = email
                        }));
        }
        else
        {
            errorMessage = "Fel: Ogiltig inloggning.";
        }
    }

    private string GetResendLink()
    {
        if (string.IsNullOrWhiteSpace(Input.Email))
            return "/Account/ResendEmailConfirmation";

        return NavigationManager.GetUriWithQueryParameters(
            "/Account/ResendEmailConfirmation",
            new Dictionary<string, object?>
                {
                    ["email"] = Input.Email.Trim()
                });
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "E-post krävs.")]
        [EmailAddress(ErrorMessage = "Ange en giltig e-postadress.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Lösenord krävs.")]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Kom ihåg mig")]
        public bool RememberMe { get; set; }
    }
}