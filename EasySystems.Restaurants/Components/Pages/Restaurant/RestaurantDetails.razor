@page "/restaurant/{Slug}"
@rendermode InteractiveServer

@using EasySystems.Restaurants.Data
@using EasySystems.Restaurants.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using System.Text.Json

@inject ApplicationDbContext Db
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager

<PageTitle>@(restaurant?.Name ?? "Restaurant")</PageTitle>

@if (isLoading)
{
    <div class="public-loading">Loading restaurant...</div>
}
else if (restaurant is null)
{
    <div class="public-not-found">
        <h1>Restaurant not found</h1>
        <p>The restaurant you are looking for does not exist or is not active.</p>
    </div>
}
else
{
    <RestaurantNavbar Restaurant="restaurant" />

    <main class="restaurant-public" style="@GetPublicPageStyle()">
        <section class="restaurant-hero-public" style="@GetHeroStyle()">
            <div class="restaurant-hero-overlay">
                <div class="restaurant-logo-public">
                    @if (!string.IsNullOrWhiteSpace(restaurant.LogoUrl))
                    {
                        <img src="@restaurant.LogoUrl" alt="@restaurant.Name logo" />
                    }
                    else
                    {
                        <span>@GetInitials(restaurant.Name)</span>
                    }
                </div>

                <h1>@restaurant.Name</h1>
                <p class="restaurant-description">@restaurant.Description</p>

                <div class="restaurant-actions">
                    <button type="button" class="primary-action" style="@GetPrimaryButtonStyle()" @onclick="ScrollToMenu">
                        Se meny
                    </button>

                    <a href="/restaurant/@restaurant.Slug/contact" class="secondary-action" style="@GetSecondaryButtonStyle()">
                        Kontakt & öppettider
                    </a>
                </div>
            </div>
        </section>

        <section id="menu" class="restaurant-section" style="@GetSectionStyle()">
            <div class="section-heading">
                <p style="color:@restaurant.MutedTextColor;">Meny</p>
                <h2 style="color:@restaurant.HeadingTextColor;">Våra rätter</h2>
            </div>

            @if (categories.Count == 0)
            {
                <div class="empty-menu" style="@GetCardStyle()">
                    <h3 style="color:@restaurant.HeadingTextColor;">Menyn är inte publicerad ännu</h3>
                    <p style="color:@restaurant.BodyTextColor;">Restaurangen håller på att lägga till sina kategorier och rätter.</p>
                </div>
            }
            else
            {
                <div class="menu-category-tabs">
                    @foreach (var category in categories)
                    {
                        <button type="button" style="@GetCategoryTabStyle()" @onclick="() => ScrollToCategory(category.Id)">
                            @category.Name
                        </button>
                    }
                </div>

                <div class="public-menu-list">
                    @foreach (var category in categories)
                    {
                        var categoryItems = items
                            .Where(x => x.MenuCategoryId == category.Id)
                            .OrderBy(x => x.SortOrder)
                            .ToList();

                        <section id="category-@category.Id" class="public-menu-category" style="@GetCategorySectionStyle()">
                            <div class="public-menu-category-header">
                                <div>
                                    <h3 style="color:@restaurant.HeadingTextColor;">@category.Name</h3>

                                    @if (!string.IsNullOrWhiteSpace(category.Description))
                                    {
                                        <p style="color:@restaurant.BodyTextColor;">@category.Description</p>
                                    }
                                </div>

                                <span style="color:@restaurant.MutedTextColor;">@categoryItems.Count rätter</span>
                            </div>

                            @if (categoryItems.Count == 0)
                            {
                                <div class="empty-category" style="color:@restaurant.MutedTextColor;">
                                    Inga rätter i denna kategori ännu.
                                </div>
                            }
                            else
                            {
                                <div class="public-dish-list">
                                    @foreach (var item in categoryItems)
                                    {
                                        <article class="luxury-dish-card" style="@GetDishCardStyle()">
                                            <button type="button"
                                                    class="luxury-dish-image-button"
                                                    @onclick="() => OpenItemOptions(item)"
                                                    aria-label="Lägg till @item.Name">
                                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                                {
                                                    <img src="@item.ImageUrl" alt="@item.Name" />
                                                }
                                                else
                                                {
                                                    <div class="luxury-dish-no-image" style="@GetDishImageFallbackStyle()">
                                                        <span>@GetInitials(item.Name)</span>
                                                    </div>
                                                }
                                            </button>

                                            <div class="luxury-dish-body">
                                                <div>
                                                    <p class="luxury-dish-category" style="color:@restaurant.MutedTextColor;">@category.Name</p>
                                                    <h4 style="color:@restaurant.HeadingTextColor;">@item.Name</h4>

                                                    @if (!string.IsNullOrWhiteSpace(item.Description))
                                                    {
                                                        <p class="luxury-dish-description" style="color:@restaurant.BodyTextColor;">@item.Description</p>
                                                    }
                                                </div>

                                                <div class="luxury-dish-bottom">
                                                    <strong style="color:@restaurant.PriceTextColor;">@item.Price.ToString("0.00") kr</strong>

                                                    <button type="button" style="@GetPrimaryButtonStyle()" @onclick="() => OpenItemOptions(item)">
                                                        Lägg till
                                                    </button>
                                                </div>
                                            </div>
                                        </article>
                                    }
                                </div>
                            }
                        </section>
                    }
                </div>
            }
        </section>

        @if (selectedMenuItem is not null)
        {
            <div class="cart-overlay">
                <div class="item-options-panel" style="@GetPanelStyle()">
                    <div class="cart-header">
                        <div>
                            <p style="color:@restaurant.MutedTextColor;">Anpassa din rätt</p>
                            <h2 style="color:@restaurant.HeadingTextColor;">@selectedMenuItem.Name</h2>
                        </div>

                        <button type="button" class="cart-close" @onclick="CloseItemOptions">×</button>
                    </div>

                    <div class="item-options-content">
                        @if (!string.IsNullOrWhiteSpace(selectedMenuItem.ImageUrl))
                        {
                            <img class="option-dish-image" src="@selectedMenuItem.ImageUrl" alt="@selectedMenuItem.Name" />
                        }

                        @if (!string.IsNullOrWhiteSpace(selectedMenuItem.Description))
                        {
                            <p class="option-dish-description" style="color:@restaurant.BodyTextColor;">@selectedMenuItem.Description</p>
                        }

                        @if (!string.IsNullOrWhiteSpace(optionValidationMessage))
                        {
                            <div class="error">@optionValidationMessage</div>
                        }

                        @{
                            var groupedOptions = selectedItemGroups
                                .Where(g => g.IsAvailable)
                                .OrderBy(g => g.SortOrder)
                                .ThenBy(g => g.Name)
                                .ToList();

                            var ungroupedIncludedOptions = selectedItemOptions
                                .Where(x => x.MenuItemOptionGroupId is null && x.IsDefaultIncluded)
                                .OrderBy(x => x.SortOrder)
                                .ToList();

                            var ungroupedExtraOptions = selectedItemOptions
                                .Where(x => x.MenuItemOptionGroupId is null && !x.IsDefaultIncluded)
                                .OrderBy(x => x.SortOrder)
                                .ToList();
                        }

                        @foreach (var group in groupedOptions)
                        {
                            var groupType = NormalizeGroupType(group.GroupType);

                            var groupOptions = selectedItemOptions
                                .Where(x => x.MenuItemOptionGroupId == group.Id && x.IsAvailable)
                                .OrderBy(x => x.SortOrder)
                                .ThenBy(x => x.Name)
                                .ToList();

                            if (groupOptions.Count == 0)
                                continue;

                            <div class="option-list meal-option-group">
                                <div class="meal-option-group-header">
                                    <div>
                                        <h3 style="color:@restaurant.HeadingTextColor;">@group.Name</h3>
                                        <p class="option-help" style="color:@restaurant.MutedTextColor;">
                                            @GetCustomerGroupHelpText(group)
                                        </p>
                                    </div>

                                    @if (group.IsRequired && groupType != IncludedIngredientsType)
                                    {
                                        <small class="required-badge">Krävs</small>
                                    }
                                </div>

                                @foreach (var option in groupOptions)
                                {
                                    if (groupType == IncludedIngredientsType || groupType == MultipleChoiceType)
                                    {
                                        <label class="option-choice premium-option-choice" style="@GetOptionChoiceStyle()">
                                            <input type="checkbox"
                                                   checked="@selectedOptionIds.Contains(option.Id)"
                                                   @onchange="(e) => ToggleOption(option.Id, (bool)e.Value!)" />

                                            <span>
                                                <strong style="color:@restaurant.HeadingTextColor;">@option.Name</strong>

                                                @if (groupType == IncludedIngredientsType)
                                                {
                                                    <small style="color:@restaurant.MutedTextColor;">Ingår</small>
                                                }
                                                else if (option.ExtraPrice > 0)
                                                {
                                                    <small style="color:@restaurant.PriceTextColor;">+@option.ExtraPrice.ToString("0.00") kr</small>
                                                }
                                                else
                                                {
                                                    <small style="color:@restaurant.MutedTextColor;">0 kr</small>
                                                }
                                            </span>
                                        </label>
                                    }
                                    else
                                    {
                                        <label class="option-choice premium-option-choice" style="@GetOptionChoiceStyle()">
                                            <input type="radio"
                                                   name="group-@group.Id"
                                                   checked="@IsSingleGroupOptionSelected(group.Id, option.Id)"
                                                   @onchange="() => SelectSingleGroupOption(group.Id, option.Id)" />

                                            <span>
                                                <strong style="color:@restaurant.HeadingTextColor;">@option.Name</strong>

                                                @if (option.ExtraPrice > 0)
                                                {
                                                    <small style="color:@restaurant.PriceTextColor;">+@option.ExtraPrice.ToString("0.00") kr</small>
                                                }
                                                else
                                                {
                                                    <small style="color:@restaurant.MutedTextColor;">Ingår</small>
                                                }
                                            </span>
                                        </label>
                                    }
                                }
                            </div>
                        }

                        @if (ungroupedIncludedOptions.Count > 0)
                        {
                            <div class="option-list">
                                <h3 style="color:@restaurant.HeadingTextColor;">Ingår i rätten</h3>
                                <p class="option-help" style="color:@restaurant.MutedTextColor;">Avmarkera det du inte vill ha.</p>

                                @foreach (var option in ungroupedIncludedOptions)
                                {
                                    <label class="option-choice premium-option-choice" style="@GetOptionChoiceStyle()">
                                        <input type="checkbox"
                                               checked="@selectedOptionIds.Contains(option.Id)"
                                               @onchange="(e) => ToggleOption(option.Id, (bool)e.Value!)" />

                                        <span>
                                            <strong style="color:@restaurant.HeadingTextColor;">@option.Name</strong>
                                            <small style="color:@restaurant.MutedTextColor;">Ingår</small>
                                        </span>
                                    </label>
                                }
                            </div>
                        }

                        @if (ungroupedExtraOptions.Count > 0)
                        {
                            <div class="option-list">
                                <h3 style="color:@restaurant.HeadingTextColor;">Extra tillval</h3>

                                @foreach (var option in ungroupedExtraOptions)
                                {
                                    <label class="option-choice premium-option-choice" style="@GetOptionChoiceStyle()">
                                        <input type="checkbox"
                                               checked="@selectedOptionIds.Contains(option.Id)"
                                               @onchange="(e) => ToggleOption(option.Id, (bool)e.Value!)" />

                                        <span>
                                            <strong style="color:@restaurant.HeadingTextColor;">@option.Name</strong>

                                            @if (option.ExtraPrice > 0)
                                            {
                                                <small style="color:@restaurant.PriceTextColor;">+@option.ExtraPrice.ToString("0.00") kr</small>
                                            }
                                            else
                                            {
                                                <small style="color:@restaurant.MutedTextColor;">0 kr</small>
                                            }
                                        </span>
                                    </label>
                                }
                            </div>
                        }

                        @if (groupedOptions.Count == 0 && ungroupedIncludedOptions.Count == 0 && ungroupedExtraOptions.Count == 0)
                        {
                            <div class="empty-category" style="color:@restaurant.MutedTextColor;">
                                Inga anpassningar för denna rätt.
                            </div>
                        }
                    </div>

                    <div class="item-options-footer">
                        <div class="cart-total">
                            <span style="color:@restaurant.MutedTextColor;">Pris</span>
                            <strong style="color:@restaurant.PriceTextColor;">@SelectedItemTotal.ToString("0.00") kr</strong>
                        </div>

                        <button type="button" class="checkout-btn" style="@GetPrimaryButtonStyle()" @onclick="AddSelectedItemToCart">
                            Lägg till i varukorg
                        </button>
                    </div>
                </div>
            </div>
        }

        @if (CartCount > 0 && !showCart)
        {
            <div class="cart-bar" style="@GetCartBarStyle()">
                <div>
                    <strong>Varukorg</strong>
                    <span>@CartCount varor • @CartTotal.ToString("0.00") kr</span>
                </div>

                <button type="button" style="@GetCartButtonStyle()" @onclick="OpenCart">
                    Visa varukorg
                </button>
            </div>
        }

        @if (showCart)
        {
            <div class="cart-overlay">
                <div class="cart-panel" style="@GetPanelStyle()">
                    <div class="cart-header">
                        <div>
                            <p style="color:@restaurant.MutedTextColor;">Din beställning</p>
                            <h2 style="color:@restaurant.HeadingTextColor;">Varukorg</h2>
                        </div>

                        <button type="button" class="cart-close" @onclick="CloseCart">×</button>
                    </div>

                    <div class="cart-scroll-area">
                        @if (orderSubmitted)
                        {
                            <div class="order-success premium-order-success">
                                <div class="success-icon">✓</div>
                                <strong>Tack! Din beställning är mottagen.</strong>
                                <p>Ordernummer: #@createdOrderId</p>

                                @if (currentUser is not null)
                                {
                                    <p>Beställningen har sparats på ditt konto.</p>
                                }

                                <button type="button" class="checkout-btn" style="@GetPrimaryButtonStyle()" @onclick="CloseCart">
                                    Stäng
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="cart-panel-content">
                                @foreach (var item in cart)
                                {
                                    <div class="cart-item" style="@GetCartItemStyle()">
                                        <div>
                                            <strong style="color:@restaurant.HeadingTextColor;">@item.Name</strong>
                                            <span style="color:@restaurant.PriceTextColor;">@item.UnitPrice.ToString("0.00") kr</span>

                                            @if (!string.IsNullOrWhiteSpace(item.SelectedOptions))
                                            {
                                                <small class="cart-options" style="color:@restaurant.MutedTextColor;">@item.SelectedOptions</small>
                                            }
                                        </div>

                                        <div class="quantity-controls">
                                            <button type="button" @onclick="() => DecreaseQuantity(item)">−</button>
                                            <span>@item.Quantity</span>
                                            <button type="button" @onclick="() => IncreaseQuantity(item)">+</button>
                                        </div>

                                        <button type="button" class="remove-item" @onclick="() => RemoveFromCart(item)">
                                            Ta bort
                                        </button>
                                    </div>
                                }
                            </div>

                            <div class="cart-checkout-area">
                                <div class="cart-total">
                                    <span style="color:@restaurant.MutedTextColor;">Totalt</span>
                                    <strong style="color:@restaurant.PriceTextColor;">@CartTotal.ToString("0.00") kr</strong>
                                </div>

                                @if (!showCheckout)
                                {
                                    <button type="button" class="checkout-btn" style="@GetPrimaryButtonStyle()" @onclick="OpenCheckout">
                                        Fortsätt till beställning
                                    </button>
                                }
                                else
                                {
                                    <div class="checkout-form">
                                        <h3 style="color:@restaurant.HeadingTextColor;">Kunduppgifter</h3>

                                        @if (currentUser is null)
                                        {
                                            <div class="tip-box">
                                                <strong>Tips</strong>
                                                <p>Du kan beställa utan konto, men om du loggar in sparas beställningen på ditt konto.</p>
                                                <a href="@GetLoginUrl()">Logga in</a>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="upload-success">
                                                Inloggad som @GetCurrentUserDisplayName(). Beställningen sparas på ditt konto.
                                            </div>
                                        }

                                        <label>Namn</label>
                                        <InputText class="input" @bind-Value="customerName" placeholder="Ditt namn" />

                                        <label>Telefon</label>
                                        <InputText class="input" @bind-Value="customerPhone" placeholder="070-123 45 67" />

                                        <label>Meddelande</label>
                                        <InputTextArea class="input textarea" @bind-Value="customerNote" placeholder="Exempel: Ingen lök, extra sås..." />

                                        @if (!string.IsNullOrWhiteSpace(orderErrorMessage))
                                        {
                                            <div class="error">@orderErrorMessage</div>
                                        }

                                        <button type="button" class="checkout-btn" style="@GetPrimaryButtonStyle()" @onclick="SubmitOrder">
                                            Skicka beställning
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <RestaurantFooter Restaurant="restaurant" />
    </main>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private const string IncludedIngredientsType = "IncludedIngredients";
    private const string SingleChoiceType = "SingleChoice";
    private const string MultipleChoiceType = "MultipleChoice";

    private Restaurant? restaurant;
    private ApplicationUser? currentUser;

    private bool isLoading = true;
    private bool userLoaded;

    private List<MenuCategory> categories = [];
    private List<MenuItem> items = [];
    private List<MenuItemOption> itemOptions = [];
    private List<MenuItemOptionGroup> itemOptionGroups = [];
    private List<CartItem> cart = [];

    private bool showCart;
    private bool showCheckout;
    private bool cartLoaded;
    private string? loadedCartStorageKey;

    private MenuItem? selectedMenuItem;
    private List<MenuItemOption> selectedItemOptions = [];
    private List<MenuItemOptionGroup> selectedItemGroups = [];
    private HashSet<int> selectedOptionIds = [];
    private Dictionary<int, int> selectedSingleGroupOptionIds = [];
    private string? optionValidationMessage;

    private string customerName = string.Empty;
    private string customerPhone = string.Empty;
    private string customerNote = string.Empty;
    private string? orderErrorMessage;

    private bool orderSubmitted;
    private int createdOrderId;

    private string CartStorageKey
    {
        get
        {
            if (restaurant is null)
                return "restaurant-cart-anonymous";

            if (currentUser is not null)
                return $"restaurant-cart-user-{currentUser.Id}-restaurant-{restaurant.Id}";

            return $"restaurant-cart-guest-restaurant-{restaurant.Id}";
        }
    }

    private decimal CartTotal => cart.Sum(x => x.UnitPrice * x.Quantity);
    private int CartCount => cart.Sum(x => x.Quantity);

    private decimal SelectedItemTotal
    {
        get
        {
            if (selectedMenuItem is null)
                return 0;

            var selectedOptionIdList = GetAllSelectedOptionIds();

            var extraTotal = selectedItemOptions
                .Where(x => selectedOptionIdList.Contains(x.Id) && x.ExtraPrice > 0)
                .Sum(x => x.ExtraPrice);

            return selectedMenuItem.Price + extraTotal;
        }
    }

    private class CartItem
    {
        public int MenuItemId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string SelectedOptions { get; set; } = string.Empty;
        public decimal UnitPrice { get; set; }
        public int Quantity { get; set; }
    }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;

        restaurant = await Db.Restaurants
            .AsNoTracking()
            .FirstOrDefaultAsync(x => x.Slug == Slug && x.IsActive);

        await LoadCurrentUser();

        if (restaurant is not null)
        {
            categories = await Db.MenuCategories
                .AsNoTracking()
                .Where(x => x.RestaurantId == restaurant.Id && x.IsVisible)
                .OrderBy(x => x.SortOrder)
                .ToListAsync();

            items = await Db.MenuItems
                .AsNoTracking()
                .Include(x => x.MenuCategory)
                .Where(x =>
                    x.IsAvailable &&
                    x.MenuCategory != null &&
                    x.MenuCategory.RestaurantId == restaurant.Id &&
                    x.MenuCategory.IsVisible)
                .OrderBy(x => x.MenuCategory!.SortOrder)
                .ThenBy(x => x.SortOrder)
                .ToListAsync();

            var itemIds = items.Select(i => i.Id).ToList();

            itemOptionGroups = await Db.MenuItemOptionGroups
                .AsNoTracking()
                .Where(x => x.IsAvailable && itemIds.Contains(x.MenuItemId))
                .OrderBy(x => x.SortOrder)
                .ToListAsync();

            itemOptions = await Db.MenuItemOptions
                .AsNoTracking()
                .Include(x => x.MenuItemOptionGroup)
                .Where(x =>
                    x.IsAvailable &&
                    itemIds.Contains(x.MenuItemId) &&
                    (x.MenuItemOptionGroupId == null || x.MenuItemOptionGroup!.IsAvailable))
                .OrderBy(x => x.MenuItemOptionGroup!.SortOrder)
                .ThenBy(x => x.SortOrder)
                .ToListAsync();
        }

        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (restaurant is null)
            return;

        if (!cartLoaded || loadedCartStorageKey != CartStorageKey)
        {
            cartLoaded = true;
            loadedCartStorageKey = CartStorageKey;

            await LoadCart();
            StateHasChanged();
        }
    }

    private async Task LoadCurrentUser()
    {
        if (userLoaded)
            return;

        userLoaded = true;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity?.IsAuthenticated == true)
        {
            currentUser = await UserManager.GetUserAsync(authState.User);

            if (currentUser is not null)
                PrefillCustomerFromUser();
        }
    }

    private void PrefillCustomerFromUser()
    {
        if (currentUser is null)
            return;

        var fullName = $"{currentUser.FirstName} {currentUser.LastName}".Trim();

        if (string.IsNullOrWhiteSpace(customerName))
        {
            customerName = string.IsNullOrWhiteSpace(fullName)
                ? currentUser.Email ?? string.Empty
                : fullName;
        }

        if (string.IsNullOrWhiteSpace(customerPhone))
            customerPhone = currentUser.PhoneNumber ?? string.Empty;
    }

    private async Task LoadCart()
    {
        if (restaurant is null)
            return;

        var json = await JS.InvokeAsync<string?>("easyCart.get", CartStorageKey);
        cart = !string.IsNullOrWhiteSpace(json)
            ? JsonSerializer.Deserialize<List<CartItem>>(json) ?? []
            : [];
    }

    private async Task SaveCart()
    {
        var json = JsonSerializer.Serialize(cart);
        await JS.InvokeVoidAsync("easyCart.set", CartStorageKey, json);
    }

    private void OpenItemOptions(MenuItem item)
    {
        selectedMenuItem = item;
        optionValidationMessage = null;

        selectedItemGroups = itemOptionGroups
            .Where(x => x.MenuItemId == item.Id && x.IsAvailable)
            .OrderBy(x => x.SortOrder)
            .ThenBy(x => x.Name)
            .ToList();

        selectedItemOptions = itemOptions
            .Where(x => x.MenuItemId == item.Id && x.IsAvailable)
            .OrderBy(x => x.MenuItemOptionGroup?.SortOrder ?? 999)
            .ThenBy(x => x.SortOrder)
            .ThenBy(x => x.Name)
            .ToList();

        selectedOptionIds = selectedItemOptions
            .Where(x =>
                x.MenuItemOptionGroupId is null && x.IsDefaultIncluded ||
                x.MenuItemOptionGroupId is not null &&
                NormalizeGroupType(x.MenuItemOptionGroup?.GroupType) == IncludedIngredientsType)
            .Select(x => x.Id)
            .ToHashSet();

        selectedSingleGroupOptionIds = [];
    }

    private void CloseItemOptions()
    {
        selectedMenuItem = null;
        selectedItemOptions = [];
        selectedItemGroups = [];
        selectedOptionIds = [];
        selectedSingleGroupOptionIds = [];
        optionValidationMessage = null;
    }

    private void ToggleOption(int optionId, bool isSelected)
    {
        if (isSelected)
            selectedOptionIds.Add(optionId);
        else
            selectedOptionIds.Remove(optionId);

        optionValidationMessage = null;
    }

    private void SelectSingleGroupOption(int groupId, int optionId)
    {
        selectedSingleGroupOptionIds[groupId] = optionId;
        optionValidationMessage = null;
    }

    private bool IsSingleGroupOptionSelected(int groupId, int optionId)
    {
        return selectedSingleGroupOptionIds.TryGetValue(groupId, out var selectedOptionId) &&
               selectedOptionId == optionId;
    }

    private HashSet<int> GetAllSelectedOptionIds()
    {
        var ids = selectedOptionIds.ToHashSet();

        foreach (var selectedOptionId in selectedSingleGroupOptionIds.Values)
            ids.Add(selectedOptionId);

        return ids;
    }

    private bool ValidateRequiredGroups()
    {
        foreach (var group in selectedItemGroups.Where(x => x.IsAvailable && x.IsRequired))
        {
            var groupType = NormalizeGroupType(group.GroupType);

            if (groupType == IncludedIngredientsType)
                continue;

            var groupOptions = selectedItemOptions
                .Where(x => x.MenuItemOptionGroupId == group.Id && x.IsAvailable)
                .ToList();

            if (groupOptions.Count == 0)
                continue;

            var hasSelection = groupType == MultipleChoiceType
                ? groupOptions.Any(x => selectedOptionIds.Contains(x.Id))
                : selectedSingleGroupOptionIds.ContainsKey(group.Id);

            if (!hasSelection)
            {
                optionValidationMessage = $"Välj ett alternativ i “{group.Name}”.";
                return false;
            }
        }

        optionValidationMessage = null;
        return true;
    }

    private async Task AddSelectedItemToCart()
    {
        if (selectedMenuItem is null)
            return;

        if (!ValidateRequiredGroups())
            return;

        var selectedOptionIdList = GetAllSelectedOptionIds();

        var removedIncludedOptions = selectedItemOptions
            .Where(x =>
                (x.MenuItemOptionGroupId is null && x.IsDefaultIncluded ||
                 x.MenuItemOptionGroupId is not null &&
                 NormalizeGroupType(x.MenuItemOptionGroup?.GroupType) == IncludedIngredientsType) &&
                !selectedOptionIdList.Contains(x.Id))
            .ToList();

        var selectedGroupedOptions = selectedItemGroups
            .OrderBy(x => x.SortOrder)
            .Select(group =>
            {
                var groupType = NormalizeGroupType(group.GroupType);

                if (groupType == IncludedIngredientsType)
                    return string.Empty;

                var selectedNames = selectedItemOptions
                    .Where(option =>
                        option.MenuItemOptionGroupId == group.Id &&
                        selectedOptionIdList.Contains(option.Id))
                    .OrderBy(option => option.SortOrder)
                    .Select(option => option.ExtraPrice > 0
                        ? $"{option.Name} +{option.ExtraPrice.ToString("0.00")} kr"
                        : option.Name)
                    .ToList();

                return selectedNames.Count == 0
                    ? string.Empty
                    : $"{group.Name}: {string.Join(", ", selectedNames)}";
            })
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .ToList();

        var selectedExtraOptions = selectedItemOptions
            .Where(x =>
                x.MenuItemOptionGroupId is null &&
                !x.IsDefaultIncluded &&
                selectedOptionIds.Contains(x.Id))
            .ToList();

        var removedText = removedIncludedOptions.Count == 0
            ? string.Empty
            : "Utan: " + string.Join(", ", removedIncludedOptions.Select(x => x.Name));

        var extraText = selectedExtraOptions.Count == 0
            ? string.Empty
            : "Extra: " + string.Join(", ", selectedExtraOptions.Select(x =>
                x.ExtraPrice > 0
                    ? $"{x.Name} +{x.ExtraPrice.ToString("0.00")} kr"
                    : x.Name));

        var optionText = string.Join(" | ",
            selectedGroupedOptions
                .Concat(new[] { removedText, extraText })
                .Where(x => !string.IsNullOrWhiteSpace(x)));

        var finalPrice = SelectedItemTotal;

        var existing = cart.FirstOrDefault(x =>
            x.MenuItemId == selectedMenuItem.Id &&
            x.SelectedOptions == optionText);

        if (existing is null)
        {
            cart.Add(new CartItem
            {
                MenuItemId = selectedMenuItem.Id,
                Name = selectedMenuItem.Name,
                SelectedOptions = optionText,
                UnitPrice = finalPrice,
                Quantity = 1
            });
        }
        else
        {
            existing.Quantity++;
        }

        await SaveCart();
        CloseItemOptions();
    }

    private async Task RemoveFromCart(CartItem item)
    {
        cart.Remove(item);
        await SaveCart();

        if (cart.Count == 0)
        {
            showCart = false;
            showCheckout = false;
        }
    }

    private async Task IncreaseQuantity(CartItem item)
    {
        item.Quantity++;
        await SaveCart();
    }

    private async Task DecreaseQuantity(CartItem item)
    {
        if (item.Quantity <= 1)
            cart.Remove(item);
        else
            item.Quantity--;

        await SaveCart();

        if (cart.Count == 0)
        {
            showCart = false;
            showCheckout = false;
        }
    }

    private void OpenCart()
    {
        showCart = true;
        orderSubmitted = false;
    }

    private void CloseCart()
    {
        showCart = false;
        showCheckout = false;
        orderErrorMessage = null;
    }

    private void OpenCheckout()
    {
        showCheckout = true;
        orderErrorMessage = null;
        PrefillCustomerFromUser();
    }

    private async Task SubmitOrder()
    {
        orderErrorMessage = null;

        if (restaurant is null)
        {
            orderErrorMessage = "Restaurant was not found.";
            return;
        }

        if (cart.Count == 0)
        {
            orderErrorMessage = "Varukorgen är tom.";
            return;
        }

        if (string.IsNullOrWhiteSpace(customerName))
        {
            orderErrorMessage = "Namn krävs.";
            return;
        }

        if (string.IsNullOrWhiteSpace(customerPhone))
        {
            orderErrorMessage = "Telefonnummer krävs.";
            return;
        }

        var order = new Order
        {
            RestaurantId = restaurant.Id,
            CustomerUserId = currentUser?.Id,
            CustomerName = customerName.Trim(),
            CustomerPhone = customerPhone.Trim(),
            CustomerNote = customerNote.Trim(),
            TotalAmount = CartTotal,
            Status = "New",
            CreatedAt = DateTime.UtcNow,
            Items = cart.Select(x => new OrderItem
            {
                MenuItemId = x.MenuItemId,
                ItemName = x.Name,
                SelectedOptions = x.SelectedOptions,
                UnitPrice = x.UnitPrice,
                Quantity = x.Quantity,
                LineTotal = x.UnitPrice * x.Quantity
            }).ToList()
        };

        Db.Orders.Add(order);
        await Db.SaveChangesAsync();

        createdOrderId = order.Id;
        orderSubmitted = true;

        cart.Clear();
        customerName = string.Empty;
        customerPhone = string.Empty;
        customerNote = string.Empty;
        showCheckout = false;

        PrefillCustomerFromUser();

        await JS.InvokeVoidAsync("easyCart.remove", CartStorageKey);
        loadedCartStorageKey = null;
    }

