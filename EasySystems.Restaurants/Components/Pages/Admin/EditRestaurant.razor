@page "/admin/restaurants/{RestaurantId:int}/edit"
@rendermode InteractiveServer

@using EasySystems.Restaurants.Data
@using EasySystems.Restaurants.Models
@using EasySystems.Restaurants.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize]

@inject ApplicationDbContext Db
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment
@inject RestaurantAccessService AccessService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Redigera restaurang</PageTitle>

@if (restaurant is not null && isAuthorized)
{
    <AdminNavbar RestaurantId="RestaurantId" RestaurantSlug="@restaurant.Slug" />
}

@if (!checkedAccess)
{
    <div class="public-loading">Kontrollerar behörighet...</div>
}
else if (!isAuthorized)
{
    <div class="public-loading">Omdirigerar...</div>
}
else if (restaurant is null)
{
    <div class="admin-page">
        <div class="admin-shell">
            <div class="form-card admin-center-card">
                <h2>Restaurangen hittades inte</h2>
            </div>
        </div>
    </div>
}
else
{
    <div class="admin-page admin-edit-restaurant-page">
        <div class="admin-shell">

            <section class="restaurant-edit-hero">
                <div>
                    <p class="admin-eyebrow">Restauranginställningar</p>
                    <h1>@restaurant.Name</h1>
                    <p>Uppdatera information, öppettider, bilder, toppmeny, sidfot och design för restaurangens publika sida.</p>
                </div>

                <div class="restaurant-edit-hero-actions">
                    <a class="admin-secondary-btn" href="/admin/restaurants">Restaurang</a>
                    <button type="button" class="admin-secondary-btn" @onclick="ViewRestaurant">
                        Visa restaurang
                    </button>
                </div>
            </section>

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="restaurant-edit-feedback success">
                    <strong>Klart!</strong>
                    <span>@successMessage</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="restaurant-edit-feedback danger">
                    <strong>Något gick fel</strong>
                    <span>@errorMessage</span>
                </div>
            }

            <EditForm Model="restaurant" OnValidSubmit="SaveRestaurant">
                <DataAnnotationsValidator />

                <div class="restaurant-edit-grid @(savedHighlight ? "saved-highlight" : "")">

                    <section class="restaurant-edit-card">

                        <div class="restaurant-edit-section">
                            <h2>Grundinformation</h2>

                            <label>Restaurangens namn</label>
                            <InputText class="settings-input" @bind-Value="restaurant.Name" />

                            <label>URL / slug</label>
                            <small class="field-help">Detta blir länken till restaurangen, till exempel: /restaurant/min-restaurang</small>
                            <InputText class="settings-input" @bind-Value="restaurant.Slug" />

                            <label>Beskrivning</label>
                            <small class="field-help">Texten som visas under restaurangens namn på startsidan.</small>
                            <InputTextArea class="settings-input settings-textarea" rows="4" @bind-Value="restaurant.Description" />
                        </div>

                        <div class="restaurant-edit-section">
                            <h2>Kontaktuppgifter</h2>

                            <div class="settings-two-cols">
                                <div>
                                    <label>Telefon</label>
                                    <InputText class="settings-input" @bind-Value="restaurant.Phone" />
                                </div>

                                <div>
                                    <label>E-post</label>
                                    <InputText class="settings-input" @bind-Value="restaurant.Email" />
                                </div>
                            </div>

                            <label>Adress</label>
                            <InputText class="settings-input" @bind-Value="restaurant.Address" />
                        </div>

                        <div class="restaurant-edit-section">
                            <h2>Sociala medier</h2>

                            <div class="settings-two-cols">
                                <div>
                                    <label>Instagram-länk</label>
                                    <InputText class="settings-input" @bind-Value="restaurant.InstagramUrl" />
                                </div>

                                <div>
                                    <label>Facebook-länk</label>
                                    <InputText class="settings-input" @bind-Value="restaurant.FacebookUrl" />
                                </div>
                            </div>

                            <div class="settings-two-cols">
                                <div>
                                    <label>TikTok-länk</label>
                                    <InputText class="settings-input" @bind-Value="restaurant.TikTokUrl" />
                                </div>

                                <div>
                                    <label>Webbplats</label>
                                    <InputText class="settings-input" @bind-Value="restaurant.WebsiteUrl" />
                                </div>
                            </div>
                        </div>

                        <div class="edit-booking-section">
                            <h2>Öppettider</h2>

                            <div class="settings-two-cols">
                                <div>
                                    <label>Måndag</label>
                                    <InputText class="settings-input" @bind-Value="restaurant.MondayHours" />
                                </div>

                                <div>
                                    <label>Tisdag</label>
                                    <InputText class="settings-input" @bind-Value="restaurant.TuesdayHours" />
                                </div>

                                <div>
                                    <label>Onsdag</label>
                                    <InputText class="settings-input" @bind-Value="restaurant.WednesdayHours" />
                                </div>

                                <div>
                                    <label>Torsdag</label>
                                    <InputText class="settings-input" @bind-Value="restaurant.ThursdayHours" />
                                </div>

                                <div>
                                    <label>Fredag</label>
                                    <InputText class="settings-input" @bind-Value="restaurant.FridayHours" />
                                </div>

                                <div>
                                    <label>Lördag</label>
                                    <InputText class="settings-input" @bind-Value="restaurant.SaturdayHours" />
                                </div>

                                <div>
                                    <label>Söndag</label>
                                    <InputText class="settings-input" @bind-Value="restaurant.SundayHours" />
                                </div>
                            </div>
                        </div>

                        <div class="edit-booking-section">
                            <h2>Beställningsinställningar</h2>

                            <label class="settings-switch">
                                <InputCheckbox @bind-Value="restaurant.IsPickupEnabled" />
                                <span>
                                    <strong>Avhämtning aktiv</strong>
                                    <small>Kunder kan välja avhämtning i kassan.</small>
                                </span>
                            </label>

                            <label class="settings-switch">
                                <InputCheckbox @bind-Value="restaurant.IsDeliveryEnabled" />
                                <span>
                                    <strong>Leverans aktiv</strong>
                                    <small>Kunder kan välja leverans i kassan.</small>
                                </span>
                            </label>

                            <label class="settings-switch">
                                <InputCheckbox @bind-Value="restaurant.IsActive" />
                                <span>
                                    <strong>Restaurangen är publicerad</strong>
                                    <small>Stäng av om restaurangen inte ska vara synlig publikt.</small>
                                </span>
                            </label>
                        </div>

                        <div class="edit-booking-section">
                            <h2>Bilder</h2>

                            <div class="image-management-grid">
                                <div class="image-management-card">
                                    <label>Logotyp</label>

                                    @if (!string.IsNullOrWhiteSpace(restaurant.LogoUrl))
                                    {
                                        <div class="current-image-preview logo-preview-box">
                                            <img src="@restaurant.LogoUrl" alt="Logotyp" />
                                        </div>

                                        <button class="danger-btn" type="button" @onclick="RemoveLogo">
                                            Ta bort logotyp
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="empty-image-preview">
                                            Ingen logotyp vald
                                        </div>
                                    }

                                    <InputFile class="file-input" OnChange="UploadLogo" accept="image/png,image/jpeg,image/webp" />
                                </div>

                                <div class="image-management-card">
                                    <label>Hero-bild</label>

                                    @if (!string.IsNullOrWhiteSpace(restaurant.HeroImageUrl))
                                    {
                                        <div class="current-image-preview hero-preview-box">
                                            <img src="@restaurant.HeroImageUrl" alt="Hero-bild" />
                                        </div>

                                        <button class="danger-btn" type="button" @onclick="RemoveHeroImage">
                                            Ta bort hero-bild
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="empty-image-preview">
                                            Ingen hero-bild vald. Färg används istället.
                                        </div>
                                    }

                                    <InputFile class="file-input" OnChange="UploadHeroImage" accept="image/png,image/jpeg,image/webp" />
                                </div>
                            </div>
                        </div>

                        <div class="edit-booking-section">
                            <h2>Varumärkesfärger</h2>

                            <div class="color-grid">
                                @ColorField("Huvudfärg", "Påverkar knappar, priser och viktiga detaljer.", restaurant.PrimaryColor, v => restaurant.PrimaryColor = v)
                                @ColorField("Sekundär färg", "Stödfärg som används tillsammans med huvudfärgen.", restaurant.SecondaryColor, v => restaurant.SecondaryColor = v)
                            </div>
                        </div>

                        <div class="edit-booking-section">
                            <h2>Sidans bakgrunder</h2>

                            <div class="color-grid">
                                @ColorField("Hela sidans bakgrund", "Bakgrunden bakom hela restaurangsidan.", restaurant.PageBackgroundColor, v => restaurant.PageBackgroundColor = v)
                                @ColorField("Menysektionens bakgrund", "Bakgrunden bakom menyområdet.", restaurant.SectionBackgroundColor, v => restaurant.SectionBackgroundColor = v)
                                @ColorField("Popup och paneler", "Bakgrund i varukorg, popup och kort.", restaurant.CardBackgroundColor, v => restaurant.CardBackgroundColor = v)
                            </div>
                        </div>

                        <div class="edit-booking-section">
                            <h2>Textfärger</h2>

                            <div class="color-grid">
                                @ColorField("Rubriker", "Restaurangnamn, kategorier och rubriker.", restaurant.HeadingTextColor, v => restaurant.HeadingTextColor = v)
                                @ColorField("Vanlig text", "Beskrivningar och vanlig information.", restaurant.BodyTextColor, v => restaurant.BodyTextColor = v)
                                @ColorField("Diskret text", "Små texter och sekundär information.", restaurant.MutedTextColor, v => restaurant.MutedTextColor = v)
                            </div>
                        </div>

                        <div class="edit-booking-section">
                            <h2>Toppmeny</h2>

                            <div class="color-grid">
                                @ColorField("Toppmenyns bakgrund", "Bakgrund på navigeringen högst upp.", restaurant.NavbarBackgroundColor, v => restaurant.NavbarBackgroundColor = v)
                                @ColorField("Toppmenyns text", "Färg på vanliga länkar.", restaurant.NavbarTextColor, v => restaurant.NavbarTextColor = v)
                                @ColorField("Hover-färg", "Färg när kunden håller musen över länkar.", restaurant.NavbarLinkHoverColor, v => restaurant.NavbarLinkHoverColor = v)
                                @ColorField("Aktiv länk bakgrund", "Bakgrund för aktiv eller markerad länk.", restaurant.NavbarActiveBackgroundColor, v => restaurant.NavbarActiveBackgroundColor = v)
                                @ColorField("Aktiv länk text", "Textfärg för aktiv eller markerad länk.", restaurant.NavbarActiveTextColor, v => restaurant.NavbarActiveTextColor = v)
                                @ColorField("Kantlinje", "Färg på toppmenyns kantlinje.", restaurant.NavbarBorderColor, v => restaurant.NavbarBorderColor = v)
                                @ColorField("Logotyp bakgrund", "Bakgrund bakom initialer om logotyp saknas.", restaurant.NavbarLogoBackgroundColor, v => restaurant.NavbarLogoBackgroundColor = v)
                                @ColorField("Logotyp text", "Textfärg för initialer i logotypen.", restaurant.NavbarLogoTextColor, v => restaurant.NavbarLogoTextColor = v)
                                @ColorField("Knapp bakgrund", "Bakgrund för login/admin-knappar.", restaurant.NavbarButtonBackgroundColor, v => restaurant.NavbarButtonBackgroundColor = v)
                                @ColorField("Knapp text", "Textfärg för knappar i toppmenyn.", restaurant.NavbarButtonTextColor, v => restaurant.NavbarButtonTextColor = v)
                                @ColorField("Varumärkets titel", "Färg på restaurangens namn i toppmenyn.", restaurant.NavbarBrandTitleColor, v => restaurant.NavbarBrandTitleColor = v)
                                @ColorField("Varumärkets undertitel", "Färg på eventuell undertitel.", restaurant.NavbarBrandSubtitleColor, v => restaurant.NavbarBrandSubtitleColor = v)
                                @ColorField("Mobilmenyns bakgrund", "Bakgrund för menyn på mobil.", restaurant.NavbarMobileBackgroundColor, v => restaurant.NavbarMobileBackgroundColor = v)
                            </div>

                            <div class="settings-two-cols">
                                <div>
                                    <label>Logotypstorlek</label>
                                    <InputNumber class="settings-input" @bind-Value="restaurant.NavbarLogoSize" />
                                </div>

                                <div>
                                    <label>Navbar höjd</label>
                                    <InputNumber class="settings-input" @bind-Value="restaurant.NavbarHeight" />
                                </div>
                            </div>

                            <div class="settings-two-cols">
                                <div>
                                    <label>Rundade hörn</label>
                                    <InputNumber class="settings-input" @bind-Value="restaurant.NavbarBorderRadius" />
                                </div>

                                <div>
                                    <label>Skugga</label>
                                    <InputText class="settings-input" @bind-Value="restaurant.NavbarShadowColor" placeholder="rgba(17,24,39,.10)" />
                                </div>
                            </div>

                            <label class="settings-switch">
                                <InputCheckbox @bind-Value="restaurant.NavbarIsSticky" />
                                <span>
                                    <strong>Sticky toppmeny</strong>
                                    <small>Toppmenyn ligger kvar när kunden scrollar.</small>
                                </span>
                            </label>

                            <label class="settings-switch">
                                <InputCheckbox @bind-Value="restaurant.NavbarIsFloating" />
                                <span>
                                    <strong>Flytande toppmeny</strong>
                                    <small>Ger toppmenyn luft, rundade hörn och mer modern känsla.</small>
                                </span>
                            </label>
                        </div>

                        <div class="edit-booking-section">
                            <h2>Sidfot</h2>

                            <label>Sidfotens titel</label>
                            <InputText class="settings-input" @bind-Value="restaurant.FooterTitle" />

                            <label>Sidfotens beskrivning</label>
                            <InputTextArea class="settings-input settings-textarea" rows="3" @bind-Value="restaurant.FooterDescription" />

                            <label>Copyright-text</label>
                            <InputText class="settings-input" @bind-Value="restaurant.FooterCopyrightText" />

                            <div class="color-grid">
                                @ColorField("Sidfotens bakgrund", "Bakgrunden längst ner på restaurangsidan.", restaurant.FooterBackgroundColor, v => restaurant.FooterBackgroundColor = v)
                                @ColorField("Sidfotens text", "Vanlig text i sidfoten.", restaurant.FooterTextColor, v => restaurant.FooterTextColor = v)
                                @ColorField("Sidfotens rubriker", "Rubriker i sidfoten.", restaurant.FooterHeadingColor, v => restaurant.FooterHeadingColor = v)
                                @ColorField("Diskret text", "Små texter i sidfoten.", restaurant.FooterMutedTextColor, v => restaurant.FooterMutedTextColor = v)
                                @ColorField("Länkfärg", "Färg på länkar i sidfoten.", restaurant.FooterLinkColor, v => restaurant.FooterLinkColor = v)
                                @ColorField("Länk hover", "Färg när kunden håller musen över länkar.", restaurant.FooterLinkHoverColor, v => restaurant.FooterLinkHoverColor = v)
                                @ColorField("Kantlinje", "Färg på linjer och avdelare i sidfoten.", restaurant.FooterBorderColor, v => restaurant.FooterBorderColor = v)
                            </div>

                            <label class="settings-switch">
                                <InputCheckbox @bind-Value="restaurant.ShowFooterLogo" />
                                <span>
                                    <strong>Visa logotyp i sidfot</strong>
                                    <small>Visar restaurangens logotyp eller initialer längst ner.</small>
                                </span>
                            </label>

                            <label class="settings-switch">
                                <InputCheckbox @bind-Value="restaurant.ShowFooterSocialLinks" />
                                <span>
                                    <strong>Visa sociala länkar</strong>
                                    <small>Visar Instagram, Facebook, TikTok och webbplats om de finns.</small>
                                </span>
                            </label>

                            <label class="settings-switch">
                                <InputCheckbox @bind-Value="restaurant.ShowFooterLegalLinks" />
                                <span>
                                    <strong>Visa juridiska länkar</strong>
                                    <small>Visar Integritet och Villkor i sidfoten.</small>
                                </span>
                            </label>
                        </div>

                        <div class="edit-booking-section">
                            <h2>Knappar</h2>

                            <div class="color-grid">
                                @ColorField("Huvudknapparnas bakgrund", "Se meny, Lägg till och Skicka beställning.", restaurant.ButtonBackgroundColor, v => restaurant.ButtonBackgroundColor = v)
                                @ColorField("Huvudknapparnas text", "Textfärg i huvudknappar.", restaurant.ButtonTextColor, v => restaurant.ButtonTextColor = v)
                                @ColorField("Sekundär knapp bakgrund", "Exempelvis Kontakt & öppettider.", restaurant.SecondaryButtonBackgroundColor, v => restaurant.SecondaryButtonBackgroundColor = v)
                                @ColorField("Sekundär knapp text", "Textfärg i sekundära knappar.", restaurant.SecondaryButtonTextColor, v => restaurant.SecondaryButtonTextColor = v)
                            </div>
                        </div>

                        <div class="edit-booking-section">
                            <h2>Hero-bild</h2>

                            <div class="color-grid">
                                @ColorField("Text ovanpå hero-bilden", "Restaurangens namn och beskrivning ovanpå bilden.", restaurant.HeroTextColor, v => restaurant.HeroTextColor = v)

                                <div class="color-setting">
                                    <label>Mörkt lager över hero-bilden</label>
                                    <small>Exempel: rgba(0,0,0,.55). Högre sista siffra ger mörkare bild.</small>
                                    <InputText class="settings-input" @bind-Value="restaurant.HeroOverlayColor" placeholder="rgba(0,0,0,.55)" />
                                </div>
                            </div>
                        </div>

                        <div class="edit-booking-section">
                            <h2>Meny och rätter</h2>

                            <div class="color-grid">
                                @ColorField("Kategoribakgrund", "Bakgrund på menysektioner.", restaurant.MenuCategoryBackgroundColor, v => restaurant.MenuCategoryBackgroundColor = v)
                                @ColorField("Rättens kortbakgrund", "Bakgrund på meny-kort.", restaurant.MenuItemBackgroundColor, v => restaurant.MenuItemBackgroundColor = v)
                                @ColorField("Prisfärg", "Färg på priser i menyn och varukorgen.", restaurant.PriceTextColor, v => restaurant.PriceTextColor = v)
                            </div>
                        </div>

                        <div class="edit-booking-section">
                            <h2>Varukorg</h2>

                            <div class="color-grid">
                                @ColorField("Varukorgsradens bakgrund", "Raden längst ner efter att kunden lagt till produkter.", restaurant.CartBarBackgroundColor, v => restaurant.CartBarBackgroundColor = v)
                                @ColorField("Varukorgsradens text", "Textfärg för antal varor och totalsumma.", restaurant.CartBarTextColor, v => restaurant.CartBarTextColor = v)
                            </div>
                        </div>

                        <div class="settings-actions">
                            <button class="admin-primary-btn" type="submit" disabled="@isSaving">
                                @(isSaving ? "Sparar..." : "Spara ändringar")
                            </button>

                            <button type="button" class="admin-secondary-btn" @onclick="BackToList">
                                Tillbaka
                            </button>
                        </div>
                    </section>

                    <aside class="restaurant-edit-side">
                        <section class="restaurant-summary-card sticky-preview">
                            <p class="admin-eyebrow">Live preview</p>
                            <h2>@DisplayOrFallback(restaurant.Name, "Restaurang")</h2>

                            <div class="restaurant-preview" style="@GetPreviewVariables()">
                                <div class="mini-navbar-preview" style="@GetMiniNavbarStyle()">
                                    <div class="mini-navbar-brand">
                                        <span style="@GetMiniLogoStyle()">@GetInitials()</span>
                                        <strong style="color:@restaurant.NavbarBrandTitleColor">@DisplayOrFallback(restaurant.Name, "Restaurang")</strong>
                                    </div>

                                    <small>Hem</small>
                                    <small>Meny</small>
                                    <small style="@GetMiniNavbarButtonStyle()">Logga in</small>
                                </div>

                                <div class="preview-hero" style="@GetHeroBackgroundStyle()">
                                    <div class="preview-logo">
                                        @if (!string.IsNullOrWhiteSpace(restaurant.LogoUrl))
                                        {
                                            <img src="@restaurant.LogoUrl" />
                                        }
                                        else
                                        {
                                            <span>@GetInitials()</span>
                                        }
                                    </div>

                                    <h2>@DisplayOrFallback(restaurant.Name, "Restaurangens namn")</h2>
                                    <p>@DisplayOrFallback(restaurant.Description, "Restaurangens beskrivning visas här.")</p>

                                    <button type="button" style="@GetPrimaryButtonStyle()">Se meny</button>
                                </div>

                                <div class="preview-info" style="@GetPreviewInfoStyle()">
                                    <span>@DisplayOrFallback(restaurant.Phone, "Telefon")</span>
                                    <span>@DisplayOrFallback(restaurant.Email, "E-post")</span>
                                    <span>@DisplayOrFallback(restaurant.Address, "Adress")</span>
                                </div>

                                <div class="preview-mini-section" style="@GetPreviewCardStyle()">
                                    <strong style="color:@restaurant.HeadingTextColor">
                                        Exempel på rätt
                                    </strong>

                                    <p style="color:@restaurant.BodyTextColor">
                                        Här ser du hur ett meny-kort kan se ut.
                                    </p>

                                    <span style="color:@restaurant.PriceTextColor">129.00 kr</span>
                                </div>

                                <div class="mini-cart-preview" style="@GetMiniCartStyle()">
                                    <strong>2 varor</strong>
                                    <span>258.00 kr</span>
                                </div>

                                <div class="mini-footer-preview" style="@GetMiniFooterStyle()">
                                    <strong style="color:@restaurant.FooterHeadingColor">
                                        @DisplayOrFallback(restaurant.FooterTitle, restaurant.Name)
                                    </strong>

                                    <span style="color:@restaurant.FooterTextColor">
                                        @DisplayOrFallback(restaurant.FooterDescription, "Sidfotens beskrivning visas här.")
                                    </span>

                                    <small style="color:@restaurant.FooterLinkColor">
                                        Integritet • Villkor • Kontakt
                                    </small>
                                </div>
                            </div>

                            <div class="restaurant-edit-preview-actions">
                                <button type="button" class="admin-secondary-btn" @onclick="ViewRestaurant">
                                    Visa restaurang
                                </button>
                            </div>
                        </section>

                        <section class="restaurant-summary-card">
                            <p class="admin-eyebrow">Status</p>

                            <div class="restaurant-summary-list">
                                <div>
                                    <span>Publicerad</span>
                                    <strong>@(restaurant.IsActive ? "Ja" : "Nej")</strong>
                                </div>

                                <div>
                                    <span>Avhämtning</span>
                                    <strong>@(restaurant.IsPickupEnabled ? "Aktiv" : "Av")</strong>
                                </div>

                                <div>
                                    <span>Leverans</span>
                                    <strong>@(restaurant.IsDeliveryEnabled ? "Aktiv" : "Av")</strong>
                                </div>

                                <div>
                                    <span>URL</span>
                                    <strong>/restaurant/@restaurant.Slug</strong>
                                </div>
                            </div>
                        </section>
                    </aside>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public int RestaurantId { get; set; }

    private Restaurant? restaurant;
    private string? errorMessage;
    private string? successMessage;

    private bool checkedAccess;
    private bool isAuthorized;
    private bool isSaving;
    private bool savedHighlight;

    private const long MaxFileSize = 5 * 1024 * 1024;

    protected override async Task OnParametersSetAsync()
    {
        checkedAccess = false;
        isAuthorized = false;
        errorMessage = null;
        successMessage = null;
        savedHighlight = false;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        isAuthorized = await AccessService.CanManageRestaurantSettingsAsync(
            authState.User,
            RestaurantId);

        checkedAccess = true;

        if (!isAuthorized)
        {
            Navigation.NavigateTo("/Account/Denied", true);
            return;
        }

        restaurant = await Db.Restaurants
            .FirstOrDefaultAsync(x => x.Id == RestaurantId);

        if (restaurant is not null)
            ApplyDefaultDesignColors();
    }

    private async Task SaveRestaurant()
    {
        if (!isAuthorized || restaurant is null)
            return;

        errorMessage = null;
        successMessage = null;
        savedHighlight = false;
        isSaving = true;

        try
        {
            restaurant.Name = restaurant.Name.Trim();
            restaurant.Slug = NormalizeSlug(restaurant.Slug);

            ApplyDefaultDesignColors();

            if (string.IsNullOrWhiteSpace(restaurant.Name))
            {
                errorMessage = "Restaurangens namn krävs.";
                return;
            }

            if (string.IsNullOrWhiteSpace(restaurant.Slug))
            {
                errorMessage = "URL / slug krävs.";
                return;
            }

            bool slugExists = await Db.Restaurants
                .AnyAsync(x => x.Slug == restaurant.Slug && x.Id != restaurant.Id);

            if (slugExists)
            {
                errorMessage = "Denna URL används redan av en annan restaurang.";
                return;
            }

            await Db.SaveChangesAsync();

            savedHighlight = true;
            successMessage = "Restaurangen har uppdaterats.";
        }
        finally
        {
            isSaving = false;
        }
    }

