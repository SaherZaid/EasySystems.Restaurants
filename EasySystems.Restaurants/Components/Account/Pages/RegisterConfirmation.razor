@page "/Account/RegisterConfirmation"

@using Microsoft.AspNetCore.Identity
@using EasySystems.Restaurants.Data

@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Check your email</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <span>ES</span>
            <div>
                <strong>EasySystems</strong>
                <p>Account created</p>
            </div>
        </div>

        <StatusMessage Message="@statusMessage" />

        <div class="auth-header">
            <p class="eyebrow">Check your inbox</p>
            <h1>Confirm your email</h1>
            <p>
                We sent a confirmation link to <strong>@Email</strong>.
                Please open it to activate your account.
            </p>
        </div>

        <div class="auth-links">
            <a href="/Account/Login">Go to login</a>

            <a href="@GetResendLink()">
                Resend confirmation email
            </a>
        </div>
    </div>

    <div class="auth-side">
        <div class="auth-side-content">
            <span class="auth-badge">One more step</span>
            <h2>Open your email and verify your account.</h2>
            <p>
                Confirming your email helps keep your account safe and unlocks login access.
            </p>

            <div class="auth-points">
                <div>
                    <strong>01</strong>
                    <span>Open your inbox</span>
                </div>

                <div>
                    <strong>02</strong>
                    <span>Click the confirmation link</span>
                </div>

                <div>
                    <strong>03</strong>
                    <span>Sign in to continue</span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string? statusMessage;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? Email { get; set; }

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (Email is null)
        {
            RedirectManager.RedirectTo("");
            return;
        }

        var user = await UserManager.FindByEmailAsync(Email);

        if (user is null)
        {
            HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
            statusMessage = "Error finding user for the provided email.";
        }
    }

    private string GetResendLink()
    {
        return NavigationManager.GetUriWithQueryParameters(
            "/Account/ResendEmailConfirmation",
            new Dictionary<string, object?>
                {
                    ["email"] = Email
                });
    }
}