@page "/Account/ResetPasswordConfirmation"

<PageTitle>Lösenordet har återställts</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <span>ES</span>
            <div>
                <strong>EasySystems</strong>
                <p>Lösenordet har uppdaterats</p>
            </div>
        </div>

        <div class="auth-header">
            <p class="eyebrow">Klart</p>
            <h1>Lösenordet har återställts</h1>
            <p>Ditt lösenord har uppdaterats. Du kan nu logga in med ditt nya lösenord.</p>
        </div>

        <a class="auth-submit auth-link-button" href="/Account/Login">
            Gå till inloggning
        </a>
    </div>

    <div class="auth-side">
        <div class="auth-side-content">
            <span class="auth-badge">Du är redo</span>
            <h2>Ditt konto är säkert igen.</h2>
            <p>
                Logga in och fortsätt hantera dina beställningar, restaurangens kontrollpanel eller ditt kundkonto.
            </p>
        </div>
    </div>
</div>