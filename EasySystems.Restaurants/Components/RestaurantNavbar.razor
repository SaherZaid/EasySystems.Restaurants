@using EasySystems.Restaurants.Models
@using EasySystems.Restaurants.Data
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Routing

@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<nav class="restaurant-navbar"
     style="--nav-bg:@GetNavBackground(); --nav-text:@GetNavText(); --primary:@GetPrimary();">
    <div class="restaurant-navbar-inner">
        <a class="restaurant-nav-brand" href="/restaurant/@Restaurant?.Slug">
            @if (!string.IsNullOrWhiteSpace(Restaurant?.LogoUrl))
            {
                <img src="@Restaurant.LogoUrl" alt="@Restaurant.Name logo" />
            }
            else
            {
                <span>@GetInitials()</span>
            }

            <strong>@Restaurant?.Name</strong>
        </a>

        <button type="button" class="restaurant-nav-toggle" @onclick="ToggleMenu">
            ☰
        </button>

        <div class="restaurant-nav-links @(isOpen ? "open" : "")">
            <a href="/restaurant/@Restaurant?.Slug" @onclick="CloseMenu">Hem</a>
            <a href="/restaurant/@Restaurant?.Slug#menu" @onclick="CloseMenu">Meny</a>
            <a href="/restaurant/@Restaurant?.Slug/contact" @onclick="CloseMenu">Kontakt & öppettider</a>
            <a href="/restaurant/@Restaurant?.Slug/privacy" @onclick="CloseMenu">Privacy</a>
            <a href="/restaurant/@Restaurant?.Slug/terms" @onclick="CloseMenu">Terms</a>

            @if (currentUser is not null)
            {
                <a href="/Account/Orders" @onclick="CloseMenu">Mina beställningar</a>
                <a href="/Account/Profile" @onclick="CloseMenu">Mitt konto</a>

                <form action="/Account/RestaurantLogout" method="post" class="restaurant-nav-logout">
                    <AntiforgeryToken />
                    <input type="hidden" name="returnUrl" value="@GetReturnUrl()" />
                    <button type="submit">
                        Logga ut
                    </button>
                </form>
            }
            else
            {
                <a class="restaurant-login-link" href="@GetLoginUrl()" @onclick="CloseMenu">
                    Logga in
                </a>
            }
        </div>
    </div>
</nav>

@code {
    [Parameter]
    public Restaurant? Restaurant { get; set; }

    private bool isOpen;
    private ApplicationUser? currentUser;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity?.IsAuthenticated == true)
        {
            currentUser = await UserManager.GetUserAsync(authState.User);
        }
    }

    private void ToggleMenu()
    {
        isOpen = !isOpen;
    }

    private void CloseMenu()
    {
        isOpen = false;
    }

    private string GetReturnUrl()
    {
        if (Restaurant is null || string.IsNullOrWhiteSpace(Restaurant.Slug))
            return "/";

        return $"/restaurant/{Restaurant.Slug}";
    }

    private string GetLoginUrl()
    {
        var returnUrl = GetReturnUrl();

        return Navigation.GetUriWithQueryParameters(
            "/Account/Login",
            new Dictionary<string, object?>
            {
                ["ReturnUrl"] = returnUrl
            });
    }

    private string GetNavBackground()
        => string.IsNullOrWhiteSpace(Restaurant?.NavbarBackgroundColor)
            ? "#FFFFFF"
            : Restaurant.NavbarBackgroundColor;

    private string GetNavText()
        => string.IsNullOrWhiteSpace(Restaurant?.NavbarTextColor)
            ? "#111827"
            : Restaurant.NavbarTextColor;

    private string GetPrimary()
        => string.IsNullOrWhiteSpace(Restaurant?.PrimaryColor)
            ? "#111827"
            : Restaurant.PrimaryColor;

    private string GetInitials()
    {
        if (Restaurant is null || string.IsNullOrWhiteSpace(Restaurant.Name))
            return "R";

        var words = Restaurant.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Join("", words.Take(2).Select(x => x[0])).ToUpper();
    }
}