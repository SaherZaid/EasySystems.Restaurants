@page "/admin/restaurants/{RestaurantId:int}/items"
@rendermode InteractiveServer

@using EasySystems.Restaurants.Data
@using EasySystems.Restaurants.Models
@using EasySystems.Restaurants.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize]

@inject ApplicationDbContext Db
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment
@inject RestaurantAccessService AccessService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Rätter</PageTitle>

@if (restaurant is not null && isAuthorized)
{
    <AdminNavbar RestaurantId="RestaurantId" RestaurantSlug="@restaurant.Slug" />
}

@if (!checkedAccess)
{
    <div class="public-loading">Kontrollerar behörighet...</div>
}
else if (!isAuthorized)
{
    <div class="public-loading">Omdirigerar...</div>
}
else
{
    <div class="admin-page">
        <div class="admin-header">
            <div>
                <p class="eyebrow">Meny</p>
                <h1>Rätter</h1>
                <p class="subtitle">
                    Lägg till rätter, priser, bilder och tillval. Du kan även dölja rätter som är slut.
                </p>
            </div>

            <div class="restaurant-admin-actions">
                <button type="button" @onclick="GoToCategories">Kategorier</button>
                <button type="button" @onclick="GoToRestaurant">Visa restaurang</button>
            </div>
        </div>

        @if (restaurant is null)
        {
            <div class="form-card admin-center-card">
                <h2>Restaurangen hittades inte</h2>
                <p>Den här restaurangen finns inte.</p>
            </div>
        }
        else if (categories.Count == 0)
        {
            <div class="form-card admin-center-card">
                <h2>Inga kategorier ännu</h2>
                <p>Du behöver skapa kategorier innan du lägger till rätter.</p>
                <button class="save-btn" type="button" @onclick="GoToCategories">
                    Skapa kategorier
                </button>
            </div>
        }
        else
        {
            <div class="admin-items-dashboard">
                <div class="items-left-column">
                    <div class="form-card">
                        <div class="admin-card-title">
                            <div>
                                <h2>Ny rätt</h2>
                                <p>Fyll i informationen och klicka på lägg till.</p>
                            </div>
                            <span>@items.Count st</span>
                        </div>

                        <label>Kategori</label>
                        <InputSelect class="input" @bind-Value="newItem.MenuCategoryId">
                            @foreach (var category in categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </InputSelect>

                        <label>Namn på rätt</label>
                        <InputText class="input"
                                   @bind-Value="newItem.Name"
                                   placeholder="Exempel: Kycklingkebab tallrik" />

                        <label>Beskrivning</label>
                        <InputTextArea class="input textarea"
                                       @bind-Value="newItem.Description"
                                       placeholder="Exempel: Serveras med ris, sallad och valfri sås." />

                        <div class="two-cols">
                            <div>
                                <label>Pris</label>
                                <InputNumber class="input" @bind-Value="newItem.Price" />
                            </div>

                            <div>
                                <label>Placering</label>
                                <InputNumber class="input" @bind-Value="newItem.SortOrder" />
                            </div>
                        </div>

                        <label>Bild</label>
                        <InputFile class="file-input"
                                   OnChange="UploadNewItemImage"
                                   accept="image/png,image/jpeg,image/webp" />

                        @if (!string.IsNullOrWhiteSpace(newItem.ImageUrl))
                        {
                            <div class="dish-image-preview">
                                <img src="@newItem.ImageUrl" alt="Förhandsvisning" />
                                <span>Bilden är uppladdad</span>
                            </div>
                        }

                        <button class="save-btn" type="button" @onclick="AddItem">
                            Lägg till rätt
                        </button>

                        @if (!string.IsNullOrWhiteSpace(errorMessage))
                        {
                            <div class="error">@errorMessage</div>
                        }

                        @if (!string.IsNullOrWhiteSpace(successMessage))
                        {
                            <div class="upload-success">@successMessage</div>
                        }
                    </div>

                    <div class="form-card category-help-card">
                        <h3>Tips</h3>
                        <p>
                            Håll namnet kort och använd beskrivningen för innehåll, såser och tillbehör.
                        </p>
                        <ul>
                            <li>Markera som ej tillgänglig om rätten är slut.</li>
                            <li>Använd tillval för extra sås, borttagna ingredienser eller topping.</li>
                            <li>Lägg gärna till bild för bättre meny.</li>
                        </ul>
                    </div>
                </div>

                <div class="preview-card">
                    <div class="admin-card-title">
                        <div>
                            <p class="preview-label">@restaurant.Name</p>
                            <h2>Alla rätter</h2>
                        </div>

                        <span>@AvailableItemCount tillgängliga</span>
                    </div>

                    <div class="items-toolbar">
                        <input class="input"
                               value="@itemSearchText"
                               @oninput="OnItemSearchChanged"
                               placeholder="Sök rätt..." />

                        <InputSelect class="input" @bind-Value="selectedCategoryFilter">
                            <option value="0">Alla kategorier</option>
                            @foreach (var category in categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </InputSelect>
                    </div>

                    @if (FilteredItems.Count == 0)
                    {
                        <div class="empty-menu">
                            <h3>Inga rätter hittades</h3>
                            <p>Testa att ändra sökning eller kategori.</p>
                        </div>
                    }
                    else
                    {
                        <div class="item-admin-list modern-item-list">
                            @foreach (var item in FilteredItems)
                            {
                                <div class="item-admin-card modern-item-card @(item.IsAvailable ? "" : "is-hidden")">
                                    @if (editingItemId == item.Id)
                                    {
                                        <div class="edit-item-form modern-edit-item-form">
                                            <h3>Redigera rätt</h3>

                                            <label>Kategori</label>
                                            <InputSelect class="input" @bind-Value="editItem.MenuCategoryId">
                                                @foreach (var category in categories)
                                                {
                                                    <option value="@category.Id">@category.Name</option>
                                                }
                                            </InputSelect>

                                            <label>Namn på rätt</label>
                                            <InputText class="input" @bind-Value="editItem.Name" />

                                            <label>Beskrivning</label>
                                            <InputTextArea class="input textarea" @bind-Value="editItem.Description" />

                                            <div class="two-cols">
                                                <div>
                                                    <label>Pris</label>
                                                    <InputNumber class="input" @bind-Value="editItem.Price" />
                                                </div>

                                                <div>
                                                    <label>Placering</label>
                                                    <InputNumber class="input" @bind-Value="editItem.SortOrder" />
                                                </div>
                                            </div>

                                            <label class="checkbox-label">
                                                <InputCheckbox @bind-Value="editItem.IsAvailable" />
                                                Visa rätten för kunder
                                            </label>

                                            @if (!string.IsNullOrWhiteSpace(editItem.ImageUrl))
                                            {
                                                <div class="dish-image-preview">
                                                    <img src="@editItem.ImageUrl" alt="@editItem.Name" />
                                                    <span>Nuvarande bild</span>
                                                </div>
                                            }

                                            <label>Byt bild</label>
                                            <InputFile class="file-input"
                                                       OnChange="UploadEditItemImage"
                                                       accept="image/png,image/jpeg,image/webp" />

                                            <div class="category-actions">
                                                <button type="button" class="save-small-btn" @onclick="SaveEditItem">
                                                    Spara
                                                </button>

                                                <button type="button" @onclick="CancelEditItem">
                                                    Avbryt
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="modern-item-image">
                                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                            {
                                                <img src="@item.ImageUrl" alt="@item.Name" />
                                            }
                                            else
                                            {
                                                <span>Ingen bild</span>
                                            }
                                        </div>

                                        <div class="modern-item-info">
                                            <div class="item-title-row">
                                                <strong>@item.Name</strong>

                                                @if (item.IsAvailable)
                                                {
                                                    <small class="visible-badge">Synlig</small>
                                                }
                                                else
                                                {
                                                    <small class="hidden-badge">Ej tillgänglig</small>
                                                }
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(item.Description))
                                            {
                                                <p>@item.Description</p>
                                            }
                                            else
                                            {
                                                <p class="muted-text">Ingen beskrivning tillagd.</p>
                                            }

                                            <div class="item-meta-row">
                                                <span>@item.Price.ToString("0.00") kr</span>
                                                <small>@item.MenuCategory?.Name</small>
                                            </div>
                                        </div>

                                        <div class="category-actions item-actions-modern">
                                            <button type="button" @onclick="() => StartEditItem(item)">
                                                Redigera
                                            </button>

                                            <button type="button" @onclick="() => ManageOptions(item.Id)">
                                                Tillval
                                            </button>

                                            <button type="button" @onclick="() => ToggleAvailability(item)">
                                                @(item.IsAvailable ? "Dölj" : "Visa")
                                            </button>

                                            @if (pendingDeleteItemId == item.Id)
                                            {
                                                <button class="danger-btn" type="button" @onclick="() => DeleteItem(item)">
                                                    Bekräfta radering
                                                </button>

                                                <button type="button" @onclick="CancelDelete">
                                                    Avbryt
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="danger-btn" type="button" @onclick="() => AskDelete(item)">
                                                    Radera
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public int RestaurantId { get; set; }

    private Restaurant? restaurant;
    private List<MenuCategory> categories = [];
    private List<MenuItem> items = [];

    private string? errorMessage;
    private string? successMessage;
    private string itemSearchText = string.Empty;

    private int selectedCategoryFilter;
    private int? editingItemId;
    private int? pendingDeleteItemId;

    private bool checkedAccess;
    private bool isAuthorized;

    private int AvailableItemCount => items.Count(x => x.IsAvailable);

    private List<MenuItem> FilteredItems
    {
        get
        {
            var query = items.AsEnumerable();

            if (selectedCategoryFilter > 0)
            {
                query = query.Where(x => x.MenuCategoryId == selectedCategoryFilter);
            }

            if (!string.IsNullOrWhiteSpace(itemSearchText))
            {
                var text = itemSearchText.Trim();

                query = query.Where(x =>
                    (!string.IsNullOrWhiteSpace(x.Name) &&
                     x.Name.Contains(text, StringComparison.OrdinalIgnoreCase)) ||
                    (!string.IsNullOrWhiteSpace(x.Description) &&
                     x.Description.Contains(text, StringComparison.OrdinalIgnoreCase)) ||
                    (!string.IsNullOrWhiteSpace(x.MenuCategory?.Name) &&
                     x.MenuCategory.Name.Contains(text, StringComparison.OrdinalIgnoreCase)));
            }

            return query.ToList();
        }
    }

    private MenuItem newItem = new()
        {
            IsAvailable = true
        };

    private MenuItem editItem = new();

    private const long MaxFileSize = 5 * 1024 * 1024;

    protected override async Task OnParametersSetAsync()
    {
        checkedAccess = false;
        isAuthorized = false;
        errorMessage = null;
        successMessage = null;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        isAuthorized = await AccessService.CanManageRestaurantMenuAsync(
            authState.User,
            RestaurantId);

        checkedAccess = true;

        if (!isAuthorized)
        {
            Navigation.NavigateTo("/Account/Denied", true);
            return;
        }

        restaurant = await Db.Restaurants
            .FirstOrDefaultAsync(x => x.Id == RestaurantId);

        if (restaurant is null)
            return;

        categories = await Db.MenuCategories
            .Where(x => x.RestaurantId == RestaurantId)
            .OrderBy(x => x.SortOrder)
            .ThenBy(x => x.Name)
            .ToListAsync();

        await LoadItems();
        ResetNewItem();
    }

    private async Task LoadItems()
    {
        if (!isAuthorized)
            return;

        items = await Db.MenuItems
            .Include(x => x.MenuCategory)
            .Where(x => x.MenuCategory != null && x.MenuCategory.RestaurantId == RestaurantId)
            .OrderBy(x => x.MenuCategory!.SortOrder)
            .ThenBy(x => x.SortOrder)
            .ThenBy(x => x.Name)
            .ToListAsync();
    }

    private void ResetNewItem()
    {
        var firstCategoryId = categories.FirstOrDefault()?.Id ?? 0;

        newItem = new MenuItem
            {
                MenuCategoryId = firstCategoryId,
                IsAvailable = true,
                SortOrder = firstCategoryId == 0
                    ? 1
                    : items.Count(x => x.MenuCategoryId == firstCategoryId) + 1
            };
    }

    private async Task AddItem()
    {
        errorMessage = null;
        successMessage = null;
        pendingDeleteItemId = null;

        if (!isAuthorized)
            return;

        newItem.Name = newItem.Name?.Trim() ?? string.Empty;
        newItem.Description = newItem.Description?.Trim() ?? string.Empty;

        if (newItem.MenuCategoryId <= 0)
        {
            errorMessage = "Välj en kategori.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newItem.Name))
        {
            errorMessage = "Namn på rätt krävs.";
            return;
        }

        if (newItem.Price <= 0)
        {
            errorMessage = "Priset måste vara större än 0.";
            return;
        }

        newItem.IsAvailable = true;

        Db.MenuItems.Add(newItem);
        await Db.SaveChangesAsync();

        await LoadItems();
        ResetNewItem();

        successMessage = "Rätten har lagts till.";
    }

    private void StartEditItem(MenuItem item)
    {
        if (!isAuthorized)
            return;

        errorMessage = null;
        successMessage = null;
        pendingDeleteItemId = null;

        editingItemId = item.Id;

        editItem = new MenuItem
            {
                Id = item.Id,
                MenuCategoryId = item.MenuCategoryId,
                Name = item.Name,
                Description = item.Description,
                Price = item.Price,
                ImageUrl = item.ImageUrl,
                IsAvailable = item.IsAvailable,
                SortOrder = item.SortOrder
            };
    }

    private void CancelEditItem()
    {
        editingItemId = null;
        editItem = new MenuItem();
        errorMessage = null;
    }

    private async Task SaveEditItem()
    {
        errorMessage = null;
        successMessage = null;

        if (!isAuthorized || editingItemId is null)
            return;

        editItem.Name = editItem.Name?.Trim() ?? string.Empty;
        editItem.Description = editItem.Description?.Trim() ?? string.Empty;

        if (editItem.MenuCategoryId <= 0)
        {
            errorMessage = "Välj en kategori.";
            return;
        }

        if (string.IsNullOrWhiteSpace(editItem.Name))
        {
            errorMessage = "Namn på rätt krävs.";
            return;
        }

        if (editItem.Price <= 0)
        {
            errorMessage = "Priset måste vara större än 0.";
            return;
        }

        var item = await Db.MenuItems
            .Include(x => x.MenuCategory)
            .FirstOrDefaultAsync(x =>
                x.Id == editingItemId.Value &&
                x.MenuCategory != null &&
                x.MenuCategory.RestaurantId == RestaurantId);

        if (item is null)
        {
            errorMessage = "Rätten hittades inte.";
            return;
        }

        item.MenuCategoryId = editItem.MenuCategoryId;
        item.Name = editItem.Name;
        item.Description = editItem.Description;
        item.Price = editItem.Price;
        item.ImageUrl = editItem.ImageUrl;
        item.IsAvailable = editItem.IsAvailable;
        item.SortOrder = editItem.SortOrder;

        await Db.SaveChangesAsync();
        await LoadItems();

        editingItemId = null;
        successMessage = "Rätten har uppdaterats.";
    }

    private async Task UploadNewItemImage(InputFileChangeEventArgs e)
    {
        if (!isAuthorized)
            return;

        var imageUrl = await SaveImageAsync(e.File, "products");

        if (!string.IsNullOrWhiteSpace(imageUrl))
        {
            newItem.ImageUrl = imageUrl;
        }
    }

    private async Task UploadEditItemImage(InputFileChangeEventArgs e)
    {
        if (!isAuthorized)
            return;

        var imageUrl = await SaveImageAsync(e.File, "products");

        if (!string.IsNullOrWhiteSpace(imageUrl))
        {
            editItem.ImageUrl = imageUrl;
        }
    }

    private async Task<string> SaveImageAsync(IBrowserFile file, string folderName)
    {
        if (!isAuthorized)
            return string.Empty;

        errorMessage = null;
        successMessage = null;

        var allowedExtensions = new[] { ".jpg", ".jpeg", ".png", ".webp" };
        var extension = Path.GetExtension(file.Name).ToLowerInvariant();

        if (!allowedExtensions.Contains(extension))
        {
            errorMessage = "Endast JPG, PNG och WEBP är tillåtna.";
            return string.Empty;
        }

        if (file.Size > MaxFileSize)
        {
            errorMessage = "Bilden får vara max 5 MB.";
            return string.Empty;
        }

        var uploadFolder = Path.Combine(Environment.WebRootPath, "uploads", folderName);

        if (!Directory.Exists(uploadFolder))
        {
            Directory.CreateDirectory(uploadFolder);
        }

        var fileName = $"{Guid.NewGuid()}{extension}";
        var fullPath = Path.Combine(uploadFolder, fileName);
        var relativePath = $"/uploads/{folderName}/{fileName}";

        await using var readStream = file.OpenReadStream(MaxFileSize);
        await using var writeStream = File.Create(fullPath);

        await readStream.CopyToAsync(writeStream);

        successMessage = "Bilden har laddats upp.";
        return relativePath;
    }

    private async Task ToggleAvailability(MenuItem item)
    {
        if (!isAuthorized)
            return;

        errorMessage = null;
        successMessage = null;
        pendingDeleteItemId = null;

        var dbItem = await Db.MenuItems
            .Include(x => x.MenuCategory)
            .FirstOrDefaultAsync(x =>
                x.Id == item.Id &&
                x.MenuCategory != null &&
                x.MenuCategory.RestaurantId == RestaurantId);

        if (dbItem is null)
            return;

        dbItem.IsAvailable = !dbItem.IsAvailable;

        await Db.SaveChangesAsync();
        await LoadItems();

        successMessage = dbItem.IsAvailable
            ? "Rätten visas nu för kunder."
            : "Rätten är nu dold för kunder.";
    }

    private void AskDelete(MenuItem item)
    {
        errorMessage = null;
        successMessage = null;
        pendingDeleteItemId = item.Id;
    }

    private void CancelDelete()
    {
        pendingDeleteItemId = null;
        errorMessage = null;
    }

    private async Task DeleteItem(MenuItem item)
    {
        if (!isAuthorized)
            return;

        errorMessage = null;
        successMessage = null;

        var dbItem = await Db.MenuItems
            .Include(x => x.MenuCategory)
            .FirstOrDefaultAsync(x =>
                x.Id == item.Id &&
                x.MenuCategory != null &&
                x.MenuCategory.RestaurantId == RestaurantId);

        if (dbItem is null)
            return;

        Db.MenuItems.Remove(dbItem);
        await Db.SaveChangesAsync();

        pendingDeleteItemId = null;

        await LoadItems();
        ResetNewItem();

        successMessage = "Rätten har raderats.";
    }

    private void OnItemSearchChanged(ChangeEventArgs e)
    {
        itemSearchText = e.Value?.ToString() ?? string.Empty;
    }

    private void ManageOptions(int menuItemId)
    {
        if (!isAuthorized)
            return;

        Navigation.NavigateTo($"/admin/restaurants/{RestaurantId}/items/{menuItemId}/options");
    }

    private void GoToCategories()
    {
        Navigation.NavigateTo($"/admin/restaurants/{RestaurantId}/categories");
    }

    private void GoToRestaurant()
    {
        if (restaurant is not null)
            Navigation.NavigateTo($"/restaurant/{restaurant.Slug}");
    }
}