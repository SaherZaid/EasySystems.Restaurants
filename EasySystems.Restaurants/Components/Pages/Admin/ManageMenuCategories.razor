@page "/admin/restaurants/{RestaurantId:int}/categories"
@using EasySystems.Restaurants.Data
@using EasySystems.Restaurants.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject NavigationManager Navigation

<PageTitle>Manage Menu Categories</PageTitle>

<div class="admin-page">
    <div class="admin-header">
        <div>
            <p class="eyebrow">Menu Builder</p>
            <h1>Manage menu categories</h1>
            <p class="subtitle">Add, rename, hide, delete and reorder restaurant menu sections.</p>
        </div>
    </div>

    @if (restaurant is null)
    {
        <div class="form-card admin-center-card">
            <h2>Restaurant not found</h2>
            <p>This restaurant does not exist.</p>
        </div>
    }
    else
    {
        <div class="admin-grid">
            <div class="form-card">
                <h2>Add new category</h2>

                <label>Category name</label>
                <InputText class="input" @bind-Value="newCategory.Name" placeholder="Burgare, Drycker, Sushi, Mandi..." />

                <label>Description</label>
                <InputTextArea class="input textarea" @bind-Value="newCategory.Description" placeholder="Short optional description..." />

                <label>Sort order</label>
                <InputNumber class="input" @bind-Value="newCategory.SortOrder" />

                <button class="save-btn" type="button" @onclick="AddCategory">Add category</button>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="error">@errorMessage</div>
                }
            </div>

            <div class="preview-card">
                <p class="preview-label">@restaurant.Name</p>

                @if (categories.Count == 0)
                {
                    <div class="empty-menu">
                        <h3>No categories yet</h3>
                        <p>Add your first menu category.</p>
                    </div>
                }
                else
                {
                    <div class="category-list">
                        @foreach (var category in categories)
                        {
                            <div class="category-admin-item">
                                <div>
                                    <strong>@category.Name</strong>
                                    <p>@category.Description</p>
                                    <span>Order: @category.SortOrder</span>
                                </div>

                                <div class="category-actions">
                                    <button type="button" @onclick="() => ToggleVisibility(category)">
                                        @(category.IsVisible ? "Hide" : "Show")
                                    </button>

                                    <button type="button" @onclick="() => MoveUp(category)">
                                        ↑
                                    </button>

                                    <button type="button" @onclick="() => MoveDown(category)">
                                        ↓
                                    </button>

                                    <button class="danger-btn" type="button" @onclick="() => DeleteCategory(category)">
                                        Delete
                                    </button>
                                </div>

                                @if (!category.IsVisible)
                                {
                                    <small class="hidden-badge">Hidden</small>
                                }
                            </div>
                        }
                    </div>
                }

                <button class="secondary-admin-btn" type="button" @onclick="GoToRestaurant">
                    View restaurant page
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int RestaurantId { get; set; }

    private Restaurant? restaurant;
    private List<MenuCategory> categories = [];
    private string? errorMessage;

    private MenuCategory newCategory = new()
        {
            IsVisible = true
        };

    protected override async Task OnParametersSetAsync()
    {
        restaurant = await Db.Restaurants
            .FirstOrDefaultAsync(x => x.Id == RestaurantId);

        await LoadCategories();

        newCategory.RestaurantId = RestaurantId;
        newCategory.SortOrder = categories.Count + 1;
    }

    private async Task LoadCategories()
    {
        categories = await Db.MenuCategories
            .Where(x => x.RestaurantId == RestaurantId)
            .OrderBy(x => x.SortOrder)
            .ToListAsync();
    }

    private async Task AddCategory()
    {
        errorMessage = null;

        newCategory.Name = newCategory.Name.Trim();

        if (string.IsNullOrWhiteSpace(newCategory.Name))
        {
            errorMessage = "Category name is required.";
            return;
        }

        newCategory.RestaurantId = RestaurantId;
        newCategory.IsVisible = true;

        Db.MenuCategories.Add(newCategory);
        await Db.SaveChangesAsync();

        newCategory = new MenuCategory
            {
                RestaurantId = RestaurantId,
                IsVisible = true,
                SortOrder = categories.Count + 2
            };

        await LoadCategories();
    }

    private async Task ToggleVisibility(MenuCategory category)
    {
        category.IsVisible = !category.IsVisible;
        await Db.SaveChangesAsync();
        await LoadCategories();
    }

    private async Task MoveUp(MenuCategory category)
    {
        if (category.SortOrder <= 1)
            return;

        category.SortOrder--;
        await Db.SaveChangesAsync();
        await LoadCategories();
    }

    private async Task MoveDown(MenuCategory category)
    {
        category.SortOrder++;
        await Db.SaveChangesAsync();
        await LoadCategories();
    }

    private async Task DeleteCategory(MenuCategory category)
    {
        Db.MenuCategories.Remove(category);
        await Db.SaveChangesAsync();
        await LoadCategories();
    }

    private void GoToRestaurant()
    {
        if (restaurant is not null)
            Navigation.NavigateTo($"/restaurant/{restaurant.Slug}");
    }
}