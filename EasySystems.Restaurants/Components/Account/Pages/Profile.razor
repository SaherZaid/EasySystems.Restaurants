@page "/Account/Profile"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using EasySystems.Restaurants.Data
@using EasySystems.Restaurants.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@attribute [Authorize]

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Min profil</PageTitle>

@if (navbarRestaurant is not null)
{
    <RestaurantNavbar Restaurant="navbarRestaurant" />
}

<div class="customer-profile-page">
    <div class="customer-profile-shell">
        <div class="customer-profile-hero">
            <div class="customer-profile-avatar">
                @GetInitials()
            </div>

            <div>
                <p class="eyebrow">Mitt konto</p>
                <h1>@GetDisplayName()</h1>
                <p>@currentUser?.Email</p>
            </div>
        </div>

        <div class="customer-profile-grid">
            <div class="customer-profile-card">
                <h2>Profiluppgifter</h2>
                <p>Uppdatera ditt namn och telefonnummer som används vid beställning.</p>

                @if (isLoading)
                {
                    <div class="public-loading">Laddar profil...</div>
                }
                else
                {
                    <EditForm Model="Input" OnValidSubmit="SaveProfile" FormName="customer-profile">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="auth-error-list" />

                        <div class="auth-two-cols">
                            <div class="auth-field">
                                <label>Förnamn</label>
                                <InputText class="auth-input" @bind-Value="Input.FirstName" />
                                <ValidationMessage For="() => Input.FirstName" class="auth-validation" />
                            </div>

                            <div class="auth-field">
                                <label>Efternamn</label>
                                <InputText class="auth-input" @bind-Value="Input.LastName" />
                                <ValidationMessage For="() => Input.LastName" class="auth-validation" />
                            </div>
                        </div>

                        <div class="auth-field">
                            <label>E-post</label>
                            <input class="auth-input" value="@Input.Email" disabled />
                        </div>

                        <div class="auth-field">
                            <label>Telefonnummer</label>
                            <InputText class="auth-input" @bind-Value="Input.PhoneNumber" />
                            <ValidationMessage For="() => Input.PhoneNumber" class="auth-validation" />
                        </div>

                        <button type="submit" class="auth-submit">
                            Spara profil
                        </button>

                        @if (!string.IsNullOrWhiteSpace(successMessage))
                        {
                            <div class="upload-success">@successMessage</div>
                        }

                        @if (!string.IsNullOrWhiteSpace(errorMessage))
                        {
                            <div class="error">@errorMessage</div>
                        }
                    </EditForm>
                }
            </div>

            <div class="customer-profile-card customer-profile-side">
                <h2>Konto</h2>

                <div class="profile-info-row">
                    <span>E-post bekräftad</span>
                    <strong>@(currentUser?.EmailConfirmed == true ? "Ja" : "Nej")</strong>
                </div>

                <div class="profile-info-row">
                    <span>Telefonnummer</span>
                    <strong>@(string.IsNullOrWhiteSpace(currentUser?.PhoneNumber) ? "Inte tillagt" : currentUser.PhoneNumber)</strong>
                </div>

                <div class="profile-info-row">
                    <span>Skapad</span>
                    <strong>@currentUser?.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</strong>
                </div>

                <div class="profile-actions">
                    <button type="button" class="secondary-admin-btn" @onclick="GoToOrders">
                        Mina beställningar
                    </button>

                    <button type="button" class="secondary-admin-btn" @onclick="GoBack">
                        Tillbaka
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private ApplicationUser? currentUser;
    private EasySystems.Restaurants.Models.Restaurant? navbarRestaurant;

    private bool isLoading = true;

    private string? successMessage;
    private string? errorMessage;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUser = await UserManager.GetUserAsync(authState.User);

        if (currentUser is null)
        {
            Navigation.NavigateTo("/Account/Login", forceLoad: true);
            return;
        }

        Input = new InputModel
        {
            FirstName = currentUser.FirstName,
            LastName = currentUser.LastName,
            Email = currentUser.Email ?? "",
            PhoneNumber = currentUser.PhoneNumber ?? ""
        };

        navbarRestaurant = await Db.Orders
            .AsNoTracking()
            .Include(x => x.Restaurant)
            .Where(x => x.CustomerUserId == currentUser.Id)
            .OrderByDescending(x => x.CreatedAt)
            .Select(x => x.Restaurant)
            .FirstOrDefaultAsync(x => x != null);

        if (navbarRestaurant is null)
        {
            navbarRestaurant = await Db.Restaurants
                .AsNoTracking()
                .Where(x => x.IsActive)
                .OrderByDescending(x => x.CreatedAt)
                .FirstOrDefaultAsync();
        }

        isLoading = false;
    }

    private async Task SaveProfile()
    {
        successMessage = null;
        errorMessage = null;

        if (currentUser is null)
            return;

        currentUser.FirstName = Input.FirstName.Trim();
        currentUser.LastName = Input.LastName.Trim();
        currentUser.PhoneNumber = Input.PhoneNumber.Trim();

        var result = await UserManager.UpdateAsync(currentUser);

        if (!result.Succeeded)
        {
            errorMessage = string.Join(", ", result.Errors.Select(x => x.Description));
            return;
        }

        successMessage = "Profilen har uppdaterats.";
    }

    private string GetDisplayName()
    {
        if (currentUser is null)
            return "Min profil";

        var fullName = $"{currentUser.FirstName} {currentUser.LastName}".Trim();

        if (!string.IsNullOrWhiteSpace(fullName))
            return fullName;

        return currentUser.Email ?? "Min profil";
    }

    private string GetInitials()
    {
        if (currentUser is null)
            return "U";

        var first = currentUser.FirstName;
        var last = currentUser.LastName;

        if (!string.IsNullOrWhiteSpace(first) && !string.IsNullOrWhiteSpace(last))
            return $"{first[0]}{last[0]}".ToUpper();

        if (!string.IsNullOrWhiteSpace(currentUser.Email))
            return currentUser.Email[0].ToString().ToUpper();

        return "U";
    }

    private void GoToOrders()
    {
        Navigation.NavigateTo("/Account/Orders");
    }

    private void GoBack()
    {
        if (navbarRestaurant is not null && !string.IsNullOrWhiteSpace(navbarRestaurant.Slug))
            Navigation.NavigateTo($"/restaurant/{navbarRestaurant.Slug}");
        else
            Navigation.NavigateTo("/");
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Förnamn krävs.")]
        [StringLength(50, ErrorMessage = "Förnamnet får inte vara längre än 50 tecken.")]
        public string FirstName { get; set; } = "";

        [Required(ErrorMessage = "Efternamn krävs.")]
        [StringLength(50, ErrorMessage = "Efternamnet får inte vara längre än 50 tecken.")]
        public string LastName { get; set; } = "";

        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Telefonnummer krävs.")]
        [Phone(ErrorMessage = "Ange ett giltigt telefonnummer.")]
        public string PhoneNumber { get; set; } = "";
    }
}