@page "/admin/restaurants/{RestaurantId:int}/edit"
@rendermode InteractiveServer

@using EasySystems.Restaurants.Data
@using EasySystems.Restaurants.Models
@using EasySystems.Restaurants.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize]

@inject ApplicationDbContext Db
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment
@inject RestaurantAccessService AccessService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Edit Restaurant</PageTitle>

@if (restaurant is not null && isAuthorized)
{
    <AdminNavbar RestaurantId="RestaurantId" RestaurantSlug="@restaurant.Slug" />
}

@if (!checkedAccess)
{
    <div class="public-loading">Checking access...</div>
}
else if (!isAuthorized)
{
    <div class="public-loading">Redirecting...</div>
}
else
{
    <div class="admin-page">
        <div class="admin-header">
            <div>
                <p class="eyebrow">Edit Restaurant</p>
                <h1>@(restaurant?.Name ?? "Restaurant")</h1>
                <p class="subtitle">Update restaurant details, branding, colors, contact information and settings.</p>
            </div>
        </div>

        @if (restaurant is null)
        {
            <div class="form-card admin-center-card">
                <h2>Restaurant not found</h2>
            </div>
        }
        else
        {
            <EditForm Model="restaurant" OnValidSubmit="SaveRestaurant">
                <DataAnnotationsValidator />

                <div class="admin-grid">
                    <div class="form-card">
                        <h2>Restaurant details</h2>

                        <label>Restaurant name</label>
                        <InputText class="input" @bind-Value="restaurant.Name" />

                        <label>Slug / URL</label>
                        <InputText class="input" @bind-Value="restaurant.Slug" />

                        <label>Description</label>
                        <InputTextArea class="input textarea" @bind-Value="restaurant.Description" />

                        <h2>Contact</h2>

                        <div class="two-cols">
                            <div>
                                <label>Phone</label>
                                <InputText class="input" @bind-Value="restaurant.Phone" />
                            </div>

                            <div>
                                <label>Email</label>
                                <InputText class="input" @bind-Value="restaurant.Email" />
                            </div>
                        </div>

                        <label>Address</label>
                        <InputText class="input" @bind-Value="restaurant.Address" />

                        <h2>Social media</h2>

                        <div class="two-cols">
                            <div>
                                <label>Instagram URL</label>
                                <InputText class="input" @bind-Value="restaurant.InstagramUrl" />
                            </div>

                            <div>
                                <label>Facebook URL</label>
                                <InputText class="input" @bind-Value="restaurant.FacebookUrl" />
                            </div>
                        </div>

                        <div class="two-cols">
                            <div>
                                <label>TikTok URL</label>
                                <InputText class="input" @bind-Value="restaurant.TikTokUrl" />
                            </div>

                            <div>
                                <label>Website URL</label>
                                <InputText class="input" @bind-Value="restaurant.WebsiteUrl" />
                            </div>
                        </div>

                        <h2>Opening hours</h2>

                        <div class="opening-hours-grid">
                            <div>
                                <label>Monday</label>
                                <InputText class="input" @bind-Value="restaurant.MondayHours" />
                            </div>

                            <div>
                                <label>Tuesday</label>
                                <InputText class="input" @bind-Value="restaurant.TuesdayHours" />
                            </div>

                            <div>
                                <label>Wednesday</label>
                                <InputText class="input" @bind-Value="restaurant.WednesdayHours" />
                            </div>

                            <div>
                                <label>Thursday</label>
                                <InputText class="input" @bind-Value="restaurant.ThursdayHours" />
                            </div>

                            <div>
                                <label>Friday</label>
                                <InputText class="input" @bind-Value="restaurant.FridayHours" />
                            </div>

                            <div>
                                <label>Saturday</label>
                                <InputText class="input" @bind-Value="restaurant.SaturdayHours" />
                            </div>

                            <div>
                                <label>Sunday</label>
                                <InputText class="input" @bind-Value="restaurant.SundayHours" />
                            </div>
                        </div>

                        <h2>Settings</h2>

                        <div class="option-row">
                            <label class="checkbox-label">
                                <InputCheckbox @bind-Value="restaurant.IsPickupEnabled" />
                                Pickup enabled
                            </label>

                            <label class="checkbox-label">
                                <InputCheckbox @bind-Value="restaurant.IsDeliveryEnabled" />
                                Delivery enabled
                            </label>

                            <label class="checkbox-label">
                                <InputCheckbox @bind-Value="restaurant.IsActive" />
                                Restaurant active
                            </label>
                        </div>

                        <h2>Brand colors</h2>

                        <div class="color-grid">
                            <div>
                                <label>Primary color</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.PrimaryColor" />
                                <InputText class="input" @bind-Value="restaurant.PrimaryColor" />
                            </div>

                            <div>
                                <label>Secondary color</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.SecondaryColor" />
                                <InputText class="input" @bind-Value="restaurant.SecondaryColor" />
                            </div>
                        </div>

                        <h2>Page colors</h2>

                        <div class="color-grid">
                            <div>
                                <label>Page background</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.PageBackgroundColor" />
                                <InputText class="input" @bind-Value="restaurant.PageBackgroundColor" />
                            </div>

                            <div>
                                <label>Section background</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.SectionBackgroundColor" />
                                <InputText class="input" @bind-Value="restaurant.SectionBackgroundColor" />
                            </div>

                            <div>
                                <label>Card background</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.CardBackgroundColor" />
                                <InputText class="input" @bind-Value="restaurant.CardBackgroundColor" />
                            </div>
                        </div>

                        <h2>Text colors</h2>

                        <div class="color-grid">
                            <div>
                                <label>Heading text</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.HeadingTextColor" />
                                <InputText class="input" @bind-Value="restaurant.HeadingTextColor" />
                            </div>

                            <div>
                                <label>Body text</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.BodyTextColor" />
                                <InputText class="input" @bind-Value="restaurant.BodyTextColor" />
                            </div>

                            <div>
                                <label>Muted text</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.MutedTextColor" />
                                <InputText class="input" @bind-Value="restaurant.MutedTextColor" />
                            </div>
                        </div>

                        <h2>Navigation colors</h2>

                        <div class="color-grid">
                            <div>
                                <label>Navbar background</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.NavbarBackgroundColor" />
                                <InputText class="input" @bind-Value="restaurant.NavbarBackgroundColor" />
                            </div>

                            <div>
                                <label>Navbar text</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.NavbarTextColor" />
                                <InputText class="input" @bind-Value="restaurant.NavbarTextColor" />
                            </div>
                        </div>

                        <h2>Footer colors</h2>

                        <div class="color-grid">
                            <div>
                                <label>Footer background</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.FooterBackgroundColor" />
                                <InputText class="input" @bind-Value="restaurant.FooterBackgroundColor" />
                            </div>

                            <div>
                                <label>Footer text</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.FooterTextColor" />
                                <InputText class="input" @bind-Value="restaurant.FooterTextColor" />
                            </div>
                        </div>

                        <h2>Button colors</h2>

                        <div class="color-grid">
                            <div>
                                <label>Main button background</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.ButtonBackgroundColor" />
                                <InputText class="input" @bind-Value="restaurant.ButtonBackgroundColor" />
                            </div>

                            <div>
                                <label>Main button text</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.ButtonTextColor" />
                                <InputText class="input" @bind-Value="restaurant.ButtonTextColor" />
                            </div>

                            <div>
                                <label>Secondary button background</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.SecondaryButtonBackgroundColor" />
                                <InputText class="input" @bind-Value="restaurant.SecondaryButtonBackgroundColor" />
                            </div>

                            <div>
                                <label>Secondary button text</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.SecondaryButtonTextColor" />
                                <InputText class="input" @bind-Value="restaurant.SecondaryButtonTextColor" />
                            </div>
                        </div>

                        <h2>Hero colors</h2>

                        <div class="color-grid">
                            <div>
                                <label>Hero text color</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.HeroTextColor" />
                                <InputText class="input" @bind-Value="restaurant.HeroTextColor" />
                            </div>

                            <div>
                                <label>Hero overlay</label>
                                <InputText class="input" @bind-Value="restaurant.HeroOverlayColor" placeholder="rgba(0,0,0,.55)" />
                            </div>
                        </div>

                        <h2>Menu colors</h2>

                        <div class="color-grid">
                            <div>
                                <label>Category background</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.MenuCategoryBackgroundColor" />
                                <InputText class="input" @bind-Value="restaurant.MenuCategoryBackgroundColor" />
                            </div>

                            <div>
                                <label>Dish card background</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.MenuItemBackgroundColor" />
                                <InputText class="input" @bind-Value="restaurant.MenuItemBackgroundColor" />
                            </div>

                            <div>
                                <label>Price text</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.PriceTextColor" />
                                <InputText class="input" @bind-Value="restaurant.PriceTextColor" />
                            </div>
                        </div>

                        <h2>Cart colors</h2>

                        <div class="color-grid">
                            <div>
                                <label>Cart bar background</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.CartBarBackgroundColor" />
                                <InputText class="input" @bind-Value="restaurant.CartBarBackgroundColor" />
                            </div>

                            <div>
                                <label>Cart bar text</label>
                                <InputText type="color" class="color-input" @bind-Value="restaurant.CartBarTextColor" />
                                <InputText class="input" @bind-Value="restaurant.CartBarTextColor" />
                            </div>
                        </div>

                        <h2>Bilder</h2>

                        <div class="image-management-grid">
                            <div class="image-management-card">
                                <label>Logotyp</label>

                                @if (!string.IsNullOrWhiteSpace(restaurant.LogoUrl))
                                {
                                    <div class="current-image-preview logo-preview-box">
                                        <img src="@restaurant.LogoUrl" alt="Logotyp" />
                                    </div>

                                    <button class="danger-btn" type="button" @onclick="RemoveLogo">
                                        Ta bort logotyp
                                    </button>
                                }
                                else
                                {
                                    <div class="empty-image-preview">
                                        Ingen logotyp vald
                                    </div>
                                }

                                <InputFile class="file-input" OnChange="UploadLogo" accept="image/png,image/jpeg,image/webp" />
                            </div>

                            <div class="image-management-card">
                                <label>Hero-bild</label>

                                @if (!string.IsNullOrWhiteSpace(restaurant.HeroImageUrl))
                                {
                                    <div class="current-image-preview hero-preview-box">
                                        <img src="@restaurant.HeroImageUrl" alt="Hero-bild" />
                                    </div>

                                    <button class="danger-btn" type="button" @onclick="RemoveHeroImage">
                                        Ta bort hero-bild
                                    </button>
                                }
                                else
                                {
                                    <div class="empty-image-preview">
                                        Ingen hero-bild vald. Färg används istället.
                                    </div>
                                }

                                <InputFile class="file-input" OnChange="UploadHeroImage" accept="image/png,image/jpeg,image/webp" />
                            </div>
                        </div>

                        <button class="save-btn" type="submit">Save changes</button>

                        @if (!string.IsNullOrWhiteSpace(errorMessage))
                        {
                            <div class="error">@errorMessage</div>
                        }

                        @if (!string.IsNullOrWhiteSpace(successMessage))
                        {
                            <div class="upload-success">@successMessage</div>
                        }
                    </div>

                    <div class="preview-card sticky-preview">
                        <p class="preview-label">Live preview</p>

                        <div class="restaurant-preview" style="@GetPreviewVariables()">
                            <div class="mini-navbar-preview" style="@GetMiniNavbarStyle()">
                                <strong>@DisplayOrFallback(restaurant.Name, "Restaurant")</strong>
                                <span>Hem</span>
                                <span>Meny</span>
                            </div>

                            <div class="preview-hero" style="@GetHeroBackgroundStyle()">
                                <div class="preview-logo">
                                    @if (!string.IsNullOrWhiteSpace(restaurant.LogoUrl))
                                    {
                                        <img src="@restaurant.LogoUrl" />
                                    }
                                    else
                                    {
                                        <span>@GetInitials()</span>
                                    }
                                </div>

                                <h2>@DisplayOrFallback(restaurant.Name, "Restaurant name")</h2>
                                <p>@DisplayOrFallback(restaurant.Description, "Restaurant description")</p>

                                <button type="button" style="@GetPrimaryButtonStyle()">Se meny</button>
                            </div>

                            <div class="preview-info" style="@GetPreviewInfoStyle()">
                                <span>@DisplayOrFallback(restaurant.Phone, "Phone")</span>
                                <span>@DisplayOrFallback(restaurant.Email, "Email")</span>
                                <span>@DisplayOrFallback(restaurant.Address, "Address")</span>
                            </div>

                            <div class="preview-mini-section" style="@GetPreviewCardStyle()">
                                <strong style="color:@restaurant.HeadingTextColor;">Dish card preview</strong>
                                <p style="color:@restaurant.BodyTextColor;">This shows menu card colors.</p>
                                <span style="color:@restaurant.PriceTextColor;">129.00 kr</span>
                            </div>

                            <div class="mini-footer-preview" style="@GetMiniFooterStyle()">
                                <strong>Footer preview</strong>
                                <span>Privacy • Terms • Contact</span>
                            </div>
                        </div>

                        <div class="restaurant-admin-actions" style="margin-top:18px;">
                            <button type="button" @onclick="ViewRestaurant">View restaurant</button>
                            <button type="button" @onclick="BackToList">Back to list</button>
                        </div>
                    </div>
                </div>
            </EditForm>
        }
    </div>
}

@code {
    [Parameter]
    public int RestaurantId { get; set; }

    private Restaurant? restaurant;
    private string? errorMessage;
    private string? successMessage;

    private bool checkedAccess;
    private bool isAuthorized;

    private const long MaxFileSize = 5 * 1024 * 1024;

    protected override async Task OnParametersSetAsync()
    {
        checkedAccess = false;
        isAuthorized = false;
        errorMessage = null;
        successMessage = null;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        isAuthorized = await AccessService.CanManageRestaurantSettingsAsync(
            authState.User,
            RestaurantId);

        checkedAccess = true;

        if (!isAuthorized)
        {
            Navigation.NavigateTo("/Account/Denied", true);
            return;
        }

        restaurant = await Db.Restaurants
            .FirstOrDefaultAsync(x => x.Id == RestaurantId);
    }

    private async Task SaveRestaurant()
    {
        if (!isAuthorized || restaurant is null)
            return;

        errorMessage = null;
        successMessage = null;

        restaurant.Name = restaurant.Name.Trim();
        restaurant.Slug = NormalizeSlug(restaurant.Slug);

        ApplyDefaultDesignColors();

        if (string.IsNullOrWhiteSpace(restaurant.Name))
        {
            errorMessage = "Restaurant name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(restaurant.Slug))
        {
            errorMessage = "Slug is required.";
            return;
        }

        bool slugExists = await Db.Restaurants
            .AnyAsync(x => x.Slug == restaurant.Slug && x.Id != restaurant.Id);

        if (slugExists)
        {
            errorMessage = "This slug is already used by another restaurant.";
            return;
        }

        await Db.SaveChangesAsync();
        successMessage = "Restaurant updated successfully.";
    }

    private void ApplyDefaultDesignColors()
    {
        if (restaurant is null)
            return;

        restaurant.PrimaryColor = DefaultColor(restaurant.PrimaryColor, "#8B0000");
        restaurant.SecondaryColor = DefaultColor(restaurant.SecondaryColor, "#FFFFFF");

        restaurant.NavbarBackgroundColor = DefaultColor(restaurant.NavbarBackgroundColor, "#FFFFFF");
        restaurant.NavbarTextColor = DefaultColor(restaurant.NavbarTextColor, "#111827");

        restaurant.FooterBackgroundColor = DefaultColor(restaurant.FooterBackgroundColor, "#111827");
        restaurant.FooterTextColor = DefaultColor(restaurant.FooterTextColor, "#FFFFFF");

        restaurant.PageBackgroundColor = DefaultColor(restaurant.PageBackgroundColor, "#FFF7ED");
        restaurant.SectionBackgroundColor = DefaultColor(restaurant.SectionBackgroundColor, "#FFFFFF");
        restaurant.CardBackgroundColor = DefaultColor(restaurant.CardBackgroundColor, "#FFFFFF");

        restaurant.HeadingTextColor = DefaultColor(restaurant.HeadingTextColor, "#111827");
        restaurant.BodyTextColor = DefaultColor(restaurant.BodyTextColor, "#4B5563");
        restaurant.MutedTextColor = DefaultColor(restaurant.MutedTextColor, "#6B7280");

        restaurant.ButtonBackgroundColor = DefaultColor(restaurant.ButtonBackgroundColor, restaurant.PrimaryColor);
        restaurant.ButtonTextColor = DefaultColor(restaurant.ButtonTextColor, "#FFFFFF");
        restaurant.SecondaryButtonBackgroundColor = DefaultColor(restaurant.SecondaryButtonBackgroundColor, "#FFFFFF");
        restaurant.SecondaryButtonTextColor = DefaultColor(restaurant.SecondaryButtonTextColor, restaurant.PrimaryColor);

        restaurant.HeroTextColor = DefaultColor(restaurant.HeroTextColor, "#FFFFFF");
        restaurant.HeroOverlayColor = DefaultColor(restaurant.HeroOverlayColor, "rgba(0,0,0,.55)");

        restaurant.MenuCategoryBackgroundColor = DefaultColor(restaurant.MenuCategoryBackgroundColor, "#FFFFFF");
        restaurant.MenuItemBackgroundColor = DefaultColor(restaurant.MenuItemBackgroundColor, "#FFFFFF");
        restaurant.PriceTextColor = DefaultColor(restaurant.PriceTextColor, restaurant.PrimaryColor);

        restaurant.CartBarBackgroundColor = DefaultColor(restaurant.CartBarBackgroundColor, "#111827");
        restaurant.CartBarTextColor = DefaultColor(restaurant.CartBarTextColor, "#FFFFFF");
    }

    private string DefaultColor(string? value, string fallback)
        => string.IsNullOrWhiteSpace(value) ? fallback : value;

    private async Task UploadLogo(InputFileChangeEventArgs e)
    {
        if (!isAuthorized || restaurant is null)
            return;

        restaurant.LogoUrl = await SaveImageAsync(e.File, "logos");
    }

    private async Task UploadHeroImage(InputFileChangeEventArgs e)
    {
        if (!isAuthorized || restaurant is null)
            return;

        restaurant.HeroImageUrl = await SaveImageAsync(e.File, "heroes");
    }

    private async Task<string> SaveImageAsync(IBrowserFile file, string folderName)
    {
        if (!isAuthorized)
            return string.Empty;

        errorMessage = null;

        var allowedExtensions = new[] { ".jpg", ".jpeg", ".png", ".webp" };
        var extension = Path.GetExtension(file.Name).ToLowerInvariant();

        if (!allowedExtensions.Contains(extension))
        {
            errorMessage = "Only JPG, PNG and WEBP images are allowed.";
            return string.Empty;
        }

        if (file.Size > MaxFileSize)
        {
            errorMessage = "Image size must be less than 5 MB.";
            return string.Empty;
        }

        var uploadFolder = Path.Combine(Environment.WebRootPath, "uploads", folderName);

        if (!Directory.Exists(uploadFolder))
        {
            Directory.CreateDirectory(uploadFolder);
        }

        var fileName = $"{Guid.NewGuid()}{extension}";
        var fullPath = Path.Combine(uploadFolder, fileName);
        var relativePath = $"/uploads/{folderName}/{fileName}";

        await using var readStream = file.OpenReadStream(MaxFileSize);
        await using var writeStream = File.Create(fullPath);

        await readStream.CopyToAsync(writeStream);

        successMessage = "Image uploaded. Remember to save changes.";
        return relativePath;
    }

    private void ViewRestaurant()
    {
        if (restaurant is not null)
            Navigation.NavigateTo($"/restaurant/{restaurant.Slug}");
    }

    private void BackToList()
    {
        Navigation.NavigateTo("/admin/restaurants");
    }

    private string DisplayOrFallback(string? value, string fallback)
        => string.IsNullOrWhiteSpace(value) ? fallback : value;

    private string GetInitials()
    {
        if (restaurant is null || string.IsNullOrWhiteSpace(restaurant.Name))
            return "ES";

        var words = restaurant.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Join("", words.Take(2).Select(x => x[0])).ToUpper();
    }

    private string GetHeroBackgroundStyle()
    {
        if (restaurant is null)
            return string.Empty;

        if (string.IsNullOrWhiteSpace(restaurant.HeroImageUrl))
            return $"background: linear-gradient(135deg, {restaurant.PrimaryColor}, #111827); color:{restaurant.HeroTextColor};";

        return $"background: linear-gradient({restaurant.HeroOverlayColor}, {restaurant.HeroOverlayColor}), url('{restaurant.HeroImageUrl}') center/cover; color:{restaurant.HeroTextColor};";
    }

    private string GetPreviewVariables()
    {
        if (restaurant is null)
            return string.Empty;

        return $"--primary:{restaurant.PrimaryColor}; --secondary:{restaurant.SecondaryColor}; background:{restaurant.PageBackgroundColor}; color:{restaurant.BodyTextColor};";
    }

    private string GetMiniNavbarStyle()
    {
        if (restaurant is null)
            return string.Empty;

        return $"background:{restaurant.NavbarBackgroundColor}; color:{restaurant.NavbarTextColor};";
    }

    private string GetMiniFooterStyle()
    {
        if (restaurant is null)
            return string.Empty;

        return $"background:{restaurant.FooterBackgroundColor}; color:{restaurant.FooterTextColor};";
    }

    private string GetPrimaryButtonStyle()
    {
        if (restaurant is null)
            return string.Empty;

        return $"background:{restaurant.ButtonBackgroundColor}; color:{restaurant.ButtonTextColor};";
    }

    private string GetPreviewInfoStyle()
    {
        if (restaurant is null)
            return string.Empty;

        return $"background:{restaurant.SectionBackgroundColor}; color:{restaurant.BodyTextColor};";
    }

    private string GetPreviewCardStyle()
    {
        if (restaurant is null)
            return string.Empty;

        return $"background:{restaurant.MenuItemBackgroundColor}; color:{restaurant.BodyTextColor}; border-radius:18px; padding:18px; margin-top:16px;";
    }

    private string NormalizeSlug(string value)
    {
        return value
            .Trim()
            .ToLower()
            .Replace(" ", "-")
            .Replace("å", "a")
            .Replace("ä", "a")
            .Replace("ö", "o");
    }

    private void RemoveLogo()
    {
        if (!isAuthorized || restaurant is null)
            return;

        restaurant.LogoUrl = null;
        successMessage = "Logotypen har tagits bort. Kom ihåg att spara ändringarna.";
        errorMessage = null;
    }

    private void RemoveHeroImage()
    {
        if (!isAuthorized || restaurant is null)
            return;

        restaurant.HeroImageUrl = null;
        successMessage = "Hero-bilden har tagits bort. Kom ihåg att spara ändringarna.";
        errorMessage = null;
    }
}