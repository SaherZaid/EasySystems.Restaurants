    private string NormalizeGroupType(string? groupType)
    {
        if (string.IsNullOrWhiteSpace(groupType))
            return SingleChoiceType;

        return groupType;
    }

    private string GetCustomerGroupHelpText(MenuItemOptionGroup group)
    {
        var groupType = NormalizeGroupType(group.GroupType);

        return groupType switch
        {
            IncludedIngredientsType => "Ingår i rätten • avmarkera det du inte vill ha",
            SingleChoiceType => $"{(group.IsRequired ? "Obligatoriskt val" : "Frivilligt")} • välj ett alternativ",
            MultipleChoiceType => $"{(group.IsRequired ? "Obligatoriskt val" : "Frivilligt")} • du kan välja flera",
            _ => "Välj ett alternativ"
        };
    }

