@using EasySystems.Restaurants.Data
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims

@inject AuthenticationStateProvider AuthStateProvider
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<nav class="admin-navbar">
    <div class="admin-navbar-inner">

        <a class="admin-brand" href="/admin/restaurants">
            <span>RA</span>
            <strong>Restaurangadmin</strong>
        </a>

        <button type="button" class="admin-menu-toggle" @onclick="ToggleMenu">
            ☰
        </button>

        <div class="admin-nav-links @(isOpen ? "open" : "")">

            

            @if (isPlatformSuperAdmin)
            {
                <NavLink href="/admin/restaurants/create" @onclick="CloseMenu">
                    Skapa
                </NavLink>
            }

            @if (!string.IsNullOrWhiteSpace(RestaurantSlug))
            {
                <a class="admin-home-link" href="@($"/restaurant/{RestaurantSlug}")" @onclick="CloseMenu">
                    Startsida
                </a>
            }

            @if (RestaurantId is not null && canAccessRestaurant)
            {
                @if (CanManageUsers)
                {
                    <NavLink href="@($"/admin/restaurants/{RestaurantId}/owner")" @onclick="CloseMenu">
                        Hantera användarroller
                    </NavLink>
                }

                @if (CanManageSettings)
                {
                    <NavLink href="@($"/admin/restaurants/{RestaurantId}/edit")" @onclick="CloseMenu">
                        Hantera & designa restaurangen
                    </NavLink>
                }

                @if (CanManageMenu)
                {
                    <NavLink href="@($"/admin/restaurants/{RestaurantId}/categories")" @onclick="CloseMenu">
                        Menykategorier
                    </NavLink>

                    <NavLink href="@($"/admin/restaurants/{RestaurantId}/items")" @onclick="CloseMenu">
                        Menyrätter
                    </NavLink>
                }

                @if (CanManageOrders)
                {
                    <NavLink href="@($"/admin/restaurants/{RestaurantId}/orders")" @onclick="CloseMenu">
                        Kundbeställningar
                    </NavLink>
                }

                @if (CanManageLegal)
                {
                    <NavLink href="@($"/admin/restaurants/{RestaurantId}/legal")" @onclick="CloseMenu">
                        Villkor & integritet
                    </NavLink>
                }
            }

        </div>
    </div>
</nav>

@code {
    [Parameter]
    public int? RestaurantId { get; set; }

    [Parameter]
    public string? RestaurantSlug { get; set; }

    private bool isOpen;
    private bool isPlatformSuperAdmin;
    private bool canAccessRestaurant;
    private string? restaurantRole;

    private bool CanManageUsers => isPlatformSuperAdmin || restaurantRole == "RestaurantOwner";
    private bool CanManageSettings => isPlatformSuperAdmin || restaurantRole == "RestaurantOwner";
    private bool CanManageLegal => isPlatformSuperAdmin || restaurantRole == "RestaurantOwner";
    private bool CanManageMenu => isPlatformSuperAdmin || restaurantRole == "RestaurantOwner" || restaurantRole == "RestaurantAdmin";
    private bool CanManageOrders => isPlatformSuperAdmin || restaurantRole == "RestaurantOwner" || restaurantRole == "RestaurantAdmin";

    protected override async Task OnParametersSetAsync()
    {
        isPlatformSuperAdmin = false;
        canAccessRestaurant = false;
        restaurantRole = null;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;

        if (principal.Identity?.IsAuthenticated != true)
            return;

        var userId = principal.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
            return;

        isPlatformSuperAdmin = principal.IsInRole("PlatformSuperAdmin");

        if (isPlatformSuperAdmin)
        {
            canAccessRestaurant = true;
            return;
        }

        if (RestaurantId is null)
            return;

        await using var db = await DbFactory.CreateDbContextAsync();

        var access = await db.RestaurantUserAccesses
            .AsNoTracking()
            .FirstOrDefaultAsync(x =>
                x.RestaurantId == RestaurantId.Value &&
                x.UserId == userId);

        if (access is not null)
        {
            canAccessRestaurant = true;
            restaurantRole = access.Role;
        }
    }

    private void ToggleMenu()
    {
        isOpen = !isOpen;
    }

    private void CloseMenu()
    {
        isOpen = false;
    }
}