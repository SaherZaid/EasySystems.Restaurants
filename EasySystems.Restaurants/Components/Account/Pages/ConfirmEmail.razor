@page "/Account/ConfirmEmail"

@using System.Text
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using EasySystems.Restaurants.Data

@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Bekräfta e-post</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <span>ES</span>
            <div>
                <strong>EasySystems</strong>
                <p>E-postbekräftelse</p>
            </div>
        </div>

        <StatusMessage Message="@statusMessage" />

        <div class="auth-header">
            <p class="eyebrow">@statusLabel</p>
            <h1>@headline</h1>
            <p>@description</p>
        </div>

        <div class="auth-links">
            <a href="/Account/Login">Gå till inloggning</a>
            <a href="/Account/ResendEmailConfirmation">Skicka verifieringsmail igen</a>
        </div>
    </div>

    <div class="auth-side">
        <div class="auth-side-content">
            <span class="auth-badge">Konto verifierat</span>
            <h2>Ditt konto är nästan klart.</h2>
            <p>
                Efter att du har bekräftat din e-post kan du logga in och fortsätta använda EasySystems.
            </p>
        </div>
    </div>
</div>

@code {
    private string? statusMessage;
    private string statusLabel = "Kontrollerar";
    private string headline = "Bekräftar din e-post";
    private string description = "Vänta medan vi verifierar ditt konto.";

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? UserId { get; set; }

    [SupplyParameterFromQuery]
    private string? Code { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (UserId is null || Code is null)
        {
            RedirectManager.RedirectTo("");
            return;
        }

        var user = await UserManager.FindByIdAsync(UserId);

        if (user is null)
        {
            HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
            statusLabel = "Fel";
            headline = "Användaren hittades inte";
            description = "Vi kunde inte hitta kontot som är kopplat till denna bekräftelselänk.";
            statusMessage = $"Fel vid hämtning av användare med ID {UserId}";
            return;
        }

        var code = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Code));
        var result = await UserManager.ConfirmEmailAsync(user, code);

        if (result.Succeeded)
        {
            statusLabel = "Klart";
            headline = "E-post bekräftad";
            description = "Tack. Din e-post har bekräftats och du kan nu logga in.";
            statusMessage = "Tack för att du bekräftade din e-post.";
        }
        else
        {
            statusLabel = "Fel";
            headline = "Bekräftelsen misslyckades";
            description = "Bekräftelselänken kan vara ogiltig eller ha gått ut. Du kan begära ett nytt verifieringsmail.";
            statusMessage = "Det gick inte att bekräfta din e-post.";
        }
    }
}