@page "/Account/ResetPasswordConfirmation"

<PageTitle>Password reset complete</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <span>ES</span>
            <div>
                <strong>EasySystems</strong>
                <p>Password updated</p>
            </div>
        </div>

        <div class="auth-header">
            <p class="eyebrow">Success</p>
            <h1>Password reset complete</h1>
            <p>Your password has been updated. You can now sign in with your new password.</p>
        </div>

        <a class="auth-submit auth-link-button" href="/Account/Login">
            Go to login
        </a>
    </div>

    <div class="auth-side">
        <div class="auth-side-content">
            <span class="auth-badge">You are ready</span>
            <h2>Your account is secure again.</h2>
            <p>
                Sign in and continue managing your orders, restaurant dashboard or customer account.
            </p>
        </div>
    </div>
</div>