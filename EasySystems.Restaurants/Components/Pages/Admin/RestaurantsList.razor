@page "/admin/restaurants"
@rendermode InteractiveServer

@using EasySystems.Restaurants.Data
@using EasySystems.Restaurants.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims

@attribute [Authorize]

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Restauranger</PageTitle>

@if (restaurants.Count > 0)
{
    var firstRestaurant = restaurants.First();

    <AdminNavbar RestaurantId="firstRestaurant.Id" RestaurantSlug="@firstRestaurant.Slug" />
}
else
{
    <AdminNavbar />
}

@if (!checkedAccess)
{
    <div class="public-loading">Laddar...</div>
}
else if (!hasAdminAccess)
{
    <div class="public-loading">Omdirigerar...</div>
}
else
{
    <div class="admin-page">
        <div class="admin-header admin-header-row">
            <div>
                <p class="eyebrow">Restaurangadmin</p>
                <h1>@(isPlatformSuperAdmin ? "Restauranger" : "Min restaurang")</h1>
                <p class="subtitle">
                    @(isPlatformSuperAdmin
                        ? "Hantera alla restaurangsidor från ett ställe."
                        : "Hantera restaurangens sida, meny, beställningar och inställningar.")
                </p>
            </div>

            @if (isPlatformSuperAdmin)
            {
                <button class="admin-primary-btn" type="button" @onclick="CreateRestaurant">
                    Skapa restaurang
                </button>
            }
        </div>

        <div class="restaurants-list-card">
            @if (restaurants.Count == 0)
            {
                <div class="empty-menu">
                    <h3>Ingen restaurangåtkomst ännu</h3>
                    <p>Du har inte åtkomst till någon restaurang ännu.</p>
                </div>
            }
            else
            {
                <div class="restaurants-grid">
                    @foreach (var restaurant in restaurants)
                    {
                        <div class="restaurant-admin-card">
                            <div class="restaurant-admin-cover" style="@GetCoverStyle(restaurant)">
                                <div class="restaurant-admin-logo">
                                    @if (!string.IsNullOrWhiteSpace(restaurant.LogoUrl))
                                    {
                                        <img src="@restaurant.LogoUrl" alt="@restaurant.Name logotyp" />
                                    }
                                    else
                                    {
                                        <span>@GetInitials(restaurant.Name)</span>
                                    }
                                </div>
                            </div>

                            <div class="restaurant-admin-body">
                                <div class="restaurant-admin-title">
                                    <div>
                                        <h2>@restaurant.Name</h2>
                                        <p>/restaurant/@restaurant.Slug</p>
                                    </div>

                                    <span class="restaurant-state @(restaurant.IsActive ? "active" : "inactive")">
                                        @(restaurant.IsActive ? "Aktiv" : "Inaktiv")
                                    </span>
                                </div>

                                <div class="restaurant-admin-info">
                                    @if (!string.IsNullOrWhiteSpace(restaurant.Phone))
                                    {
                                        <span>@restaurant.Phone</span>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(restaurant.Address))
                                    {
                                        <span>@restaurant.Address</span>
                                    }
                                </div>

                                <div class="restaurant-admin-actions">
                                    

                                    <button type="button" @onclick="() => ViewRestaurant(restaurant.Slug)">
                                        Visa restaurangsida
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private List<Restaurant> restaurants = [];
    private List<RestaurantUserAccess> myAccesses = [];

    private string? currentUserId;
    private bool isPlatformSuperAdmin;
    private bool hasAdminAccess;
    private bool checkedAccess;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;

        if (principal.Identity?.IsAuthenticated != true)
        {
            checkedAccess = true;
            Navigation.NavigateTo("/Account/AccessDenied", true);
            return;
        }

        var userId = principal.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            checkedAccess = true;
            Navigation.NavigateTo("/Account/AccessDenied", true);
            return;
        }

        currentUserId = userId;
        isPlatformSuperAdmin = principal.IsInRole("PlatformSuperAdmin");

        await using var db = await DbFactory.CreateDbContextAsync();

        if (isPlatformSuperAdmin)
        {
            restaurants = await db.Restaurants
                .AsNoTracking()
                .OrderByDescending(x => x.CreatedAt)
                .ToListAsync();

            hasAdminAccess = true;
        }
        else
        {
            myAccesses = await db.RestaurantUserAccesses
                .AsNoTracking()
                .Where(x =>
                    x.UserId == userId &&
                    (x.Role == "RestaurantOwner" || x.Role == "RestaurantAdmin"))
                .ToListAsync();

            var restaurantIds = myAccesses
                .Select(x => x.RestaurantId)
                .Distinct()
                .ToList();

            restaurants = await db.Restaurants
                .AsNoTracking()
                .Where(x => restaurantIds.Contains(x.Id))
                .OrderBy(x => x.Name)
                .ToListAsync();

            hasAdminAccess = restaurants.Count > 0;
        }

        checkedAccess = true;

        if (!hasAdminAccess)
        {
            Navigation.NavigateTo("/Account/Denied", true);
        }
    }

    private void CreateRestaurant()
    {
        if (!isPlatformSuperAdmin)
            return;

        Navigation.NavigateTo("/admin/restaurants/create");
    }

    private void ManageRestaurant(int restaurantId)
    {
        if (!hasAdminAccess)
            return;

        if (isPlatformSuperAdmin || IsRestaurantOwner(restaurantId))
        {
            Navigation.NavigateTo($"/admin/restaurants/{restaurantId}/edit");
            return;
        }

        Navigation.NavigateTo($"/admin/restaurants/{restaurantId}/orders");
    }

    private bool IsRestaurantOwner(int restaurantId)
    {
        if (isPlatformSuperAdmin)
            return true;

        return myAccesses.Any(x =>
            x.RestaurantId == restaurantId &&
            x.Role == "RestaurantOwner");
    }

    private void ViewRestaurant(string slug)
    {
        Navigation.NavigateTo($"/restaurant/{slug}");
    }

    private string GetCoverStyle(Restaurant restaurant)
    {
        if (!string.IsNullOrWhiteSpace(restaurant.HeroImageUrl))
        {
            return $"background: linear-gradient(rgba(0,0,0,.35), rgba(0,0,0,.35)), url('{restaurant.HeroImageUrl}') center/cover;";
        }

        return $"background: linear-gradient(135deg, {restaurant.PrimaryColor}, #111827);";
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "ES";

        var words = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Join("", words.Take(2).Select(x => x[0])).ToUpper();
    }
}