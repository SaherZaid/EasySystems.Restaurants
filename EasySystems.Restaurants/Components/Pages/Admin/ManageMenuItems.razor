@page "/admin/restaurants/{RestaurantId:int}/items"
@rendermode InteractiveServer

@using EasySystems.Restaurants.Data
@using EasySystems.Restaurants.Models
@using EasySystems.Restaurants.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize]

@inject ApplicationDbContext Db
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment
@inject RestaurantAccessService AccessService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Manage Menu Items</PageTitle>

@if (restaurant is not null && isAuthorized)
{
    <AdminNavbar RestaurantId="RestaurantId" RestaurantSlug="@restaurant.Slug" />
}

@if (!checkedAccess)
{
    <div class="public-loading">Checking access...</div>
}
else if (!isAuthorized)
{
    <div class="public-not-found">
        <h1>Access denied</h1>
        <p>You do not have permission to manage dishes for this restaurant.</p>
    </div>
}
else
{
    <div class="admin-page">
        <div class="admin-header">
            <div>
                <p class="eyebrow">Menu Items</p>
                <h1>Manage dishes</h1>
                <p class="subtitle">Add dishes, edit them, manage options and control availability.</p>
            </div>
        </div>

        @if (restaurant is null)
        {
            <div class="form-card admin-center-card">
                <h2>Restaurant not found</h2>
                <p>This restaurant does not exist.</p>
            </div>
        }
        else if (categories.Count == 0)
        {
            <div class="form-card admin-center-card">
                <h2>No categories yet</h2>
                <p>You need to create menu categories before adding dishes.</p>
                <button class="save-btn" type="button" @onclick="GoToCategories">Create categories</button>
            </div>
        }
        else
        {
            <div class="admin-grid">
                <div class="form-card">
                    <h2>Add new dish</h2>

                    <label>Category</label>
                    <InputSelect class="input" @bind-Value="newItem.MenuCategoryId">
                        @foreach (var category in categories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </InputSelect>

                    <label>Dish name</label>
                    <InputText class="input" @bind-Value="newItem.Name" placeholder="Kyckling Kebab Tallrik" />

                    <label>Description</label>
                    <InputTextArea class="input textarea" @bind-Value="newItem.Description" placeholder="Serveras med ris, sallad och valfri sås..." />

                    <div class="two-cols">
                        <div>
                            <label>Price</label>
                            <InputNumber class="input" @bind-Value="newItem.Price" />
                        </div>

                        <div>
                            <label>Sort order</label>
                            <InputNumber class="input" @bind-Value="newItem.SortOrder" />
                        </div>
                    </div>

                    <label>Dish image</label>
                    <InputFile class="file-input" OnChange="UploadNewItemImage" accept="image/png,image/jpeg,image/webp" />

                    @if (!string.IsNullOrWhiteSpace(newItem.ImageUrl))
                    {
                        <p class="upload-success">Dish image uploaded successfully</p>
                    }

                    <button class="save-btn" type="button" @onclick="AddItem">Add dish</button>

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="error">@errorMessage</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(successMessage))
                    {
                        <div class="upload-success">@successMessage</div>
                    }
                </div>

                <div class="preview-card">
                    <p class="preview-label">@restaurant.Name dishes</p>

                    @if (items.Count == 0)
                    {
                        <div class="empty-menu">
                            <h3>No dishes yet</h3>
                            <p>Add your first dish to the menu.</p>
                        </div>
                    }
                    else
                    {
                        <div class="item-admin-list">
                            @foreach (var item in items)
                            {
                                <div class="item-admin-card">
                                    @if (editingItemId == item.Id)
                                    {
                                        <div class="edit-item-form">
                                            <label>Category</label>
                                            <InputSelect class="input" @bind-Value="editItem.MenuCategoryId">
                                                @foreach (var category in categories)
                                                {
                                                    <option value="@category.Id">@category.Name</option>
                                                }
                                            </InputSelect>

                                            <label>Dish name</label>
                                            <InputText class="input" @bind-Value="editItem.Name" />

                                            <label>Description</label>
                                            <InputTextArea class="input textarea" @bind-Value="editItem.Description" />

                                            <div class="two-cols">
                                                <div>
                                                    <label>Price</label>
                                                    <InputNumber class="input" @bind-Value="editItem.Price" />
                                                </div>

                                                <div>
                                                    <label>Sort order</label>
                                                    <InputNumber class="input" @bind-Value="editItem.SortOrder" />
                                                </div>
                                            </div>

                                            <label class="checkbox-label">
                                                <InputCheckbox @bind-Value="editItem.IsAvailable" />
                                                Available
                                            </label>

                                            <label>Replace image</label>
                                            <InputFile class="file-input" OnChange="UploadEditItemImage" accept="image/png,image/jpeg,image/webp" />

                                            <div class="category-actions">
                                                <button type="button" @onclick="SaveEditItem">Save</button>
                                                <button type="button" @onclick="CancelEditItem">Cancel</button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.Name" />
                                        }

                                        <div>
                                            <strong>@item.Name</strong>

                                            @if (!string.IsNullOrWhiteSpace(item.Description))
                                            {
                                                <p>@item.Description</p>
                                            }

                                            <span>@item.Price.ToString("0.00") kr</span>
                                            <small>@item.MenuCategory?.Name</small>
                                        </div>

                                        <div class="category-actions">
                                            <button type="button" @onclick="() => StartEditItem(item)">
                                                Edit
                                            </button>

                                            <button type="button" @onclick="() => ManageOptions(item.Id)">
                                                Options
                                            </button>

                                            <button type="button" @onclick="() => ToggleAvailability(item)">
                                                @(item.IsAvailable ? "Mark unavailable" : "Mark available")
                                            </button>

                                            <button class="danger-btn" type="button" @onclick="() => DeleteItem(item)">
                                                Delete
                                            </button>
                                        </div>

                                        @if (!item.IsAvailable)
                                        {
                                            <small class="hidden-badge">Unavailable</small>
                                        }
                                    }
                                </div>
                            }
                        </div>
                    }

                    <button class="secondary-admin-btn" type="button" @onclick="GoToRestaurant">
                        View restaurant page
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public int RestaurantId { get; set; }

    private Restaurant? restaurant;
    private List<MenuCategory> categories = [];
    private List<MenuItem> items = [];

    private string? errorMessage;
    private string? successMessage;

    private int? editingItemId;

    private bool checkedAccess;
    private bool isAuthorized;

    private MenuItem newItem = new()
    {
        IsAvailable = true
    };

    private MenuItem editItem = new();

    private const long MaxFileSize = 5 * 1024 * 1024;

    protected override async Task OnParametersSetAsync()
    {
        checkedAccess = false;
        isAuthorized = false;

        restaurant = await Db.Restaurants
            .FirstOrDefaultAsync(x => x.Id == RestaurantId);

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        isAuthorized = await AccessService.CanAccessRestaurantAsync(
            authState.User,
            RestaurantId);

        checkedAccess = true;

        if (!isAuthorized || restaurant is null)
            return;

        categories = await Db.MenuCategories
            .Where(x => x.RestaurantId == RestaurantId)
            .OrderBy(x => x.SortOrder)
            .ToListAsync();

        await LoadItems();
        ResetNewItem();
    }

    private async Task LoadItems()
    {
        items = await Db.MenuItems
            .Include(x => x.MenuCategory)
            .Where(x => x.MenuCategory != null && x.MenuCategory.RestaurantId == RestaurantId)
            .OrderBy(x => x.MenuCategory!.SortOrder)
            .ThenBy(x => x.SortOrder)
            .ToListAsync();
    }

    private void ResetNewItem()
    {
        newItem = new MenuItem
        {
            MenuCategoryId = categories.FirstOrDefault()?.Id ?? 0,
            IsAvailable = true,
            SortOrder = items.Count + 1
        };
    }

    private async Task AddItem()
    {
        errorMessage = null;
        successMessage = null;

        newItem.Name = newItem.Name.Trim();

        if (newItem.MenuCategoryId <= 0)
        {
            errorMessage = "Category is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newItem.Name))
        {
            errorMessage = "Dish name is required.";
            return;
        }

        if (newItem.Price <= 0)
        {
            errorMessage = "Price must be greater than 0.";
            return;
        }

        newItem.IsAvailable = true;

        Db.MenuItems.Add(newItem);
        await Db.SaveChangesAsync();

        await LoadItems();
        ResetNewItem();

        successMessage = "Dish added successfully.";
    }

    private void StartEditItem(MenuItem item)
    {
        errorMessage = null;
        successMessage = null;

        editingItemId = item.Id;

        editItem = new MenuItem
        {
            Id = item.Id,
            MenuCategoryId = item.MenuCategoryId,
            Name = item.Name,
            Description = item.Description,
            Price = item.Price,
            ImageUrl = item.ImageUrl,
            IsAvailable = item.IsAvailable,
            SortOrder = item.SortOrder
        };
    }

    private void CancelEditItem()
    {
        editingItemId = null;
        editItem = new MenuItem();
        errorMessage = null;
    }

    private async Task SaveEditItem()
    {
        errorMessage = null;
        successMessage = null;

        if (editingItemId is null)
            return;

        editItem.Name = editItem.Name.Trim();

        if (editItem.MenuCategoryId <= 0)
        {
            errorMessage = "Category is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(editItem.Name))
        {
            errorMessage = "Dish name is required.";
            return;
        }

        if (editItem.Price <= 0)
        {
            errorMessage = "Price must be greater than 0.";
            return;
        }

        var item = await Db.MenuItems
            .Include(x => x.MenuCategory)
            .FirstOrDefaultAsync(x =>
                x.Id == editingItemId.Value &&
                x.MenuCategory != null &&
                x.MenuCategory.RestaurantId == RestaurantId);

        if (item is null)
        {
            errorMessage = "Dish not found.";
            return;
        }

        item.MenuCategoryId = editItem.MenuCategoryId;
        item.Name = editItem.Name;
        item.Description = editItem.Description;
        item.Price = editItem.Price;
        item.ImageUrl = editItem.ImageUrl;
        item.IsAvailable = editItem.IsAvailable;
        item.SortOrder = editItem.SortOrder;

        await Db.SaveChangesAsync();
        await LoadItems();

        editingItemId = null;
        successMessage = "Dish updated successfully.";
    }

    private async Task UploadNewItemImage(InputFileChangeEventArgs e)
    {
        newItem.ImageUrl = await SaveImageAsync(e.File, "products");
    }

    private async Task UploadEditItemImage(InputFileChangeEventArgs e)
    {
        editItem.ImageUrl = await SaveImageAsync(e.File, "products");
    }

    private async Task<string> SaveImageAsync(IBrowserFile file, string folderName)
    {
        errorMessage = null;

        var allowedExtensions = new[] { ".jpg", ".jpeg", ".png", ".webp" };
        var extension = Path.GetExtension(file.Name).ToLowerInvariant();

        if (!allowedExtensions.Contains(extension))
        {
            errorMessage = "Only JPG, PNG and WEBP images are allowed.";
            return string.Empty;
        }

        if (file.Size > MaxFileSize)
        {
            errorMessage = "Image size must be less than 5 MB.";
            return string.Empty;
        }

        var uploadFolder = Path.Combine(Environment.WebRootPath, "uploads", folderName);

        if (!Directory.Exists(uploadFolder))
        {
            Directory.CreateDirectory(uploadFolder);
        }

        var fileName = $"{Guid.NewGuid()}{extension}";
        var fullPath = Path.Combine(uploadFolder, fileName);
        var relativePath = $"/uploads/{folderName}/{fileName}";

        await using var readStream = file.OpenReadStream(MaxFileSize);
        await using var writeStream = File.Create(fullPath);

        await readStream.CopyToAsync(writeStream);

        successMessage = "Image uploaded.";
        return relativePath;
    }

    private async Task ToggleAvailability(MenuItem item)
    {
        item.IsAvailable = !item.IsAvailable;
        await Db.SaveChangesAsync();
        await LoadItems();
    }

    private async Task DeleteItem(MenuItem item)
    {
        Db.MenuItems.Remove(item);
        await Db.SaveChangesAsync();

        await LoadItems();
        successMessage = "Dish deleted.";
    }

    private void ManageOptions(int menuItemId)
    {
        Navigation.NavigateTo($"/admin/restaurants/{RestaurantId}/items/{menuItemId}/options");
    }

    private void GoToCategories()
    {
        Navigation.NavigateTo($"/admin/restaurants/{RestaurantId}/categories");
    }

    private void GoToRestaurant()
    {
        if (restaurant is not null)
            Navigation.NavigateTo($"/restaurant/{restaurant.Slug}");
    }
}