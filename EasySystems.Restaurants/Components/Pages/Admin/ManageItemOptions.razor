@page "/admin/restaurants/{RestaurantId:int}/items/{MenuItemId:int}/options"
@rendermode InteractiveServer

@using EasySystems.Restaurants.Data
@using EasySystems.Restaurants.Models
@using EasySystems.Restaurants.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize]

@inject ApplicationDbContext Db
@inject NavigationManager Navigation
@inject RestaurantAccessService AccessService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Tillval och måltidsval</PageTitle>

@if (restaurant is not null && isAuthorized)
{
    <AdminNavbar RestaurantId="RestaurantId" RestaurantSlug="@restaurant.Slug" />
}

@if (!checkedAccess)
{
    <div class="public-loading">Kontrollerar behörighet...</div>
}
else if (!isAuthorized)
{
    <div class="public-loading">Omdirigerar...</div>
}
else
{
    <div class="admin-page">
        <div class="admin-header">
            <div>
                <p class="eyebrow">Meny</p>
                <h1>Tillval och måltidsval</h1>
                <p class="subtitle">
                    Skapa grupper för ingredienser, dryck, pommes, storlek och extra tillval.
                </p>
            </div>

            <div class="restaurant-admin-actions">
                <button type="button" @onclick="BackToItems">Tillbaka till rätter</button>
            </div>
        </div>

        @if (restaurant is null || menuItem is null)
        {
            <div class="form-card admin-center-card">
                <h2>Rätten hittades inte</h2>
                <p>Den här rätten finns inte.</p>
            </div>
        }
        else
        {
            <div class="admin-options-dashboard">
                <div class="options-left-column">
                    <div class="form-card">
                        <div class="dish-option-summary modern-dish-summary">
                            @if (!string.IsNullOrWhiteSpace(menuItem.ImageUrl))
                            {
                                <img src="@menuItem.ImageUrl" alt="@menuItem.Name" />
                            }

                            <div>
                                <span>@menuItem.MenuCategory?.Name</span>
                                <strong>@menuItem.Name</strong>
                                <p>@menuItem.Description</p>
                                <b>@menuItem.Price.ToString("0.00") kr</b>
                            </div>
                        </div>
                    </div>

                    <div class="form-card">
                        <div class="admin-card-title">
                            <div>
                                <h2>Ny grupp</h2>
                                <p>Exempel: Ingredienser, Välj dryck, Välj pommes eller Extra tillval.</p>
                            </div>
                            <span>@groups.Count grupper</span>
                        </div>

                        <label>Gruppnamn</label>
                        <InputText class="input"
                                   @bind-Value="newGroup.Name"
                                   placeholder="Exempel: Ingredienser" />

                        <label>Typ av grupp</label>
                        <div class="option-type-picker">
                            <button type="button"
                                    class="option-type-card @(newGroup.GroupType == IncludedIngredientsType ? "selected" : "")"
                                    @onclick="() => SetNewGroupType(IncludedIngredientsType)">
                                <strong>Ingredienser som ingår</strong>
                                <span>För saker som redan finns i rätten. Kunden kan ta bort dem.</span>
                            </button>

                            <button type="button"
                                    class="option-type-card @(newGroup.GroupType == SingleChoiceType ? "selected" : "")"
                                    @onclick="() => SetNewGroupType(SingleChoiceType)">
                                <strong>Välj ett alternativ</strong>
                                <span>För dryck, pommes eller storlek. Kunden väljer bara ett.</span>
                            </button>

                            <button type="button"
                                    class="option-type-card @(newGroup.GroupType == MultipleChoiceType ? "selected" : "")"
                                    @onclick="() => SetNewGroupType(MultipleChoiceType)">
                                <strong>Flera val</strong>
                                <span>För extra tillval. Kunden kan välja flera.</span>
                            </button>
                        </div>

                        @if (newGroup.GroupType != IncludedIngredientsType)
                        {
                            <label class="checkbox-label">
                                <InputCheckbox @bind-Value="newGroup.IsRequired" />
                                Kunden måste välja något i denna grupp
                            </label>
                        }

                        <label>Placering</label>
                        <InputNumber class="input" @bind-Value="newGroup.SortOrder" />

                        <label class="checkbox-label">
                            <InputCheckbox @bind-Value="newGroup.IsAvailable" />
                            Visa gruppen för kunder
                        </label>

                        <button class="save-btn" type="button" @onclick="AddGroup">
                            Lägg till grupp
                        </button>
                    </div>

                    <div class="form-card">
                        <div class="admin-card-title">
                            <div>
                                <h2>Nytt val</h2>
                                <p>Lägg till ingrediens, dryck, pommes, storlek eller extra tillval.</p>
                            </div>
                            <span>@options.Count val</span>
                        </div>

                        <label>Placera i grupp</label>
                        <InputSelect class="input" @bind-Value="newOption.MenuItemOptionGroupId" @onchange="OnNewOptionGroupChanged">
                            <option value="">Ingen grupp - vanligt tillval</option>
                            @foreach (var group in groups)
                            {
                                <option value="@group.Id">@group.Name (@FormatGroupType(group.GroupType))</option>
                            }
                        </InputSelect>

                        <label>Namn</label>
                        <InputText class="input"
                                   @bind-Value="newOption.Name"
                                   placeholder="Exempel: Lök, Coca-Cola, Stor pommes, Extra ost..." />

                        @if (SelectedNewOptionGroupType == IncludedIngredientsType)
                        {
                            <div class="upload-success">
                                Detta val kommer vara markerat från början. Kunden kan ta bort det.
                            </div>
                        }
                        else
                        {
                            <label>Extra pris</label>
                            <InputNumber class="input" @bind-Value="newOption.ExtraPrice" />
                        }

                        <label>Placering</label>
                        <InputNumber class="input" @bind-Value="newOption.SortOrder" />

                        <label class="checkbox-label">
                            <InputCheckbox @bind-Value="newOption.IsAvailable" />
                            Visa detta val för kunder
                        </label>

                        <button class="save-btn" type="button" @onclick="AddOption">
                            Lägg till val
                        </button>

                        @if (!string.IsNullOrWhiteSpace(errorMessage))
                        {
                            <div class="error">@errorMessage</div>
                        }

                        @if (!string.IsNullOrWhiteSpace(successMessage))
                        {
                            <div class="upload-success">@successMessage</div>
                        }
                    </div>

                    <div class="form-card category-help-card">
                        <h3>Exempel MAX/McDonald's</h3>
                        <ul>
                            <li><strong>Ingredienser:</strong> typ “Ingredienser som ingår”. Lägg till lök, sallad, tomat.</li>
                            <li><strong>Välj dryck:</strong> typ “Välj ett alternativ”. Lägg till Coca-Cola, Fanta, Sprite.</li>
                            <li><strong>Välj pommes:</strong> typ “Välj ett alternativ”. Lägg till Normal pommes, Stor pommes +10 kr.</li>
                            <li><strong>Extra tillval:</strong> typ “Flera val”. Lägg till Extra ost, Bacon, Extra kött.</li>
                        </ul>
                    </div>
                </div>

                <div class="preview-card">
                    <div class="admin-card-title">
                        <div>
                            <p class="preview-label">@menuItem.Name</p>
                            <h2>Val som kunden ser</h2>
                        </div>

                        <span>@AvailableOptionCount synliga</span>
                    </div>

                    @if (groups.Count == 0 && options.Count == 0)
                    {
                        <div class="empty-menu">
                            <h3>Inga val ännu</h3>
                            <p>Skapa en grupp eller lägg till vanliga tillval.</p>
                        </div>
                    }
                    else
                    {
                        <div class="option-section-grid">
                            @foreach (var group in groups.OrderBy(x => x.SortOrder).ThenBy(x => x.Name))
                            {
                                var groupOptions = options
                                .Where(x => x.MenuItemOptionGroupId == group.Id)
                                .OrderBy(x => x.SortOrder)
                                .ThenBy(x => x.Name)
                                .ToList();

                                <div class="option-group-admin-card @(group.IsAvailable ? "" : "is-hidden")">
                                    @if (editingGroupId == group.Id)
                                    {
                                        <div class="edit-category-form modern-option-edit">
                                            <h3>Redigera grupp</h3>

                                            <label>Gruppnamn</label>
                                            <InputText class="input" @bind-Value="editGroup.Name" />

                                            <label>Typ av grupp</label>
                                            <div class="option-type-picker">
                                                <button type="button"
                                                        class="option-type-card @(editGroup.GroupType == IncludedIngredientsType ? "selected" : "")"
                                                        @onclick="() => SetEditGroupType(IncludedIngredientsType)">
                                                    <strong>Ingredienser som ingår</strong>
                                                    <span>Kunden kan ta bort dessa.</span>
                                                </button>

                                                <button type="button"
                                                        class="option-type-card @(editGroup.GroupType == SingleChoiceType ? "selected" : "")"
                                                        @onclick="() => SetEditGroupType(SingleChoiceType)">
                                                    <strong>Välj ett alternativ</strong>
                                                    <span>Kunden väljer ett.</span>
                                                </button>

                                                <button type="button"
                                                        class="option-type-card @(editGroup.GroupType == MultipleChoiceType ? "selected" : "")"
                                                        @onclick="() => SetEditGroupType(MultipleChoiceType)">
                                                    <strong>Flera val</strong>
                                                    <span>Kunden kan välja flera.</span>
                                                </button>
                                            </div>

                                            @if (editGroup.GroupType != IncludedIngredientsType)
                                            {
                                                <label class="checkbox-label">
                                                    <InputCheckbox @bind-Value="editGroup.IsRequired" />
                                                    Kunden måste välja något
                                                </label>
                                            }

                                            <label>Placering</label>
                                            <InputNumber class="input" @bind-Value="editGroup.SortOrder" />

                                            <label class="checkbox-label">
                                                <InputCheckbox @bind-Value="editGroup.IsAvailable" />
                                                Visa gruppen för kunder
                                            </label>

                                            <div class="category-actions">
                                                <button type="button" class="save-small-btn" @onclick="SaveEditGroup">
                                                    Spara
                                                </button>

                                                <button type="button" @onclick="CancelEditGroup">
                                                    Avbryt
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="option-group-header">
                                            <div>
                                                <h3>@group.Name</h3>
                                                <p>@GetGroupSummary(group)</p>

                                                @if (!group.IsAvailable)
                                                {
                                                    <small class="hidden-badge">Dold</small>
                                                }
                                            </div>

                                            <div class="category-actions">
                                                <button type="button" @onclick="() => StartEditGroup(group)">
                                                    Redigera grupp
                                                </button>

                                                <button type="button" @onclick="() => ToggleGroupAvailability(group)">
                                                    @(group.IsAvailable ? "Dölj" : "Visa")
                                                </button>

                                                @if (pendingDeleteGroupId == group.Id)
                                                {
                                                    <button class="danger-btn" type="button" @onclick="() => DeleteGroup(group)">
                                                        Bekräfta radering
                                                    </button>

                                                    <button type="button" @onclick="CancelDeleteGroup">
                                                        Avbryt
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="danger-btn" type="button" @onclick="() => AskDeleteGroup(group)">
                                                        Radera grupp
                                                    </button>
                                                }
                                            </div>
                                        </div>

                                        @if (groupOptions.Count == 0)
                                        {
                                            <div class="empty-category">
                                                Inga val i denna grupp ännu.
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="option-admin-list modern-option-list">
                                                @foreach (var option in groupOptions)
                                                {
                                                    @OptionCard(option)
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            }

                            @if (UngroupedOptions.Count > 0)
                            {
                                <div>
                                    <h3>Vanliga tillval utan grupp</h3>

                                    <div class="option-admin-list modern-option-list">
                                        @foreach (var option in UngroupedOptions)
                                        {
                                            @OptionCard(option)
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public int RestaurantId { get; set; }
    [Parameter] public int MenuItemId { get; set; }

    private const string IncludedIngredientsType = "IncludedIngredients";
    private const string SingleChoiceType = "SingleChoice";
    private const string MultipleChoiceType = "MultipleChoice";

    private Restaurant? restaurant;
    private MenuItem? menuItem;

    private List<MenuItemOptionGroup> groups = [];
    private List<MenuItemOption> options = [];

    private string? errorMessage;
    private string? successMessage;

    private int? editingGroupId;
    private int? pendingDeleteGroupId;

    private int? editingOptionId;
    private int? pendingDeleteOptionId;

    private bool checkedAccess;
    private bool isAuthorized;

    private int AvailableOptionCount => options.Count(x => x.IsAvailable);

    private string SelectedNewOptionGroupType
    {
        get
        {
            if (newOption.MenuItemOptionGroupId is null)
                return string.Empty;

            return groups.FirstOrDefault(x => x.Id == newOption.MenuItemOptionGroupId.Value)?.GroupType ?? string.Empty;
        }
    }

    private List<MenuItemOption> UngroupedOptions => options
    .Where(x => x.MenuItemOptionGroupId is null)
    .OrderByDescending(x => x.IsDefaultIncluded)
    .ThenBy(x => x.SortOrder)
    .ThenBy(x => x.Name)
    .ToList();

    private MenuItemOptionGroup newGroup = new()
            {
                IsRequired = true,
                AllowMultiple = false,
                IsAvailable = true,
                SortOrder = 1,
                GroupType = SingleChoiceType
            };

    private MenuItemOptionGroup editGroup = new();

    private MenuItemOption newOption = new()
            {
                IsAvailable = true,
                IsDefaultIncluded = false
            };

    private MenuItemOption editOption = new();

    protected override async Task OnParametersSetAsync()
    {
        checkedAccess = false;
        isAuthorized = false;
        errorMessage = null;
        successMessage = null;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        isAuthorized = await AccessService.CanManageRestaurantMenuAsync(
        authState.User,
        RestaurantId);

        checkedAccess = true;

        if (!isAuthorized)
        {
            Navigation.NavigateTo("/Account/Denied", true);
            return;
        }

        restaurant = await Db.Restaurants.FirstOrDefaultAsync(x => x.Id == RestaurantId);

        if (restaurant is null)
            return;

        menuItem = await Db.MenuItems
        .Include(x => x.MenuCategory)
        .FirstOrDefaultAsync(x =>
            x.Id == MenuItemId &&
            x.MenuCategory != null &&
            x.MenuCategory.RestaurantId == RestaurantId);

        if (menuItem is null)
            return;

        await LoadData();
        ResetNewGroup();
        ResetNewOption();
    }

    private async Task LoadData()
    {
        if (!isAuthorized)
            return;

        groups = await Db.MenuItemOptionGroups
        .Where(x => x.MenuItemId == MenuItemId)
        .OrderBy(x => x.SortOrder)
        .ThenBy(x => x.Name)
        .ToListAsync();

        options = await Db.MenuItemOptions
        .Include(x => x.MenuItemOptionGroup)
        .Where(x => x.MenuItemId == MenuItemId)
        .OrderBy(x => x.MenuItemOptionGroupId == null ? 1 : 0)
        .ThenBy(x => x.MenuItemOptionGroup!.SortOrder)
        .ThenBy(x => x.SortOrder)
        .ThenBy(x => x.Name)
        .ToListAsync();
    }

    private void ResetNewGroup()
    {
        newGroup = new MenuItemOptionGroup
                {
                    MenuItemId = MenuItemId,
                    Name = string.Empty,
                    GroupType = SingleChoiceType,
                    IsRequired = true,
                    AllowMultiple = false,
                    IsAvailable = true,
                    SortOrder = groups.Count == 0 ? 1 : groups.Max(x => x.SortOrder) + 1
                };
    }

    private void ResetNewOption()
    {
        newOption = new MenuItemOption
                {
                    MenuItemId = MenuItemId,
                    MenuItemOptionGroupId = groups.FirstOrDefault()?.Id,
                    IsAvailable = true,
                    IsDefaultIncluded = false,
                    ExtraPrice = 0,
                    SortOrder = options.Count + 1
                };

        ApplyOptionDefaultsFromSelectedGroup();
    }

    private void SetNewGroupType(string groupType)
    {
        newGroup.GroupType = groupType;

        if (groupType == IncludedIngredientsType)
        {
            newGroup.IsRequired = false;
            newGroup.AllowMultiple = true;
        }
        else if (groupType == SingleChoiceType)
        {
            newGroup.AllowMultiple = false;
            newGroup.IsRequired = true;
        }
        else if (groupType == MultipleChoiceType)
        {
            newGroup.AllowMultiple = true;
            newGroup.IsRequired = false;
        }
    }

    private void SetEditGroupType(string groupType)
    {
        editGroup.GroupType = groupType;

        if (groupType == IncludedIngredientsType)
        {
            editGroup.IsRequired = false;
            editGroup.AllowMultiple = true;
        }
        else if (groupType == SingleChoiceType)
        {
            editGroup.AllowMultiple = false;
            editGroup.IsRequired = true;
        }
        else if (groupType == MultipleChoiceType)
        {
            editGroup.AllowMultiple = true;
            editGroup.IsRequired = false;
        }
    }

    private async Task AddGroup()
    {
        errorMessage = null;
        successMessage = null;
        pendingDeleteGroupId = null;

        if (!isAuthorized || menuItem is null)
            return;

        newGroup.Name = newGroup.Name?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(newGroup.Name))
        {
            errorMessage = "Gruppnamn krävs.";
            return;
        }

        ApplyGroupRules(newGroup);
        newGroup.MenuItemId = MenuItemId;

        Db.MenuItemOptionGroups.Add(newGroup);
        await Db.SaveChangesAsync();

        await LoadData();
        ResetNewGroup();
        ResetNewOption();

        successMessage = "Gruppen har lagts till.";
    }

    private void StartEditGroup(MenuItemOptionGroup group)
    {
        errorMessage = null;
        successMessage = null;
        pendingDeleteGroupId = null;

        editingGroupId = group.Id;

        editGroup = new MenuItemOptionGroup
                {
                    Id = group.Id,
                    MenuItemId = group.MenuItemId,
                    Name = group.Name,
                    GroupType = string.IsNullOrWhiteSpace(group.GroupType) ? SingleChoiceType : group.GroupType,
                    IsRequired = group.IsRequired,
                    AllowMultiple = group.AllowMultiple,
                    SortOrder = group.SortOrder,
                    IsAvailable = group.IsAvailable
                };
    }

    private void CancelEditGroup()
    {
        editingGroupId = null;
        editGroup = new MenuItemOptionGroup();
        errorMessage = null;
    }

    private async Task SaveEditGroup()
    {
        errorMessage = null;
        successMessage = null;

        if (!isAuthorized || editingGroupId is null)
            return;

        editGroup.Name = editGroup.Name?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(editGroup.Name))
        {
            errorMessage = "Gruppnamn krävs.";
            return;
        }

        var group = await Db.MenuItemOptionGroups
        .FirstOrDefaultAsync(x => x.Id == editingGroupId.Value && x.MenuItemId == MenuItemId);

        if (group is null)
        {
            errorMessage = "Gruppen hittades inte.";
            return;
        }

        ApplyGroupRules(editGroup);

        group.Name = editGroup.Name;
        group.GroupType = editGroup.GroupType;
        group.IsRequired = editGroup.IsRequired;
        group.AllowMultiple = editGroup.AllowMultiple;
        group.SortOrder = editGroup.SortOrder;
        group.IsAvailable = editGroup.IsAvailable;

        await Db.SaveChangesAsync();
        await LoadData();

        editingGroupId = null;
        successMessage = "Gruppen har uppdaterats.";
    }

    private async Task ToggleGroupAvailability(MenuItemOptionGroup group)
    {
        errorMessage = null;
        successMessage = null;

        var dbGroup = await Db.MenuItemOptionGroups
        .FirstOrDefaultAsync(x => x.Id == group.Id && x.MenuItemId == MenuItemId);

        if (dbGroup is null)
            return;

        dbGroup.IsAvailable = !dbGroup.IsAvailable;

        await Db.SaveChangesAsync();
        await LoadData();

        successMessage = dbGroup.IsAvailable
        ? "Gruppen visas nu för kunder."
        : "Gruppen är nu dold för kunder.";
    }

    private void AskDeleteGroup(MenuItemOptionGroup group)
    {
        errorMessage = null;
        successMessage = null;
        pendingDeleteGroupId = group.Id;
    }

    private void CancelDeleteGroup()
    {
        pendingDeleteGroupId = null;
        errorMessage = null;
    }

    private async Task DeleteGroup(MenuItemOptionGroup group)
    {
        errorMessage = null;
        successMessage = null;

        var hasOptions = await Db.MenuItemOptions.AnyAsync(x => x.MenuItemOptionGroupId == group.Id);

        if (hasOptions)
        {
            errorMessage = "Gruppen innehåller val. Flytta eller radera valen först.";
            pendingDeleteGroupId = null;
            return;
        }

        var dbGroup = await Db.MenuItemOptionGroups
        .FirstOrDefaultAsync(x => x.Id == group.Id && x.MenuItemId == MenuItemId);

        if (dbGroup is null)
            return;

        Db.MenuItemOptionGroups.Remove(dbGroup);
        await Db.SaveChangesAsync();

        pendingDeleteGroupId = null;

        await LoadData();
        ResetNewGroup();
        ResetNewOption();

        successMessage = "Gruppen har raderats.";
    }

    private void OnNewOptionGroupChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var groupId))
            newOption.MenuItemOptionGroupId = groupId;
        else
            newOption.MenuItemOptionGroupId = null;

        ApplyOptionDefaultsFromSelectedGroup();
    }

    private void ApplyOptionDefaultsFromSelectedGroup()
    {
        if (SelectedNewOptionGroupType == IncludedIngredientsType)
        {
            newOption.IsDefaultIncluded = true;
            newOption.ExtraPrice = 0;
        }
        else
        {
            newOption.IsDefaultIncluded = false;
        }
    }

    private async Task AddOption()
    {
        errorMessage = null;
        successMessage = null;
        pendingDeleteOptionId = null;

        if (!isAuthorized || menuItem is null)
            return;

        newOption.Name = newOption.Name?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(newOption.Name))
        {
            errorMessage = "Namn krävs.";
            return;
        }

        var groupType = string.Empty;

        if (newOption.MenuItemOptionGroupId.HasValue)
        {
            var group = await Db.MenuItemOptionGroups
            .FirstOrDefaultAsync(x => x.Id == newOption.MenuItemOptionGroupId.Value && x.MenuItemId == MenuItemId);

            if (group is null)
            {
                errorMessage = "Gruppen hittades inte.";
                return;
            }

            groupType = group.GroupType;
        }

        if (groupType == IncludedIngredientsType)
        {
            newOption.IsDefaultIncluded = true;
            newOption.ExtraPrice = 0;
        }
        else
        {
            newOption.IsDefaultIncluded = false;
        }

        if (newOption.ExtraPrice < 0)
        {
            errorMessage = "Extra pris kan inte vara negativt.";
            return;
        }

        newOption.MenuItemId = MenuItemId;

        Db.MenuItemOptions.Add(newOption);
        await Db.SaveChangesAsync();

        await LoadData();
        ResetNewOption();

        successMessage = "Valet har sparats.";
    }

    private void StartEditOption(MenuItemOption option)
    {
        if (!isAuthorized)
            return;

        errorMessage = null;
        successMessage = null;
        pendingDeleteOptionId = null;

        editingOptionId = option.Id;

        editOption = new MenuItemOption
                {
                    Id = option.Id,
                    MenuItemId = option.MenuItemId,
                    MenuItemOptionGroupId = option.MenuItemOptionGroupId,
                    Name = option.Name,
                    ExtraPrice = option.ExtraPrice,
                    IsDefaultIncluded = option.IsDefaultIncluded,
                    SortOrder = option.SortOrder,
                    IsAvailable = option.IsAvailable
                };
    }

    private void CancelEditOption()
    {
        editingOptionId = null;
        editOption = new MenuItemOption();
        errorMessage = null;
    }

    private async Task SaveEditOption()
    {
        errorMessage = null;
        successMessage = null;

        if (!isAuthorized || editingOptionId is null)
            return;

        editOption.Name = editOption.Name?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(editOption.Name))
        {
            errorMessage = "Namn krävs.";
            return;
        }

        var option = await Db.MenuItemOptions
        .Include(x => x.MenuItem)
        .ThenInclude(x => x!.MenuCategory)
        .FirstOrDefaultAsync(x =>
            x.Id == editingOptionId.Value &&
            x.MenuItemId == MenuItemId &&
            x.MenuItem != null &&
            x.MenuItem.MenuCategory != null &&
            x.MenuItem.MenuCategory.RestaurantId == RestaurantId);

        if (option is null)
        {
            errorMessage = "Valet hittades inte.";
            return;
        }

        var groupType = string.Empty;

        if (editOption.MenuItemOptionGroupId.HasValue)
        {
            var group = await Db.MenuItemOptionGroups
            .FirstOrDefaultAsync(x => x.Id == editOption.MenuItemOptionGroupId.Value && x.MenuItemId == MenuItemId);

            if (group is null)
            {
                errorMessage = "Gruppen hittades inte.";
                return;
            }

            groupType = group.GroupType;
        }

        if (groupType == IncludedIngredientsType)
        {
            editOption.IsDefaultIncluded = true;
            editOption.ExtraPrice = 0;
        }
        else
        {
            editOption.IsDefaultIncluded = false;
        }

        if (editOption.ExtraPrice < 0)
        {
            errorMessage = "Extra pris kan inte vara negativt.";
            return;
        }

        option.MenuItemOptionGroupId = editOption.MenuItemOptionGroupId;
        option.Name = editOption.Name;
        option.ExtraPrice = editOption.ExtraPrice;
        option.IsDefaultIncluded = editOption.IsDefaultIncluded;
        option.SortOrder = editOption.SortOrder;
        option.IsAvailable = editOption.IsAvailable;

        await Db.SaveChangesAsync();
        await LoadData();

        editingOptionId = null;
        successMessage = "Valet har uppdaterats.";
    }

    private async Task ToggleAvailability(MenuItemOption option)
    {
        if (!isAuthorized)
            return;

        errorMessage = null;
        successMessage = null;
        pendingDeleteOptionId = null;

        var dbOption = await Db.MenuItemOptions
        .Include(x => x.MenuItem)
        .ThenInclude(x => x!.MenuCategory)
        .FirstOrDefaultAsync(x =>
            x.Id == option.Id &&
            x.MenuItemId == MenuItemId &&
            x.MenuItem != null &&
            x.MenuItem.MenuCategory != null &&
            x.MenuItem.MenuCategory.RestaurantId == RestaurantId);

        if (dbOption is null)
            return;

        dbOption.IsAvailable = !dbOption.IsAvailable;

        await Db.SaveChangesAsync();
        await LoadData();

        successMessage = dbOption.IsAvailable
        ? "Valet visas nu för kunder."
        : "Valet är nu dolt för kunder.";
    }

    private void AskDelete(MenuItemOption option)
    {
        errorMessage = null;
        successMessage = null;
        pendingDeleteOptionId = option.Id;
    }

    private void CancelDelete()
    {
        pendingDeleteOptionId = null;
        errorMessage = null;
    }

    private async Task DeleteOption(MenuItemOption option)
    {
        if (!isAuthorized)
            return;

        errorMessage = null;
        successMessage = null;

        var dbOption = await Db.MenuItemOptions
        .Include(x => x.MenuItem)
        .ThenInclude(x => x!.MenuCategory)
        .FirstOrDefaultAsync(x =>
            x.Id == option.Id &&
            x.MenuItemId == MenuItemId &&
            x.MenuItem != null &&
            x.MenuItem.MenuCategory != null &&
            x.MenuItem.MenuCategory.RestaurantId == RestaurantId);

        if (dbOption is null)
            return;

        Db.MenuItemOptions.Remove(dbOption);
        await Db.SaveChangesAsync();

        pendingDeleteOptionId = null;

        await LoadData();

        successMessage = "Valet har raderats.";
    }

    private RenderFragment OptionCard(MenuItemOption option) => @<div class="option-admin-card modern-option-card @(option.IsAvailable ? "" : "is-hidden")">
        @if (editingOptionId == option.Id)
    {
        <div class="edit-category-form modern-option-edit">
            <h3>Redigera val</h3>

            <label>Grupp</label>
            <InputSelect class="input" @bind-Value="editOption.MenuItemOptionGroupId">
                <option value="">Ingen grupp - vanligt tillval</option>
                @foreach (var group in groups)
            {
                <option value="@group.Id">@group.Name (@FormatGroupType(group.GroupType))</option>
            }
            </InputSelect>

            <label>Namn</label>
            <InputText class="input" @bind-Value="editOption.Name" />

            @if (GetGroupType(editOption.MenuItemOptionGroupId) == IncludedIngredientsType)
        {
            <div class="upload-success">
                Detta är en ingrediens som ingår. Kunden kan ta bort den.
            </div>
        }
        else
        {
            <label>Extra pris</label>
            <InputNumber class="input" @bind-Value="editOption.ExtraPrice" />
        }

            <label>Placering</label>
            <InputNumber class="input" @bind-Value="editOption.SortOrder" />

            <label class="checkbox-label">
                <InputCheckbox @bind-Value="editOption.IsAvailable" />
                Visa detta val för kunder
            </label>

            <div class="category-actions">
                <button type="button" class="save-small-btn" @onclick="SaveEditOption">
                    Spara
                </button>

                <button type="button" @onclick="CancelEditOption">
                    Avbryt
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="option-card-main">
            <div>
                <strong>@option.Name</strong>

                @if (GetGroupType(option.MenuItemOptionGroupId) == IncludedIngredientsType)
            {
                <span class="included-tag">Ingår - kan tas bort</span>
            }
            else if (option.ExtraPrice > 0)
            {
                <span class="extra-price-tag">+@option.ExtraPrice.ToString("0.00") kr</span>
            }
            else
            {
                <span class="included-tag">0 kr</span>
            }

                @if (!option.IsAvailable)
            {
                <small class="hidden-badge">Dold</small>
            }
            </div>

            <small>Placering: @option.SortOrder</small>
        </div>

        <div class="category-actions option-actions-modern">
            <button type="button" @onclick="() => StartEditOption(option)">
                Redigera
            </button>

            <button type="button" @onclick="() => ToggleAvailability(option)">
                @(option.IsAvailable ? "Dölj" : "Visa")
            </button>

            @if (pendingDeleteOptionId == option.Id)
        {
            <button class="danger-btn" type="button" @onclick="() => DeleteOption(option)">
                Bekräfta radering
            </button>

            <button type="button" @onclick="CancelDelete">
                Avbryt
            </button>
        }
        else
        {
            <button class="danger-btn" type="button" @onclick="() => AskDelete(option)">
                Radera
            </button>
        }
        </div>
    }
    </div>;

    private void ApplyGroupRules(MenuItemOptionGroup group)
    {
        if (group.GroupType == IncludedIngredientsType)
        {
            group.IsRequired = false;
            group.AllowMultiple = true;
        }
        else if (group.GroupType == SingleChoiceType)
        {
            group.AllowMultiple = false;
        }
        else if (group.GroupType == MultipleChoiceType)
        {
            group.AllowMultiple = true;
        }
    }

    private string GetGroupType(int? groupId)
    {
        if (groupId is null)
            return string.Empty;

        return groups.FirstOrDefault(x => x.Id == groupId.Value)?.GroupType ?? string.Empty;
    }

    private string FormatGroupType(string? groupType)
    {
        return groupType switch
        {
            IncludedIngredientsType => "Ingredienser",
            SingleChoiceType => "Ett val",
            MultipleChoiceType => "Flera val",
            _ => "Ett val"
        };
    }

    private string GetGroupSummary(MenuItemOptionGroup group)
    {
        return group.GroupType switch
        {
            IncludedIngredientsType => "Ingredienser som ingår • kunden kan ta bort",
            SingleChoiceType => $"{(group.IsRequired ? "Obligatorisk" : "Frivillig")} • Ett val",
            MultipleChoiceType => $"{(group.IsRequired ? "Obligatorisk" : "Frivillig")} • Flera val",
            _ => "Ett val"
        };
    }

    private void BackToItems()
    {
        Navigation.NavigateTo($"/admin/restaurants/{RestaurantId}/items");
    }
}