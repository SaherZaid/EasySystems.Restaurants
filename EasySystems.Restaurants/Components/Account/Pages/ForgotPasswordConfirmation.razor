@page "/Account/ForgotPasswordConfirmation"

<PageTitle>E-post skickad</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <span>ES</span>
            <div>
                <strong>EasySystems</strong>
                <p>Återställ lösenord</p>
            </div>
        </div>

        <div class="auth-header">
            <p class="eyebrow">Kontrollera din e-post</p>
            <h1>Återställningslänk skickad</h1>
            <p>
                Om det finns ett konto med den e-postadressen har vi skickat en länk för att återställa lösenordet.
                Kontrollera din inkorg och även skräpposten.
            </p>
        </div>

        <div class="auth-links">
            <a href="/Account/Login">Tillbaka till inloggning</a>
            <a href="/Account/Register">Skapa konto</a>
        </div>
    </div>

    <div class="auth-side">
        <div class="auth-side-content">
            <span class="auth-badge">Nästan klart</span>
            <h2>Öppna din e-post och fortsätt.</h2>
            <p>
                Klicka på länken vi skickade för att återställa lösenordet säkert och komma in på ditt konto igen.
            </p>

            <div class="auth-points">
                <div>
                    <strong>01</strong>
                    <span>Kontrollera din inkorg</span>
                </div>

                <div>
                    <strong>02</strong>
                    <span>Klicka på återställningslänken</span>
                </div>

                <div>
                    <strong>03</strong>
                    <span>Skapa ditt nya lösenord</span>
                </div>
            </div>
        </div>
    </div>
</div>