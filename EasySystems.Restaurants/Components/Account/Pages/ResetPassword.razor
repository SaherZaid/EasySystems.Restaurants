@page "/Account/ResetPassword"

@using System.ComponentModel.DataAnnotations
@using System.Text
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using EasySystems.Restaurants.Data

@inject IdentityRedirectManager RedirectManager
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Återställ lösenord</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <span>ES</span>
            <div>
                <strong>EasySystems</strong>
                <p>Säker återställning av lösenord</p>
            </div>
        </div>

        <StatusMessage Message="@Message" />

        <EditForm Model="Input" FormName="reset-password" OnValidSubmit="OnValidSubmitAsync" method="post">
            <DataAnnotationsValidator />

            <input type="hidden" name="Input.Code" value="@Input.Code" />

            <div class="auth-header">
                <p class="eyebrow">Återställ lösenord</p>
                <h1>Skapa ett nytt lösenord</h1>
                <p>Ange din e-post och välj ett nytt säkert lösenord för ditt konto.</p>
            </div>

            <ValidationSummary class="auth-error-list" role="alert" />

            <div class="auth-field">
                <label for="Input.Email">E-post</label>
                <InputText @bind-Value="Input.Email"
                           id="Input.Email"
                           class="auth-input"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="namn@example.com" />
                <ValidationMessage For="() => Input.Email" class="auth-validation" />
            </div>

            <div class="auth-field">
                <label for="Input.Password">Nytt lösenord</label>
                <InputText type="password"
                           @bind-Value="Input.Password"
                           id="Input.Password"
                           class="auth-input"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="••••••••" />
                <ValidationMessage For="() => Input.Password" class="auth-validation" />
            </div>

            <div class="auth-field">
                <label for="Input.ConfirmPassword">Bekräfta nytt lösenord</label>
                <InputText type="password"
                           @bind-Value="Input.ConfirmPassword"
                           id="Input.ConfirmPassword"
                           class="auth-input"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="••••••••" />
                <ValidationMessage For="() => Input.ConfirmPassword" class="auth-validation" />
            </div>

            <button type="submit" class="auth-submit">
                Återställ lösenord
            </button>

            <div class="auth-links">
                <a href="/Account/Login">Tillbaka till inloggning</a>
                <a href="/Account/Register">Skapa konto</a>
            </div>
        </EditForm>
    </div>

    <div class="auth-side">
        <div class="auth-side-content">
            <span class="auth-badge">Kontoåterställning</span>
            <h2>Skapa ett nytt lösenord och logga in säkert igen.</h2>
            <p>
                Ditt nya lösenord används nästa gång du loggar in på ditt EasySystems-konto.
            </p>

            <div class="auth-points">
                <div>
                    <strong>01</strong>
                    <span>Använd e-posten som är kopplad till ditt konto</span>
                </div>

                <div>
                    <strong>02</strong>
                    <span>Välj ett starkt nytt lösenord</span>
                </div>

                <div>
                    <strong>03</strong>
                    <span>Logga in säkert igen</span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private IEnumerable<IdentityError>? identityErrors;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? Code { get; set; }

    private string? Message =>
        identityErrors is null
            ? null
            : $"Fel: {string.Join(", ", identityErrors.Select(error => error.Description))}";

    protected override void OnInitialized()
    {
        if (Code is null)
        {
            RedirectManager.RedirectTo("Account/InvalidPasswordReset");
            return;
        }

        Input.Code = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Code));
    }

    private async Task OnValidSubmitAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);

        if (user is null)
        {
            RedirectManager.RedirectTo("Account/ResetPasswordConfirmation");
            return;
        }

        var result = await UserManager.ResetPasswordAsync(user, Input.Code, Input.Password);

        if (result.Succeeded)
        {
            RedirectManager.RedirectTo("Account/ResetPasswordConfirmation");
            return;
        }

        identityErrors = result.Errors;
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "E-post krävs.")]
        [EmailAddress(ErrorMessage = "Ange en giltig e-postadress.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Lösenord krävs.")]
        [StringLength(100, ErrorMessage = "Lösenordet måste vara minst {2} och max {1} tecken långt.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Bekräfta lösenord krävs.")]
        [DataType(DataType.Password)]
        [Display(Name = "Bekräfta lösenord")]
        [Compare("Password", ErrorMessage = "Lösenorden matchar inte.")]
        public string ConfirmPassword { get; set; } = "";

        [Required]
        public string Code { get; set; } = "";
    }
}